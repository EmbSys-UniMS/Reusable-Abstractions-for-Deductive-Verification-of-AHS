"  ==>  (((((hMAX())+((((0))-(supMAX()))*(TS()))) >= (hDEG()))&((((hDEG())+((((0))-(supDEG()))*(TS()))) >= (hMIN()))&(((hMIN()) >= ((0)))&(((h) > (hMAX()))&((true)&((iMAX()) > ((0))))))))&((((c) = ((0)))&(((TS()) >= (c))&(((TS()) > ((0)))&((t) = ((0))))))&((((supMAX()) >= (supDEG()))&(((supDEG()) > ((0)))&(((iMAX()) >= (supMAX()))&(((pRate()) > ((0)))&((((3))*(pRate())) = (iMAX()))))))&(((\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supMAX()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hMAX()))&(((h)+((((0))-(asup))*(TS()))) > (hDEG())))))))))))->((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supMAX()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hMAX()))&(((h)+((((0))-(asup))*(TS()))) > (hDEG()))))))))&((((!(\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supMAX()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hMAX()))&(((h)+((((0))-(asup))*(TS()))) > (hDEG()))))))))))))&(\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supDEG()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hDEG()))&(((h)+((((0))-(asup))*(TS()))) > (hMIN()))))))))))))->((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supDEG()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hDEG()))&(((h)+((((0))-(asup))*(TS()))) > (hMIN()))))))))&((((!(\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supMAX()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hMAX()))&(((h)+((((0))-(asup))*(TS()))) > (hDEG()))))))))))))&((!(\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supDEG()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hDEG()))&(((h)+((((0))-(asup))*(TS()))) > (hMIN()))))))))))))&(\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&((asup) = ((0))))))))))))->((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&((asup) = ((0)))))))&((((failOld) = (fail))&((fail) = ((0))))&(((p1) = ((1)))&(((p2) = ((1)))&((p3) = ((1))))))))))))->([{{{{?((c) >= (TS()));};{{c:=(0);};{{asup:=*;};{{a1:=*;};{{a2:=*;};{{a3:=*;};{{{?(\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supMAX()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hMAX()))&(((h)+((((0))-(asup))*(TS()))) > (hDEG())))))))))));};{?((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supMAX()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hMAX()))&(((h)+((((0))-(asup))*(TS()))) > (hDEG())))))));}}++{{?(!(\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supMAX()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hMAX()))&(((h)+((((0))-(asup))*(TS()))) > (hDEG()))))))))))));};{{{?(\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supDEG()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hDEG()))&(((h)+((((0))-(asup))*(TS()))) > (hMIN())))))))))));};{?((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supDEG()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hDEG()))&(((h)+((((0))-(asup))*(TS()))) > (hMIN())))))));}}++{{?(!(\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&(((asup) = (supDEG()))&((((h)+((((((a1)+(a2))+(a3))*(pRate()))-(asup))*(TS()))) > (hDEG()))&(((h)+((((0))-(asup))*(TS()))) > (hMIN()))))))))))));};{{{?(\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&((asup) = ((0))))))))));};{?((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&((asup) = ((0))))));}}++{?(!(\exists a1 (\exists a2 (\exists a3 (\exists asup ((((a1) = ((0)))|((a1) = ((1))))&((((a2) = ((0)))|((a2) = ((1))))&((((a3) = ((0)))|((a3) = ((1))))&((asup) = ((0)))))))))));}}}}}}}}}}}}++{?(!((c) >= (TS())));}};{{{failOld:=fail;};{{{{fail:=(0);};{{p1:=(1);};{{p2:=(1);};{p3:=(1);}}}}++{{fail:=(1);};{{p1:=*;};{{p2:=*;};{{p3:=*;};{?((((p1) = ((1)))|((p1) = ((0))))&((((p2) = ((1)))|((p2) = ((0))))&((((p3) = ((1)))|((p3) = ((0))))&((((p1)+(p2))+(p3)) < ((3))))));}}}}}};{{{?((fail) > (failOld));};{{ths:=t;};{{hhs:=h;};{shs:=asup;}}}}++{?(!((fail) > (failOld)));}}}};{{i:=(((min<< ._1 < ._2&._0=._1|._1>=._2&._0=._2 >>((a1,p1)))+(min<< ._1 < ._2&._0=._1|._1>=._2&._0=._2 >>((a2,p2))))+(min<< ._1 < ._2&._0=._1|._1>=._2&._0=._2 >>((a3,p3))))*(pRate());};{{d:=*;};{{?(((0)) <= (d));};{{?((d) <= (asup));};{{t'=(1),c'=(1),h'=(i)-(d)&(c) <= (TS())}}}}}}}}*]((((fail) = ((1)))&(((hhs) > (hMAX()))&(((shs) >= (supMAX()))&(((t)-(ths)) <= (((hMAX())-(hDEG()))/(supMAX()))))))->(((h) > (hDEG()))&((asup) >= (supDEG())))))
\qed::accc5867ac1cb20429a8f3bb2d2cd74a"
End.
Tool.
  tool """" KeYmaera X """"
  model """" Theorem "FMAISOLA/IWDSa"

ProgramVariables
    Real c;
    Real t;
    
    Real h; /* h= waterlevel l */
    Real d;
    Real i;
    
    Real asup;
    Real a1; 
    Real a2;
    Real a3;
    Real p1;
    Real p2;
    Real p3;
    
    Real hhs;
    Real ths;
    Real shs;
    Real failOld;
    Real fail;
End.

Definitions
    Real TS;
    /* max inflow */
    Real iMAX;
    /* pump rate */
    Real pRate; 
    
    
    Real hMAX;
    Real hDEG;
    Real hMIN;
    /* Supply */
    Real supMAX; 
    Real supDEG;
    Real sMIN;
    
    /* Contracts */
    Real WCRREPAIR(Real a1, Real a2, Real a3, Real asup)         =   ((a1+a2+a3)*pRate-asup)*(TS);  
    Real WCRFAIL(Real asup)                                      =   (0-asup)*(TS); 
    Bool SLFULL(Real h, Real a1, Real a2, Real a3, Real asup)    <-> (a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1) & asup=supMAX & h+WCRREPAIR(a1, a2, a3, asup) > hMAX & h+WCRFAIL(asup) > hDEG;
    Bool SLDEG(Real h, Real a1, Real a2, Real a3, Real asup)     <-> (a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1) & asup=supDEG & h+WCRREPAIR(a1, a2, a3, asup) > hDEG & h+WCRFAIL(asup) > hMIN;
    Bool SLMIN(Real h, Real a1, Real a2, Real a3, Real asup)     <-> (a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1) & asup=0; 
    Bool CHECKFULL(Real h) <-> (\exists a1 \exists a2 \exists a3 \exists asup SLFULL(h, a1, a2, a3, asup));
    Bool CHECKDEG(Real h) <-> (\exists a1 \exists a2 \exists a3 \exists asup SLDEG(h, a1, a2, a3, asup));
    Bool CHECKMIN(Real h) <-> (\exists a1 \exists a2 \exists a3 \exists asup SLMIN(h, a1, a2, a3, asup));
    Real tMAX = (hMAX-hDEG)/supMAX; /*max time for degrading from hMAX to hDEG*/
End.


Problem
(hMAX+WCRFAIL(supMAX) >= hDEG & hDEG+WCRFAIL(supDEG) >= hMIN & hMIN >= 0 & h > hMAX & true &iMAX>0)&
(c=0 & TS>=c & TS >0 & t=0) &
(supMAX>=supDEG & supDEG>0 & iMAX>=supMAX & pRate>0 & 3*pRate=iMAX) &
/* contracts hold initially */
((CHECKFULL(h))->SLFULL(h, a1, a2, a3, asup)) &
((!CHECKFULL(h)&CHECKDEG(h))->SLDEG(h, a1, a2, a3, asup)) &
((!CHECKFULL(h)&!CHECKDEG(h)&CHECKMIN(h))->SLMIN(h, a1, a2, a3, asup)) &
/* pumps are working initially */
(failOld = fail & fail= 0) & p1=1 & p2=1 & p3=1
->
[
    {   
        if(c>=TS) /* Resilience Contract Embedding */
        {
            c:=0;asup:=*;a1:=*; a2:=*;a3:=*;
            if(CHECKFULL(h)){?SLFULL(h, a1, a2, a3, asup);}
            else 
            {
                if(CHECKDEG(h)) {?SLDEG(h, a1, a2, a3, asup);}
                else 
                {
                    if(CHECKMIN(h)) {?SLMIN(h, a1, a2, a3, asup);}
                }
            }
            
        }
        {failOld:=fail;
        {fail:=0; p1:=1; p2:=1; p3:=1; ++ fail:=1; p1:=*; p2:=*; p3:=*; ?(p1=1|p1=0)&(p2=1|p2=0)&(p3=1|p3=0)&p1+p2+p3<3;}; /*pump system can fail*/
        if(fail>failOld)  /* store state in case of failure */
        {
            ths:=t; hhs:=h; shs:=asup;
        };}
        i:=(min(a1,p1)+min(a2,p2)+min(a3,p3))*pRate; /* caclulate inflow */
        d:=*;?0<=d;?d<=asup;                        /* choose demand */
        {t'=1, c'=1, h'=i-d & c<= TS} /* evolution */
    }*@invariant((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&(0<=(a1+a2+a3)*pRate & (a1+a2+a3)*pRate<=iMAX & asup<=supMAX & TS>=c & c>=0 & 
    (fail =0 | fail =1)) & 
    (fail=1 & hhs>hMAX & shs>=supMAX & t-ths<=tMAX -> h>=hhs-supMAX*(t-ths) & h>hDEG & asup>=supDEG ) )
] ((fail=1 & hhs>hMAX & shs>=supMAX & t-ths<=tMAX)->h>hDEG & asup>=supDEG)
End.

Tactic "FMAISOLA/PropAGreater: Proof"
expandAllDefs();
unfold;
loop("(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&(0<=(a1+a2+a3)*pRate()&(a1+a2+a3)*pRate()<=iMAX()&asup<=supMAX()&TS()>=c&c>=0&(fail=0|fail=1))&(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG())", 'R=="[{{?c>=TS();c:=0;asup:=*;a1:=*;a2:=*;a3:=*;{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG());?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG();++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG());{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN());?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN();++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN());{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0);?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0;++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0);}}}++?!c>=TS();}{failOld:=fail;{fail:=0;p1:=1;p2:=1;p3:=1;++fail:=1;p1:=*;p2:=*;p3:=*;?(p1=1|p1=0)&(p2=1|p2=0)&(p3=1|p3=0)&p1+p2+p3 < 3;}{?fail>failOld;ths:=t;hhs:=h;shs:=asup;++?!fail>failOld;}}i:=(min(a1,p1)+min(a2,p2)+min(a3,p3))*pRate();d:=*;?0<=d;?d<=asup;{t'=1,c'=1,h'=i-d&c<=TS()}}*](fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>hDEG()&asup>=supDEG())"); <(
  "Init":
    implyL('L=="\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())->(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG()"); <(
      "\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())":
        hideR('R=="(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&(0<=(a1+a2+a3)*pRate()&(a1+a2+a3)*pRate()<=iMAX()&asup<=supMAX()&TS()>=c&c>=0&(fail=0|fail=1))&(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG())");
        hideL('L=="!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())&\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN())->(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN()");
        hideL('L=="!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())&!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN())&\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0)->(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0");
        QE,
      "(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG()":
        hideL('L=="!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())&\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN())->(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN()");
        hideL('L=="!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())&!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN())&\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0)->(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0");
        QE
    ),
  "Post":
    unfold;
    fullSimplify;
