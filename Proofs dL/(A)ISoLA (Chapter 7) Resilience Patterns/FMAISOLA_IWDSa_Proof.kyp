          "[?!c>=TS();]((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&(0<=(a1+a2+a3)*pRate()&(a1+a2+a3)*pRate()<=iMAX()&asup<=supMAX()&TS()>=c&c>=0&(fail=0|fail=1))&(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG()))":
            unfold;
            fullSimplify;
