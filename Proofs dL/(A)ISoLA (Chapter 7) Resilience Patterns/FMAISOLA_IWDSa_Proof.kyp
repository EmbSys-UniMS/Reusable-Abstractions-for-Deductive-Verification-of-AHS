                                            hideL('L=="p1=1|p1=0");
                                            hideL('L=="a3=0|a3=1");
                                            hideL('L=="a2=0|a2=1");
                                            hideL('L=="a1=0|a1=1");
                                            auto,
                                          "Show":
                                            hideR('R=="[{t'=1,c'=1,h'=(min(a1,p1)+min(a2,p2)+min(a3,p3))*pRate()-d&c<=TS()}]h>=hhs-supMAX()*(t-ths)");
                                            hideL('L=="TS()>=c");
                                            hideL('L=="c>=0");
                                            hideL('L=="fail=1");
                                            hideL('L=="hhs>hMAX()");
                                            hideL('L=="shs>=supMAX()");
                                            hideL('L=="t-ths<=(hMAX()-hDEG())/supMAX()");
                                            hideL('L=="h>=hhs-supMAX()*(t-ths)");
                                            hideL('L=="h>hDEG()");
                                            hideL('L=="hDEG()+(-supDEG())*TS()>=hMIN()");
                                            hideL('L=="hMAX()+(-supMAX())*TS()>=hDEG()");
                                            QE
                                        )
                                    ),
                                  "!(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX())":
                                    notAnd('L=="!(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX())");
                                    orL('L=="!fail=1|!(hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX())"); <(
                                      "!fail=1":
                                        notEqual('L=="!fail=1");
                                        auto,
                                      "!(hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX())":
                                        notAnd('L=="!(hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX())");
                                        notGreater('L=="#!hhs>hMAX()#|!(shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX())");
                                        orL('L=="hhs<=hMAX()|!(shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX())"); <(
                                          "hhs<=hMAX()":
                                            auto,
                                          "!(shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX())":
                                            notAnd('L=="!(shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX())");
                                            notGreaterEqual('L=="#!shs>=supMAX()#|!t-ths<=(hMAX()-hDEG())/supMAX()");
                                            orL('L=="shs < supMAX()|!t-ths<=(hMAX()-hDEG())/supMAX()"); <(
                                              "shs < supMAX()":
                                                auto,
                                              "!t-ths<=(hMAX()-hDEG())/supMAX()":
                                                notLessEqual('L=="!t-ths<=(hMAX()-hDEG())/supMAX()");
                                                dC("t-ths>(hMAX()-hDEG())/supMAX()", 'R=="[{t'=1,c'=1,h'=(min(a1,p1)+min(a2,p2)+min(a3,p3))*pRate()-d&c<=TS()}](fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG())"); <(
                                                  "Use":
                                                    auto,
                                                  "Show":
                                                    hideL('L=="a2=0|a2=1");
                                                    hideL('L=="a1=0|a1=1");
                                                    hideL('L=="a3=0|a3=1");
                                                    hideL('L=="fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG()");
                                                    hideL('L=="p2=1|p2=0");
                                                    hideL('L=="p3=1|p3=0");
                                                    hideL('L=="p1=1|p1=0");
                                                    auto
                                                )
                                            )
                                        )
                                    )
                                ),
                              "Show":
                                hideR('R=="[{t'=1,c'=1,h'=(min(a1,p1)+min(a2,p2)+min(a3,p3))*pRate()-d&c<=TS()}](fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG())");
                                QE
                            )
                        )
                    )
                )
            )
        )
    )
)
End.

End. """"
  tactic """" expandAllDefs();
unfold;
loop("(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&(0<=(a1+a2+a3)*pRate()&(a1+a2+a3)*pRate()<=iMAX()&asup<=supMAX()&TS()>=c&c>=0&(fail=0|fail=1))&(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG())", 'R=="[{{?c>=TS();c:=0;asup:=*;a1:=*;a2:=*;a3:=*;{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG());?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG();++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG());{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN());?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN();++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN());{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0);?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0;++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0);}}}++?!c>=TS();}{failOld:=fail;{fail:=0;p1:=1;p2:=1;p3:=1;++fail:=1;p1:=*;p2:=*;p3:=*;?(p1=1|p1=0)&(p2=1|p2=0)&(p3=1|p3=0)&p1+p2+p3 < 3;}{?fail>failOld;ths:=t;hhs:=h;shs:=asup;++?!fail>failOld;}}i:=(min(a1,p1)+min(a2,p2)+min(a3,p3))*pRate();d:=*;?0<=d;?d<=asup;{t'=1,c'=1,h'=i-d&c<=TS()}}*](fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>hDEG()&asup>=supDEG())"); <(
  "Init":
    implyL('L=="\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())->(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG()"); <(
      "\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())":
        hideR('R=="(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&(0<=(a1+a2+a3)*pRate()&(a1+a2+a3)*pRate()<=iMAX()&asup<=supMAX()&TS()>=c&c>=0&(fail=0|fail=1))&(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG())");
        hideL('L=="!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())&\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN())->(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN()");
        hideL('L=="!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())&!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN())&\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0)->(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0");
        QE,
      "(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG()":
        hideL('L=="!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())&\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN())->(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN()");
        hideL('L=="!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG())&!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN())&\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0)->(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0");
        QE
    ),
  "Post":
    unfold;
    fullSimplify;
    QE,
  "Step":
    composeb('R=="[{?c>=TS();c:=0;asup:=*;a1:=*;a2:=*;a3:=*;{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG());?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG();++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG());{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN());?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN();++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN());{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0);?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0;++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0);}}}++?!c>=TS();}{failOld:=fail;{fail:=0;p1:=1;p2:=1;p3:=1;++fail:=1;p1:=*;p2:=*;p3:=*;?(p1=1|p1=0)&(p2=1|p2=0)&(p3=1|p3=0)&p1+p2+p3 < 3;}{?fail>failOld;ths:=t;hhs:=h;shs:=asup;++?!fail>failOld;}}i:=(min(a1,p1)+min(a2,p2)+min(a3,p3))*pRate();d:=*;?0<=d;?d<=asup;{t'=1,c'=1,h'=i-d&c<=TS()}]((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&(0<=(a1+a2+a3)*pRate()&(a1+a2+a3)*pRate()<=iMAX()&asup<=supMAX()&TS()>=c&c>=0&(fail=0|fail=1))&(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG()))");
    MR("(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&(0<=(a1+a2+a3)*pRate()&(a1+a2+a3)*pRate()<=iMAX()&asup<=supMAX()&TS()>=c&c>=0&(fail=0|fail=1))&(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG())", 'R=="[?c>=TS();c:=0;asup:=*;a1:=*;a2:=*;a3:=*;{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG());?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG();++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG());{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN());?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN();++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supDEG()&h+((a1+a2+a3)*pRate()-asup)*TS()>hDEG()&h+(0-asup)*TS()>hMIN());{?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0);?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0;++?!\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=0);}}}++?!c>=TS();][{failOld:=fail;{fail:=0;p1:=1;p2:=1;p3:=1;++fail:=1;p1:=*;p2:=*;p3:=*;?(p1=1|p1=0)&(p2=1|p2=0)&(p3=1|p3=0)&p1+p2+p3 < 3;}{?fail>failOld;ths:=t;hhs:=h;shs:=asup;++?!fail>failOld;}}i:=(min(a1,p1)+min(a2,p2)+min(a3,p3))*pRate();d:=*;?0<=d;?d<=asup;{t'=1,c'=1,h'=i-d&c<=TS()}]((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&(0<=(a1+a2+a3)*pRate()&(a1+a2+a3)*pRate()<=iMAX()&asup<=supMAX()&TS()>=c&c>=0&(fail=0|fail=1))&(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG()))"); <(
      "Use Q->P":
        unfold; <(
          "[?\exists a1 \exists a2 \exists a3 \exists asup ((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG());?(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&asup=supMAX()&h+((a1+a2+a3)*pRate()-asup)*TS()>hMAX()&h+(0-asup)*TS()>hDEG();]((a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&(0<=(a1+a2+a3)*pRate()&(a1+a2+a3)*pRate()<=iMAX()&asup<=supMAX()&TS()>=0&0>=0&(fail=0|fail=1))&(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup>=supDEG()))":
            fullSimplify;
            andR('R=="(0<=(a1_1+a2_1+a3_1)*pRate()&(a1_1+a2_1+a3_1)*pRate()<=iMAX())&(fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup_1>=supDEG())"); <(
              "0<=(a1_1+a2_1+a3_1)*pRate()&(a1_1+a2_1+a3_1)*pRate()<=iMAX()":
                andR('R=="0<=(a1_1+a2_1+a3_1)*pRate()&(a1_1+a2_1+a3_1)*pRate()<=iMAX()"); <(
                  "0<=(a1_1+a2_1+a3_1)*pRate()":
                    QE,
                  "(a1_1+a2_1+a3_1)*pRate()<=iMAX()":
                    QE
                ),
              "fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup_1>=supDEG()":
                implyR('R=="fail=1&hhs>hMAX()&shs>=supMAX()&t-ths<=(hMAX()-hDEG())/supMAX()->h>=hhs-supMAX()*(t-ths)&h>hDEG()&asup_1>=supDEG()");
                unfold;
