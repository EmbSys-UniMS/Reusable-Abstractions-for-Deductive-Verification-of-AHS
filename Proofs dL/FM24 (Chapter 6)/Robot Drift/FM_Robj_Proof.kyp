                                hideL('L=="drftLOW()>=1");
                                hideL('L=="-drftHIGH()<=drft");
                                hideL('L=="drft<=drftHIGH()");
                                hideL('L=="TEVD()>=TSTP()");
                                dC("0<=cr", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()}]abs(xr-xa)+abs(yr-ya)-(vmaxr+VMAXa())*(TS()-cr)>TSTP()"); <(
                                  "Use":
                                    hideL('L=="abs(vxrCur)<=abs(vxrMax)");
                                    hideL('L=="abs(vyrCur)<=abs(vyrMax)");
                                    discreteGhost("xa", "xao", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()&0<=cr}]abs(xr-xa)+abs(yr-ya)-(vmaxr+VMAXa())*(TS()-cr)>TSTP()");
                                    discreteGhost("ya", "yao", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()&0<=cr}]abs(xr-xa)+abs(yr-ya)-(vmaxr+VMAXa())*(TS()-cr)>TSTP()");
                                    discreteGhost("xr", "xro", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()&0<=cr}]abs(xr-xa)+abs(yr-ya)-(vmaxr+VMAXa())*(TS()-cr)>TSTP()");
                                    discreteGhost("yr", "yro", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()&0<=cr}]abs(xr-xa)+abs(yr-ya)-(vmaxr+VMAXa())*(TS()-cr)>TSTP()");
                                    discreteGhost("cr", "cro", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()&0<=cr}]abs(xr-xa)+abs(yr-ya)-(vmaxr+VMAXa())*(TS()-cr)>TSTP()");
                                    dC("xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxrCur*(cr-cro)&yr=yro+vyrCur*(cr-cro)&cr-cro>=0", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()&0<=cr}]abs(xr-xa)+abs(yr-ya)-(vmaxr+VMAXa())*(TS()-cr)>TSTP()"); <(
                                      "Use":
                                        dC("abs(xro+vxrCur*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxrCur)+abs(vxa))*(cr-cro)&abs(yro+vyrCur*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyrCur)+abs(vya))*(cr-cro)", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&(cr<=TS()&0<=cr)&xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxrCur*(cr-cro)&yr=yro+vyrCur*(cr-cro)&cr-cro>=0}]abs(xr-xa)+abs(yr-ya)-(vmaxr+VMAXa())*(TS()-cr)>TSTP()"); <(
                                          "Use":
                                            auto,
                                          "Show":
                                            dW('R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&(cr<=TS()&0<=cr)&xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxrCur*(cr-cro)&yr=yro+vyrCur*(cr-cro)&cr-cro>=0}](abs(xro+vxrCur*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxrCur)+abs(vxa))*(cr-cro)&abs(yro+vyrCur*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyrCur)+abs(vya))*(cr-cro))");
                                            discreteGhost("cr-cro", "p", 'R=="abs(xro+vxrCur*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxrCur)+abs(vxa))*(cr-cro)&abs(yro+vyrCur*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyrCur)+abs(vya))*(cr-cro)");
                                            hideL('L=="p=cr-cro");
                                            unfold;
                                            fullSimplify;
                                            QE
                                        ),
                                      "Show":
                                        auto
                                    ),
                                  "Show":
                                    auto
                                ),
                              "Show":
                                hideR('R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()}]abs(xr-xa)+abs(yr-ya)-(vmaxr+VMAXa())*(TS()-cr)>TSTP()");
                                auto
                            ),
                          "Show":
                            hideR('R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()}]abs(xr-xa)+abs(yr-ya)-(abs(vxrMax)+abs(vyrMax)+VMAXa())*(TS()-cr)>TSTP()");
                            hideL('L=="abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()");
