        randomb('R=="[drft:=*;][?-drftHIGH()<=drft&drft<=drftHIGH();{?drft>drftLOW()&drftOld<=drftLOW();ths:=t;dhs:=abs(xr-xa)+abs(yr-ya);vhs:=abs(vxr)+abs(vyr);++?!(drft>drftLOW()&drftOld<=drftLOW());}{t'=1.0,cr'=1.0,xr'=vxr*drft,yr'=vyr*drft,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
        allR('R=="\forall drft [?-drftHIGH()<=drft&drft<=drftHIGH();{?drft>drftLOW()&drftOld<=drftLOW();ths:=t;dhs:=abs(xr-xa)+abs(yr-ya);vhs:=abs(vxr)+abs(vyr);++?!(drft>drftLOW()&drftOld<=drftLOW());}{t'=1.0,cr'=1.0,xr'=vxr*drft,yr'=vyr*drft,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
        composeb('R=="[?-drftHIGH()<=drft&drft<=drftHIGH();{?drft>drftLOW()&drftOld<=drftLOW();ths:=t;dhs:=abs(xr-xa)+abs(yr-ya);vhs:=abs(vxr)+abs(vyr);++?!(drft>drftLOW()&drftOld<=drftLOW());}{t'=1.0,cr'=1.0,xr'=vxr*drft,yr'=vyr*drft,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
        testb('R=="[?-drftHIGH()<=drft&drft<=drftHIGH();][{?drft>drftLOW()&drftOld<=drftLOW();ths:=t;dhs:=abs(xr-xa)+abs(yr-ya);vhs:=abs(vxr)+abs(vyr);++?!(drft>drftLOW()&drftOld<=drftLOW());}{t'=1.0,cr'=1.0,xr'=vxr*drft,yr'=vyr*drft,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
        implyR('R=="-drftHIGH()<=drft&drft<=drftHIGH()->[{?drft>drftLOW()&drftOld<=drftLOW();ths:=t;dhs:=abs(xr-xa)+abs(yr-ya);vhs:=abs(vxr)+abs(vyr);++?!(drft>drftLOW()&drftOld<=drftLOW());}{t'=1.0,cr'=1.0,xr'=vxr*drft,yr'=vyr*drft,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
        composeb('R=="[{?drft>drftLOW()&drftOld<=drftLOW();ths:=t;dhs:=abs(xr-xa)+abs(yr-ya);vhs:=abs(vxr)+abs(vyr);++?!(drft>drftLOW()&drftOld<=drftLOW());}{t'=1.0,cr'=1.0,xr'=vxr*drft,yr'=vyr*drft,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
        MR("-drftHIGH()<=drft&drft<=drftHIGH()", 'R=="[?drft>drftLOW()&drftOld<=drftLOW();ths:=t;dhs:=abs(xr-xa)+abs(yr-ya);vhs:=abs(vxr)+abs(vyr);++?!(drft>drftLOW()&drftOld<=drftLOW());][{t'=1.0,cr'=1.0,xr'=vxr*drft,yr'=vyr*drft,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))"); <(
          "Use Q->P":
            auto,
          "Show [a]Q":
            unfold;
            orL('L=="abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0"); <(
              "abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()":
                andL('L=="abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()");
                dC("abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()", 'R=="[{t'=1.0,cr'=1.0,xr'=vxr*drft,yr'=vyr*drft,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))"); <(
                  "Use":
                    auto,
                  "Show":
                    andL('L=="VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()");
                    unfold;
                    dC("abs(xr-xa)+abs(yr-ya)-(abs(vxr*drftHIGH())+abs(vyr*drftHIGH())+VMAXa())*(TS()-cr)>TSTP()", 'R=="[{t'=1.0,cr'=1.0,xr'=vxr*drft,yr'=vyr*drft,xa'=vxa,ya'=vya&cr<=TS()}]abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()"); <(
                      "Use":
                        auto,
                      "Show":
                        discreteGhost("vxr*drft", "vxrCur", 'R=="[{t'=1.0,cr'=1.0,xr'=vxr*drft,yr'=vyr*drft,xa'=vxa,ya'=vya&cr<=TS()}]abs(xr-xa)+abs(yr-ya)-(abs(vxr*drftHIGH())+abs(vyr*drftHIGH())+VMAXa())*(TS()-cr)>TSTP()");
                        discreteGhost("vyr*drft", "vyrCur", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyr*drft,xa'=vxa,ya'=vya&cr<=TS()}]abs(xr-xa)+abs(yr-ya)-(abs(vxr*drftHIGH())+abs(vyr*drftHIGH())+VMAXa())*(TS()-cr)>TSTP()");
                        discreteGhost("vxr*drftHIGH()", "vxrMax", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()}]abs(xr-xa)+abs(yr-ya)-(abs(vxr*drftHIGH())+abs(vyr*drftHIGH())+VMAXa())*(TS()-cr)>TSTP()");
                        discreteGhost("vyr*drftHIGH()", "vyrMax", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()}]abs(xr-xa)+abs(yr-ya)-(abs(vxrMax)+abs(vyr*drftHIGH())+VMAXa())*(TS()-cr)>TSTP()");
                        cut("abs(vxrCur)<=abs(vxrMax)&abs(vyrCur)<=abs(vyrMax)"); <(
                          "Use":
                            andL('L=="abs(vxrCur)<=abs(vxrMax)&abs(vyrCur)<=abs(vyrMax)");
                            edit("abs(xr-xa)+abs(yr-ya)-(abs(vxrMax)+abs(vyrMax)+VMAXa())*(TS()-cr)>TSTP()", 'L=="abs(xr-xa)+abs(yr-ya)-((abs(vxr)+abs(vyr))*drftHIGH()+VMAXa())*(TS()-cr)>TSTP()");
                            hideL('L=="vxrCur=vxr*drft");
                            hideL('L=="vyrCur=vyr*drft");
                            hideL('L=="vxrMax=vxr*drftHIGH()");
                            hideL('L=="vyrMax=vyr*drftHIGH()");
                            hideL('L=="abs(vxr)+abs(vyr)<=VMAXr()");
                            discreteGhost("abs(vxrMax)+abs(vyrMax)", "vmaxr", 'R=="[{t'=1.0,cr'=1.0,xr'=vxrCur,yr'=vyrCur,xa'=vxa,ya'=vya&cr<=TS()}]abs(xr-xa)+abs(yr-ya)-(abs(vxrMax)+abs(vyrMax)+VMAXa())*(TS()-cr)>TSTP()");
                            cut("abs(vxrCur)+abs(vyrCur)<=vmaxr"); <(
                              "Use":
                                hideL('L=="vmaxr=abs(vxrMax)+abs(vyrMax)");
