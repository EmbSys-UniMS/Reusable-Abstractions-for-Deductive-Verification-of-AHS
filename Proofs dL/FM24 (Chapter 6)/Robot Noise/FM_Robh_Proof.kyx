                                    andR('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()&0<=cr)&abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()}]abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()&[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()&0<=cr)&abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()}](abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr())"); <(
                                      "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()&0<=cr)&abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()}]abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()":
                                        auto,
                                      "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()&0<=cr)&abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()}](abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr())":
                                        boxAnd('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()&0<=cr)&abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()}](abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr())");
                                        andR('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()&0<=cr)&abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()}]abs(xr-xa)+abs(yr-ya)>TEVD()&[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()&0<=cr)&abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()}](VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr())"); <(
                                          "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()&0<=cr)&abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()}]abs(xr-xa)+abs(yr-ya)>TEVD()":
                                            todo,
                                          "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()&0<=cr)&abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()}](VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr())":
                                            todo
                                        )
                                    ),
                                  "Show":
                                    todo
                                ),
                              "Show":
                                todo
                            ),
                          "abs(vxr)+abs(vyr)=0":
                            auto
                        )
                    ),
                  "ths>-1":
                    hideL('L=="ths=-1->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()&abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0");
                    auto
                )
            )
        )
    )
)
End.

Tactic "FM/Robh from tactic"
implyR('R=="(d(xr,yr,xa,ya)>TEVD()&VMAXa()>=0&VMINr()>=0&VMAXr()>=VMINr()&cr=0&TS()>=cr&t=0&NHIGH()>=NLOW()&NLOW()>=0&TEVD()>=TSTP())&dS=d(xr,yr,xa,ya)&(\exists vxr \exists vyr HCFull(dS,vxr,vyr)->HCFull(dS,vxr,vyr))&(!\exists vxr \exists vyr HCFull(dS,vxr,vyr)->HCFB(dS,vxr,vyr))&ths=-1&noise=0->[{{noiseOld:=noise;noise:=*;dS:=d(xr,yr,xa,ya)+noise;{?noise>NLOW()&noiseOld<=NLOW();ths:=t;dhs:=d(xr,yr,xa,ya);vhs:=n(vxr,vyr);++?!(noise>NLOW()&noiseOld<=NLOW());}}{?cr>=TS();cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr HCFull(dS,vxr,vyr);?HCFull(dS,vxr,vyr);++?!\exists vxr \exists vyr HCFull(dS,vxr,vyr);?HCFB(dS,vxr,vyr);}++?!cr>=TS();}{vxa:=*;vya:=*;?n(vxa,vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}}*](ths=-1->d(xr,yr,xa,ya)>TEVD()&VMINr()<=n(vxr,vyr)&n(vxr,vyr)<=VMAXr()|n(vxr,vyr)=0)");
loop("(t>=0&0<=cr&cr<=TS()&(ths=-1&noise<=NLOW()|ths>-1))&(ths=-1->d(xr,yr,xa,ya)-(n(vxr,vyr)+VMAXa())*(TS()-cr)>TEVD()&d(xr,yr,xa,ya)>TEVD()&VMINr()<=n(vxr,vyr)&n(vxr,vyr)<=VMAXr()|n(vxr,vyr)=0)", 'R=="[{{noiseOld:=noise;noise:=*;dS:=d(xr,yr,xa,ya)+noise;{?noise>NLOW()&noiseOld<=NLOW();ths:=t;dhs:=d(xr,yr,xa,ya);vhs:=n(vxr,vyr);++?!(noise>NLOW()&noiseOld<=NLOW());}}{?cr>=TS();cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr HCFull(dS,vxr,vyr);?HCFull(dS,vxr,vyr);++?!\exists vxr \exists vyr HCFull(dS,vxr,vyr);?HCFB(dS,vxr,vyr);}++?!cr>=TS();}{vxa:=*;vya:=*;?n(vxa,vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}}*](ths=-1->d(xr,yr,xa,ya)>TEVD()&VMINr()<=n(vxr,vyr)&n(vxr,vyr)<=VMAXr()|n(vxr,vyr)=0)"); <(
  "Init":
    cut("\exists vxr \exists vyr HCFull(dS,vxr,vyr)|!\exists vxr \exists vyr HCFull(dS,vxr,vyr)"); <(
      "Use":
        orL('L=="\exists vxr \exists vyr HCFull(dS,vxr,vyr)|!\exists vxr \exists vyr HCFull(dS,vxr,vyr)"); <(
          "\exists vxr \exists vyr HCFull(dS,vxr,vyr)":
            implyL('L=="\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP())->VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP()"); <(
              "\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP())":
                hideR('R=="(t>=0&0<=cr&cr<=TS()&(ths=-1&noise<=NLOW()|ths>-1))&(ths=-1->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()&abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)");
                expandAllDefs();
                QE,
              "VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP()":
                QE
            ),
          "!\exists vxr \exists vyr HCFull(dS,vxr,vyr)":
            expandAllDefs();
            implyL('L=="!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP())->abs(vxr)+abs(vyr)=0"); <(
              "!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP())":
                QE,
              "abs(vxr)+abs(vyr)=0":
                QE
            )
        ),
      "Show":
        hideR('R=="(t>=0&0<=cr&cr<=TS()&(ths=-1&noise<=NLOW()|ths>-1))&(ths=-1->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()&abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)");
        QE
    ),
  "Post":
    QE,
  "Step":
    composeb('R=="[{noiseOld:=noise;noise:=*;dS:=abs(xr-xa)+abs(yr-ya)+noise;{?noise>NLOW()&noiseOld<=NLOW();ths:=t;dhs:=abs(xr-xa)+abs(yr-ya);vhs:=abs(vxr)+abs(vyr);++?!(noise>NLOW()&noiseOld<=NLOW());}}{?cr>=TS();cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP();++?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;}++?!cr>=TS();}{vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}]((t>=0&0<=cr&cr<=TS()&(ths=-1&noise<=NLOW()|ths>-1))&(ths=-1->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()&abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
    MR("(t>=0&0<=cr&cr<=TS()&(ths=-1&noise<=NLOW()|ths>-1))&(ths=-1->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()&abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise", 'R=="[noiseOld:=noise;noise:=*;dS:=abs(xr-xa)+abs(yr-ya)+noise;{?noise>NLOW()&noiseOld<=NLOW();ths:=t;dhs:=abs(xr-xa)+abs(yr-ya);vhs:=abs(vxr)+abs(vyr);++?!(noise>NLOW()&noiseOld<=NLOW());}][{?cr>=TS();cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP();++?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;}++?!cr>=TS();}{vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}]((t>=0&0<=cr&cr<=TS()&(ths=-1&noise<=NLOW()|ths>-1))&(ths=-1->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()&abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))"); <(
      "Use Q->P":
        auto,
      "Show [a]Q":
        composeb('R=="[{?cr>=TS();cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP();++?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;}++?!cr>=TS();}{vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}]((t>=0&0<=cr&cr<=TS()&(ths=-1&noise<=NLOW()|ths>-1))&(ths=-1->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()&abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
        MR("(t>=0&0<=cr&cr<=TS()&(ths=-1&noise<=NLOW()|ths>-1))&(ths=-1->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()&abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise", 'R=="[?cr>=TS();cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP();++?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;}++?!cr>=TS();][{vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}]((t>=0&0<=cr&cr<=TS()&(ths=-1&noise<=NLOW()|ths>-1))&(ths=-1->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()&abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))"); <(
          "Use Q->P":
            choiceb('R=="[?cr>=TS();cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP();++?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;}++?!cr>=TS();]((t>=0&0<=cr&cr<=TS()&(ths=-1&noise<=NLOW()|ths>-1))&(ths=-1->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TEVD()&abs(xr-xa)+abs(yr-ya)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise)");
