                    hideL('L=="\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP())");
                    testb('R=="[?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP();](t>=0&0<=0&0<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-0)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise&noise<=NHIGH())");
                    implyR('R=="VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP()->t>=0&0<=0&0<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-0)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise&noise<=NHIGH()");
                    QE,
                  "[?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;](t>=0&0<=0&0<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-0)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise&noise<=NHIGH())":
                    composeb('R=="[?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;](t>=0&0<=0&0<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-0)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise&noise<=NHIGH())");
                    testb('R=="[?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());][?abs(vxr)+abs(vyr)=0;](t>=0&0<=0&0<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-0)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise&noise<=NHIGH())");
                    implyR('R=="!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP())->[?abs(vxr)+abs(vyr)=0;](t>=0&0<=0&0<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-0)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise&noise<=NHIGH())");
                    testb('R=="[?abs(vxr)+abs(vyr)=0;](t>=0&0<=0&0<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-0)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise&noise<=NHIGH())");
                    implyR('R=="abs(vxr)+abs(vyr)=0->t>=0&0<=0&0<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-0)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise&noise<=NHIGH()");
                    hideL('L=="!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP())");
                    auto
                ),
              "[?!cr>=TS();](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&dS=d(xr,yr,xa,ya)+noise&noise<=NHIGH())":
                auto
            ),
          "Show [a]Q":
            composeb('R=="[{vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
            composeb('R=="[vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();][{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
            randomb('R=="[vxa:=*;][vya:=*;?abs(vxa)+abs(vya)<=VMAXa();][{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
            allR('R=="\forall vxa [vya:=*;?abs(vxa)+abs(vya)<=VMAXa();][{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
            composeb('R=="[vya:=*;?abs(vxa)+abs(vya)<=VMAXa();][{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
            randomb('R=="[vya:=*;][?abs(vxa)+abs(vya)<=VMAXa();][{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
            allR('R=="\forall vya [?abs(vxa)+abs(vya)<=VMAXa();][{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
            testb('R=="[?abs(vxa)+abs(vya)<=VMAXa();][{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
            implyR('R=="abs(vxa)+abs(vya)<=VMAXa()->[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
            dC("0<=cr", 'R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))"); <(
              "Use":
                unfold;
                orL('L=="abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0"); <(
                  "abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()":
                    andL('L=="abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()");
                    dC("abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()", 'R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()&0<=cr}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))"); <(
                      "Use":
                        todo,
                      "Show":
                        andL('L=="abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()");
                        andL('L=="VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()");
                        hideL('L=="abs(xr-xa)+abs(yr-ya)>TSTP()");
                        todo
                    ),
                  "abs(vxr)+abs(vyr)=0":
                    todo
                ),
              "Show":
                todo
            )
        )
    )
)
End.

Tactic "FM/Robi from tactic"
unfold;
loop("t>=0&0<=cr&cr<=TS()&(d(xr,yr,xa,ya)-(n(vxr,vyr)+VMAXa())*(TS()-cr)>TSTP()&d(xr,yr,xa,ya)>TSTP()&VMINr()<=n(vxr,vyr)&n(vxr,vyr)<=VMAXr()|n(vxr,vyr)=0)", 'R=="[{{noiseOld:=noise;noise:=*;?noise<=NHIGH();dS:=d(xr,yr,xa,ya)+noise;{?noise>NLOW()&noiseOld<=NLOW();ths:=t;dhs:=d(xr,yr,xa,ya);vhs:=n(vxr,vyr);++?!(noise>NLOW()&noiseOld<=NLOW());}}{?cr>=TS();cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr HCFull(dS,vxr,vyr);?HCFull(dS,vxr,vyr);++?!\exists vxr \exists vyr HCFull(dS,vxr,vyr);?HCFB(dS,vxr,vyr);}++?!cr>=TS();}{vxa:=*;vya:=*;?n(vxa,vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}}*](d(xr,yr,xa,ya)>TSTP()&VMINr()<=n(vxr,vyr)&n(vxr,vyr)<=VMAXr()|n(vxr,vyr)=0)"); <(
  "Init":
    cut("\exists vxr \exists vyr HCFull(dS,vxr,vyr)|!\exists vxr \exists vyr HCFull(dS,vxr,vyr)"); <(
      "Use":
        orL('L=="\exists vxr \exists vyr HCFull(dS,vxr,vyr)|!\exists vxr \exists vyr HCFull(dS,vxr,vyr)"); <(
          "\exists vxr \exists vyr HCFull(dS,vxr,vyr)":
            implyL('L=="\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP())->VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP()"); <(
              "\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP())":
                hideR('R=="t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)");
                expandAllDefs();
                QE,
              "VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP()":
                QE
            ),
          "!\exists vxr \exists vyr HCFull(dS,vxr,vyr)":
            implyL('L=="!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP())->abs(vxr)+abs(vyr)=0"); <(
              "!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP())":
                hideR('R=="t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)");
                QE,
              "abs(vxr)+abs(vyr)=0":
                QE
            )
        ),
      "Show":
        hideR('R=="t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)");
        QE
    ),
  "Post":
    QE,
  "Step":
    composeb('R=="[{noiseOld:=noise;noise:=*;?noise<=NHIGH();dS:=abs(xr-xa)+abs(yr-ya)+noise;{?noise>NLOW()&noiseOld<=NLOW();ths:=t;dhs:=abs(xr-xa)+abs(yr-ya);vhs:=abs(vxr)+abs(vyr);++?!(noise>NLOW()&noiseOld<=NLOW());}}{?cr>=TS();cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP();++?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NLOW())>TEVD()&dS+(-(abs(vxr)+abs(vyr)+VMAXa())*TS()-NHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;}++?!cr>=TS();}{vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()}](t>=0&0<=cr&cr<=TS()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()-cr)>TSTP()&abs(xr-xa)+abs(yr-ya)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
