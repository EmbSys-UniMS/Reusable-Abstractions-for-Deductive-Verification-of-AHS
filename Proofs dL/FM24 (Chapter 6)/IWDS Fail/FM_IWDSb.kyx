                ),
              "[?!c>=TS();]((0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))":
                unfold;
                fullSimplify;
                QE
