                        boxAnd('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}](((ai-as)*TS() < RR()*TS()->h+(-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))");
                        andR('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}]((ai-as)*TS() < RR()*TS()->h+(-as)*(TS()-c)>=hDEG()&as=sMAX())&[{t'=1,c'=1,h'=i-d&c<=TS()}]((fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))"); <(
                          "[{t'=1,c'=1,h'=i-d&c<=TS()}]((ai-as)*TS() < RR()*TS()->h+(-as)*(TS()-c)>=hDEG()&as=sMAX())":
