/* Exported from KeYmaera X v5.0 */

Theorem "FM/IWDSb"

ProgramVariables
    Real c;
    Real t;
    
    Real h; /* water level l */
    Real d;
    Real i; /* inflow */
    
    Real as; /* supply action */
    Real ai; /* inflow action */
    
    
    Real hfail;
    Real tfail;
    Real sfail;
    Real failOld;
    Real fail;
    
    Real trepair;
End.

Definitions
    Real TS;
    Real iMAX;
    
    Real hMAX;
    Real hDEG;
    Real hMIN;
    /* Supply */
    Real sMAX; 
    Real sDEG;
    Real sMIN;
    /* Recovery Rate */
    Real RR;   
    
    /* Contracts */
    Real WCRREPAIR(Real ai, Real as, Real time)       =  (ai-as)*(time);  
    Real WCRFAIL(Real as, Real time)         =  (0-as)*(time); 
    Bool RECOVER(Real ai, Real as)        <-> WCRREPAIR(ai, as, TS)>=RR*TS;
    Bool HCFULL(Real h, Real ai, Real as) <-> 0<=ai & ai <= iMAX & as=sMAX & h+WCRREPAIR(ai, as, TS) >= hMAX & h+WCRFAIL(as, TS) >= hDEG;
    Bool HCDEG(Real h, Real ai, Real as)  <-> 0<=ai & ai <= iMAX & as=sDEG & h+WCRREPAIR(ai, as, TS) >= hDEG & h+WCRFAIL(as, TS) >= hMIN & RECOVER(ai,as);
    Bool HCMIN(Real h, Real ai, Real as)  <-> 0<=ai & ai <= iMAX & as=0    & h+WCRREPAIR(ai, as, TS) >= hMIN & h+WCRFAIL(as, TS) >= hMIN & RECOVER(ai,as);
    
    /*max time for degrading from hMAX to hDEG*/
    Real tMAX = (hMAX-hDEG)/sMAX;  
    /*max time for recovering from hMIN to hDEG&as>=sDEG*/
    Real tREPDEG = (hDEG-hMIN)/RR+TS;
    Real tREPMAX = (hMAX-hMIN)/RR+TS;
End.


Problem
(hMAX+WCRFAIL(sMAX,TS) >= hDEG & hDEG+WCRFAIL(sDEG,TS) >= hMIN & hMIN > 0 & h >= hMAX & RR>0 &iMAX>0 & WCRREPAIR(iMAX, sDEG, TS)>=RR*TS)&
(c=0 & TS>0 & t=0 & trepair = t) &
(sMAX>=sDEG & sDEG>0 & iMAX>=sMAX) & true &
/* Contracts hold Initially*/
(((\exists ai \exists as HCFULL(h, ai, as)) ->  HCFULL(h, ai, as)) &
( ( !(\exists ai \exists as HCFULL(h, ai, as)) & (\exists ai \exists as HCDEG(h, ai, as)) ) -> HCDEG(h, ai, as)) &
((!(\exists ai \exists as HCFULL(h, ai, as)) & !(\exists ai \exists as HCDEG(h, ai, as)) & (\exists ai \exists as HCMIN(h, ai, as))) -> HCMIN(h, ai, as))) & 
/* No Fail Initially */
(failOld = fail & fail= 0)
->
[
    {   
        {if(c>=TS) /* Resilience Contracts */
        {
            c:=0;as:=*;ai:=*;
            if(\exists ai \exists as HCFULL(h, ai, as)){?HCFULL(h, ai, as);}
            else 
            {
                if(\exists ai \exists as HCDEG(h, ai, as)) {?HCDEG(h, ai, as);}
                else 
                {
                    if(\exists ai \exists as HCMIN(h, ai, as)) {?HCMIN(h, ai, as);}
                }
            }
            
        }
        {failOld:=fail;
        {fail:=0; i:=min(iMAX,ai); ++ fail:=1; i:=0;}; /*pump system can fail*/
        if(fail>failOld) /* Store Values in Case of Failure */
        {
            tfail:=t; hfail:=h; sfail:=as;
        };
        if(fail<failOld) /* Store Time in Case of Repair */
        {
            trepair:=t;
        };}}    
        d:=*;?0<=d;?d<=as; /* Demand */
        {t'=1, c'=1, h'=i-d & c<= TS} /* Evolution */
    }*@invariant((0<=ai & ai<=iMAX & as>=0 & as<=sMAX & TS>=c & c>=0 & 
                 (fail =0 | fail =1)) & 
                 h-as*(TS-c)>=hMIN &
                 (WCRREPAIR(ai, as, TS)<RR*TS -> h+WCRFAIL(as,TS-c)>=hDEG & as=sMAX) &
                 (fail = 0 & WCRREPAIR(ai, as, TS)>=RR*TS -> h>=hMIN+RR*(t-trepair)|as>=sDEG&h>=hDEG) &
                 (fail = 0 & as<sDEG -> (t-trepair)+(TS-c)<tREPDEG))
] ((as>=0&h>=hMIN)&
    (fail=0& (t-trepair)>=tREPDEG->as>=sDEG&h>=hDEG))
End.

Tactic "FM/WDSCond/RRecovery: Proof"
implyR('R=="(hMAX()+WCRFAIL(sMAX(),TS())>=hDEG()&hDEG()+WCRFAIL(sDEG(),TS())>=hMIN()&hMIN()>0&h>=hMAX()&RR()>0&iMAX()>0&WCRREPAIR(iMAX(),sDEG(),TS())>=RR()*TS())&(c=0&TS()>0&t=0&trepair=t)&(sMAX()>=sDEG()&sDEG()>0&iMAX()>=sMAX())&true&((\exists ai \exists as HCFULL(h,ai,as)->HCFULL(h,ai,as))&(!\exists ai \exists as HCFULL(h,ai,as)&\exists ai \exists as HCDEG(h,ai,as)->HCDEG(h,ai,as))&(!\exists ai \exists as HCFULL(h,ai,as)&!\exists ai \exists as HCDEG(h,ai,as)&\exists ai \exists as HCMIN(h,ai,as)->HCMIN(h,ai,as)))&failOld=fail&fail=0->[{{{?c>=TS();c:=0;as:=*;ai:=*;{?\exists ai \exists as HCFULL(h,ai,as);?HCFULL(h,ai,as);++?!\exists ai \exists as HCFULL(h,ai,as);{?\exists ai \exists as HCDEG(h,ai,as);?HCDEG(h,ai,as);++?!\exists ai \exists as HCDEG(h,ai,as);{?\exists ai \exists as HCMIN(h,ai,as);?HCMIN(h,ai,as);++?!\exists ai \exists as HCMIN(h,ai,as);}}}++?!c>=TS();}failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=0;}{?fail>failOld;tfail:=t;hfail:=h;sfail:=as;++?!fail>failOld;}{?fail < failOld;trepair:=t;++?!fail < failOld;}}d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}}*]((as>=0&h>=hMIN())&(fail=0&t-trepair>=tREPDEG()->as>=sDEG()&h>=hDEG()))");
loop("(0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h-as*(TS()-c)>=hMIN()&(WCRREPAIR(ai,as,TS()) < RR()*TS()->h+WCRFAIL(as,TS()-c)>=hDEG()&as=sMAX())&(fail=0&WCRREPAIR(ai,as,TS())>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG())", 'R=="[{{{?c>=TS();c:=0;as:=*;ai:=*;{?\exists ai \exists as HCFULL(h,ai,as);?HCFULL(h,ai,as);++?!\exists ai \exists as HCFULL(h,ai,as);{?\exists ai \exists as HCDEG(h,ai,as);?HCDEG(h,ai,as);++?!\exists ai \exists as HCDEG(h,ai,as);{?\exists ai \exists as HCMIN(h,ai,as);?HCMIN(h,ai,as);++?!\exists ai \exists as HCMIN(h,ai,as);}}}++?!c>=TS();}failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=0;}{?fail>failOld;tfail:=t;hfail:=h;sfail:=as;++?!fail>failOld;}{?fail < failOld;trepair:=t;++?!fail < failOld;}}d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}}*]((as>=0&h>=hMIN())&(fail=0&t-trepair>=tREPDEG()->as>=sDEG()&h>=hDEG()))"); <(
  "Init":
    implyL('L=="\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())->0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG()"); <(
      "\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())":
        hideR('R=="(0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG())");
        existsR("iMAX()", 'R=="\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())");
        existsR("sMAX()", 'R=="\exists as (0<=iMAX()&iMAX()<=iMAX()&as=sMAX()&h+(iMAX()-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())");
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())->0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS()");
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())->0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS()");
        QE,
      "0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG()":
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())->0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS()");
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())->0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS()");
        unfold;
        fullSimplify;
        QE
    ),
  "Post":
    unfold;
    fullSimplify;
    cut("(ai-as)*TS() < RR()*TS()|!(ai-as)*TS() < RR()*TS()"); <(
      "Use":
        orL('L=="(ai-as)*TS() < RR()*TS()|!(ai-as)*TS() < RR()*TS()"); <(
          "(ai-as)*TS() < RR()*TS()":
            unfold;
            fullSimplify;
            QE,
          "!(ai-as)*TS() < RR()*TS()":
            unfold;
            fullSimplify;
            andR('R=="h>=hMIN()&(fail=0&t-trepair>=tREPDEG()->as>=sDEG()&h>=hDEG())"); <(
              "h>=hMIN()":
                QE,
              "fail=0&t-trepair>=tREPDEG()->as>=sDEG()&h>=hDEG()":
                implyR('R=="fail=0&t-trepair>=tREPDEG()->as>=sDEG()&h>=hDEG()");
                unfold;
                fullSimplify;
                QE
            )
        ),
      "Show":
        hideR('R=="h>=hMIN()&(fail=0&t-trepair>=tREPDEG()->as>=sDEG()&h>=hDEG())");
        QE
    ),
  "Step":
    composeb('R=="[{{?c>=TS();c:=0;as:=*;ai:=*;{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());?0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());?0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());?0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());}}}++?!c>=TS();}failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=0;}{?fail>failOld;tfail:=t;hfail:=h;sfail:=as;++?!fail>failOld;}{?fail < failOld;trepair:=t;++?!fail < failOld;}}d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}]((0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))");
    MR("(0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG())&i>=0&(fail=0->i=ai)", 'R=="[{?c>=TS();c:=0;as:=*;ai:=*;{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());?0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());?0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());?0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());}}}++?!c>=TS();}failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=0;}{?fail>failOld;tfail:=t;hfail:=h;sfail:=as;++?!fail>failOld;}{?fail < failOld;trepair:=t;++?!fail < failOld;}][d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}]((0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))"); <(
      "Use Q->P":
        composeb('R=="[{?c>=TS();c:=0;as:=*;ai:=*;{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());?0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());?0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());?0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());}}}++?!c>=TS();}failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=0;}{?fail>failOld;tfail:=t;hfail:=h;sfail:=as;++?!fail>failOld;}{?fail < failOld;trepair:=t;++?!fail < failOld;}]((0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG())&i>=0&(fail=0->i=ai))");
