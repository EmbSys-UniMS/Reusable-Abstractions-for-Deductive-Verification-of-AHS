      "Show [a]Q":
        unfold;
        boxAnd('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}]((0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))");
        andR('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}](0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&[{t'=1,c'=1,h'=i-d&c<=TS()}](h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))"); <(
          "[{t'=1,c'=1,h'=i-d&c<=TS()}](0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))":
            auto,
          "[{t'=1,c'=1,h'=i-d&c<=TS()}](h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))":
            boxAnd('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}](h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))");
            andR('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}]h-as*(TS()-c)>=hMIN()&[{t'=1,c'=1,h'=i-d&c<=TS()}](((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))"); <(
              "[{t'=1,c'=1,h'=i-d&c<=TS()}]h-as*(TS()-c)>=hMIN()":
                auto,
              "[{t'=1,c'=1,h'=i-d&c<=TS()}](((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))":
                cut("(ai-as)*TS() < RR()*TS()|!(ai-as)*TS() < RR()*TS()"); <(
                  "Use":
                    orL('L=="(ai-as)*TS() < RR()*TS()|!(ai-as)*TS() < RR()*TS()"); <(
                      "(ai-as)*TS() < RR()*TS()":
                        implyL('L=="(ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX()"); <(
                          "(ai-as)*TS() < RR()*TS()":
                            hideR('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}](((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))");
                            QE,
                          "h+(0-as)*(TS()-c)>=hDEG()&as=sMAX()":
                            boxAnd('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}](((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))");
                            andR('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}]((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&[{t'=1,c'=1,h'=i-d&c<=TS()}]((fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))"); <(
                              "[{t'=1,c'=1,h'=i-d&c<=TS()}]((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())":
                                auto,
                              "[{t'=1,c'=1,h'=i-d&c<=TS()}]((fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))":
                                hideL('L=="(iMAX()-sDEG())*TS()>=RR()*TS()");
