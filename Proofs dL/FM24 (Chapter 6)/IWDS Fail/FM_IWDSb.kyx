                                  "fail=1":
                                    allL2R('L=="fail=1");
                                    auto
                                ),
                              "[{t'=1,c'=1,h'=i-d&c<=TS()}](fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG())":
                                orL('L=="fail=0|fail=1"); <(
                                  "fail=0":
                                    allL2R('L=="fail=0");
                                    cut("as < sDEG()|as>=sDEG()"); <(
                                      "Use":
                                        orL('L=="as < sDEG()|as>=sDEG()"); <(
                                          "as < sDEG()":
                                            implyL('L=="0=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()"); <(
                                              "0=0&as < sDEG()":
                                                hideR('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}](0=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG())");
                                                QE,
                                              "t-trepair+(TS()-c) < tREPDEG()":
                                                unfold;
                                                fullSimplify;
                                                auto
                                            ),
                                          "as>=sDEG()":
                                            auto
                                        ),
                                      "Show":
                                        hideR('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}](0=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG())");
                                        QE
                                    ),
                                  "fail=1":
                                    allL2R('L=="fail=1");
                                    auto
                                )
                            )
                        )
                    ),
                  "Show":
                    hideR('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}](((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(fail=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(fail=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG()))");
