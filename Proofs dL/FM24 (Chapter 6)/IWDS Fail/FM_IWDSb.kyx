          "Show [a]Q":
            unfold; <(
              "[?0>failOld;tfail:=t;hfail:=h;sfail:=as;][?0 < failOld;trepair:=t;++?!0 < failOld;]((0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(0=0|0=1))&h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(0=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(0=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG())&min(iMAX(),ai)>=0&(0=0->min(iMAX(),ai)=ai))//[?0 < failOld;trepair:=t;]((0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(0=0|0=1))&h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(0=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(0=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG())&min(iMAX(),ai)>=0&(0=0->min(iMAX(),ai)=ai))":
                fullSimplify;
                QE,
              "[?1>failOld;tfail:=t;hfail:=h;sfail:=as;][?1 < failOld;trepair:=t;++?!1 < failOld;]((0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(1=0|1=1))&h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(1=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(1=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG())&0>=0&(1=0->0=ai))//[?1 < failOld;trepair:=t;]((0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(1=0|1=1))&h-as*(TS()-c)>=hMIN()&((ai-as)*TS() < RR()*TS()->h+(0-as)*(TS()-c)>=hDEG()&as=sMAX())&(1=0&(ai-as)*TS()>=RR()*TS()->h>=hMIN()+RR()*(t-trepair)|as>=sDEG()&h>=hDEG())&(1=0&as < sDEG()->t-trepair+(TS()-c) < tREPDEG())&0>=0&(1=0->0=ai))":
                unfold;
