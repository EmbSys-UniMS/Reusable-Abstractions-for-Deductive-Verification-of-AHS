                    andR('R=="[{t'=1,c'=1,h'=min(0,ai)-d&c<=TS()}](0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=c&c>=0&(1=0|1=1))&[{t'=1,c'=1,h'=min(0,ai)-d&c<=TS()}](h+(0-as)*(TS()-c)>=hMIN()&(1=1&hhs>=hMAX()&as>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG()))"); <(
