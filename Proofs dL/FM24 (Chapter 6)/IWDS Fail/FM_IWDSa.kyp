                                dC("h>=hhs-sMAX()*(t-ths)", 'R=="[{t'=1,c'=1,h'=x&c<=TS()}](1=1&hhs>=hMAX()&as>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG())"); <(
