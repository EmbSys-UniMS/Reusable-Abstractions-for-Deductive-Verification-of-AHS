Lemma "FM/IWDSa from tactic".
"  ==>  (((((hMAX())+((((0))-(sMAX()))*(TS()))) >= (hDEG()))&((((hDEG())+((((0))-(sDEG()))*(TS()))) >= (hMIN()))&(((hMIN()) > ((0)))&(((h) >= (hMAX()))&((iMAX()) > ((0)))))))&((((c) = ((0)))&(((TS()) >= (c))&((t) = ((0)))))&((((sMAX()) >= (sDEG()))&(((sDEG()) > ((0)))&((iMAX()) >= (sMAX()))))&((((\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sMAX()))&((((h)+(((ai)-(as))*(TS()))) >= (hMAX()))&(((h)+((((0))-(as))*(TS()))) >= (hDEG()))))))))->((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sMAX()))&((((h)+(((ai)-(as))*(TS()))) >= (hMAX()))&(((h)+((((0))-(as))*(TS()))) >= (hDEG())))))))&((((!(\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sMAX()))&((((h)+(((ai)-(as))*(TS()))) >= (hMAX()))&(((h)+((((0))-(as))*(TS()))) >= (hDEG())))))))))&(\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sDEG()))&((((h)+(((ai)-(as))*(TS()))) >= (hDEG()))&(((h)+((((0))-(as))*(TS()))) >= (hMIN())))))))))->((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sDEG()))&((((h)+(((ai)-(as))*(TS()))) >= (hDEG()))&(((h)+((((0))-(as))*(TS()))) >= (hMIN())))))))&(((!(\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sMAX()))&((((h)+(((ai)-(as))*(TS()))) >= (hMAX()))&(((h)+((((0))-(as))*(TS()))) >= (hDEG())))))))))&((!(\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sDEG()))&((((h)+(((ai)-(as))*(TS()))) >= (hDEG()))&(((h)+((((0))-(as))*(TS()))) >= (hMIN())))))))))&(\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = ((0)))&((((h)+(((ai)-(as))*(TS()))) >= (hMIN()))&(((h)+((((0))-(as))*(TS()))) >= (hMIN()))))))))))->((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = ((0)))&((((h)+(((ai)-(as))*(TS()))) >= (hMIN()))&(((h)+((((0))-(as))*(TS()))) >= (hMIN())))))))))&(((failOld) = (fail))&((fail) = ((0))))))))->([{{{{?((c) >= (TS()));};{{c:=(0);};{{as:=*;};{{ai:=*;};{{{?(\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sMAX()))&((((h)+(((ai)-(as))*(TS()))) >= (hMAX()))&(((h)+((((0))-(as))*(TS()))) >= (hDEG()))))))));};{?((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sMAX()))&((((h)+(((ai)-(as))*(TS()))) >= (hMAX()))&(((h)+((((0))-(as))*(TS()))) >= (hDEG()))))));}}++{{?(!(\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sMAX()))&((((h)+(((ai)-(as))*(TS()))) >= (hMAX()))&(((h)+((((0))-(as))*(TS()))) >= (hDEG())))))))));};{{{?(\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sDEG()))&((((h)+(((ai)-(as))*(TS()))) >= (hDEG()))&(((h)+((((0))-(as))*(TS()))) >= (hMIN()))))))));};{?((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sDEG()))&((((h)+(((ai)-(as))*(TS()))) >= (hDEG()))&(((h)+((((0))-(as))*(TS()))) >= (hMIN()))))));}}++{{?(!(\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = (sDEG()))&((((h)+(((ai)-(as))*(TS()))) >= (hDEG()))&(((h)+((((0))-(as))*(TS()))) >= (hMIN())))))))));};{{{?(\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = ((0)))&((((h)+(((ai)-(as))*(TS()))) >= (hMIN()))&(((h)+((((0))-(as))*(TS()))) >= (hMIN()))))))));};{?((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = ((0)))&((((h)+(((ai)-(as))*(TS()))) >= (hMIN()))&(((h)+((((0))-(as))*(TS()))) >= (hMIN()))))));}}++{?(!(\exists ai (\exists as ((((0)) <= (ai))&(((ai) <= (iMAX()))&(((as) = ((0)))&((((h)+(((ai)-(as))*(TS()))) >= (hMIN()))&(((h)+((((0))-(as))*(TS()))) >= (hMIN())))))))));}}}}}}}}}}++{?(!((c) >= (TS())));}};{{{failOld:=fail;};{{{{fail:=(0);};{i:=min<< ._1 < ._2&._0=._1|._1>=._2&._0=._2 >>((iMAX(),ai));}}++{{fail:=(1);};{i:=min<< ._1 < ._2&._0=._1|._1>=._2&._0=._2 >>(((0),ai));}}};{{{?((fail) > (failOld));};{{ths:=t;};{{hhs:=h;};{shs:=as;}}}}++{?(!((fail) > (failOld)));}}}};{{d:=*;};{{?(((0)) <= (d));};{{?((d) <= (as));};{{t'=(1),c'=(1),h'=(i)-(d)&(c) <= (TS())}}}}}}}*]((((fail) = ((1)))&(((hhs) >= (hMAX()))&(((shs) >= (sMAX()))&(((t)-(ths)) <= (((hMAX())-(hDEG()))/(sMAX()))))))->(((h) >= (hDEG()))&((as) >= (sDEG())))))
\qed::fcf5c79373d51a8d861071b7bf3c371c"
End.
Tool.
  tool """" KeYmaera X """"
  model """" Theorem "FM/IWDSa"

ProgramVariables
    Real c;
    Real t;
    
    Real h; /* water level */
    Real d; /* demand */
    Real i; /* inflow */
    
    Real as; /* supply action */
    Real ai; /* inflow action */
    
    /* observer */
    Real hhs;
    Real ths;
    Real shs;
    Real failOld;
    Real fail;
End.

Definitions
    Real TS;
    Real iMAX;
    Bool HC;
    
    Real hMAX;
    Real hDEG;
    Real hMIN;
    /* Supply */
    Real sMAX; 
    Real sDEG;
    Real sMIN;
    /* Recovery Rate */
    Real RR;   
    
    /* Contracts */
    Real WCRREPAIR(Real ai, Real as)    =  (ai-as)*(TS);  
    Real WCRFAIL(Real as, Real TS)               =  (0-as)*(TS); 
    Bool RECOVER(Real ai, Real as)        <-> WCRREPAIR(ai, as)>=RR;
    Bool HCFULL(Real h, Real ai, Real as) <-> 0<=ai & ai <= iMAX & as=sMAX  & h+WCRREPAIR(ai, as) >= hMAX   & h+WCRFAIL(as, TS) >= hDEG;
    Bool HCDEG(Real h, Real ai, Real as)  <-> 0<=ai & ai <= iMAX & as=sDEG  & h+WCRREPAIR(ai, as) >= hDEG   & h+WCRFAIL(as, TS) >= hMIN;
    Bool HCMIN(Real h, Real ai, Real as)  <-> 0<=ai & ai <= iMAX & as=0     & h+WCRREPAIR(ai, as) >= hMIN   & h+WCRFAIL(as, TS) >= hMIN;
    
    Real tMAX = (hMAX-hDEG)/sMAX; /*max time for degrading from hMAX to hDEG*/
End.


Problem
(hMAX+WCRFAIL(sMAX, TS) >= hDEG & hDEG+WCRFAIL(sDEG, TS) >= hMIN & hMIN > 0 & h >= hMAX &iMAX>0)&
(c=0 & TS>=c & t=0) &
(sMAX>=sDEG & sDEG>0 & iMAX>=sMAX) &
/* Contracts hold initially */
(((\exists ai \exists as HCFULL(h, ai, as)) ->  HCFULL(h, ai, as)) &
( ( !(\exists ai \exists as HCFULL(h, ai, as)) & (\exists ai \exists as HCDEG(h, ai, as)) ) -> HCDEG(h, ai, as)) &
((!(\exists ai \exists as HCFULL(h, ai, as)) & !(\exists ai \exists as HCDEG(h, ai, as)) & (\exists ai \exists as HCMIN(h, ai, as))) -> HCMIN(h, ai, as))) & 
/* Initially no failure */
(failOld = fail & fail= 0)
->
[
    {   
        if(c>=TS) /* Resilience Contracts */
        {
            c:=0;as:=*;ai:=*;
            if(\exists ai \exists as HCFULL(h, ai, as)){?HCFULL(h, ai, as);}
            else 
            {
                if(\exists ai \exists as HCDEG(h, ai, as)) {?HCDEG(h, ai, as);}
                else 
                {
                     if(\exists ai \exists as HCMIN(h, ai, as)) {?HCMIN(h, ai, as);}
                }
            }
            
        }
        {failOld:=fail;
        {fail:=0; i:=min(iMAX,ai); ++ fail:=1; i:=min(0,ai);}; /*pump system can fail*/
        if(fail>failOld) /* store in case of failure */
        {
            ths:=t; hhs:=h; shs:=as;
        };}
        d:=*;?0<=d;?d<=as; /* demand */
        {t'=1, c'=1, h'=i-d & c<= TS}
    }*@invariant((0<=ai & ai<=iMAX & as<=sMAX & TS>=c & c>=0 & 
    (fail =0 | fail =1)) & h+WCRFAIL(as,TS-c)>=hMIN &
    (fail=1 & hhs>=hMAX & shs>=sMAX & t-ths<=tMAX -> h>=hhs-sMAX*(t-ths) & h>=hDEG & as>=sDEG ) )
] ((fail=1 & hhs>=hMAX & shs>=sMAX & t-ths<=tMAX)->h>=hDEG & as>=sDEG)
End.

Tactic "FM/IWDSa: Proof"
implyR('R=="(hMAX()+WCRFAIL(sMAX(),TS())>=hDEG()&hDEG()+WCRFAIL(sDEG(),TS())>=hMIN()&hMIN()>0&h>=hMAX()&iMAX()>0)&(c=0&TS()>=c&t=0)&(sMAX()>=sDEG()&sDEG()>0&iMAX()>=sMAX())&((\exists ai \exists as HCFULL(h,ai,as)->HCFULL(h,ai,as))&(!\exists ai \exists as HCFULL(h,ai,as)&\exists ai \exists as HCDEG(h,ai,as)->HCDEG(h,ai,as))&(!\exists ai \exists as HCFULL(h,ai,as)&!\exists ai \exists as HCDEG(h,ai,as)&\exists ai \exists as HCMIN(h,ai,as)->HCMIN(h,ai,as)))&failOld=fail&fail=0->[{{?c>=TS();c:=0;as:=*;ai:=*;{?\exists ai \exists as HCFULL(h,ai,as);?HCFULL(h,ai,as);++?!\exists ai \exists as HCFULL(h,ai,as);{?\exists ai \exists as HCDEG(h,ai,as);?HCDEG(h,ai,as);++?!\exists ai \exists as HCDEG(h,ai,as);{?\exists ai \exists as HCMIN(h,ai,as);?HCMIN(h,ai,as);++?!\exists ai \exists as HCMIN(h,ai,as);}}}++?!c>=TS();}{failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=min(0,ai);}{?fail>failOld;ths:=t;hhs:=h;shs:=as;++?!fail>failOld;}}d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}}*](fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX()->h>=hDEG()&as>=sDEG())");
loop("(0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG())", 'R=="[{{?c>=TS();c:=0;as:=*;ai:=*;{?\exists ai \exists as HCFULL(h,ai,as);?HCFULL(h,ai,as);++?!\exists ai \exists as HCFULL(h,ai,as);{?\exists ai \exists as HCDEG(h,ai,as);?HCDEG(h,ai,as);++?!\exists ai \exists as HCDEG(h,ai,as);{?\exists ai \exists as HCMIN(h,ai,as);?HCMIN(h,ai,as);++?!\exists ai \exists as HCMIN(h,ai,as);}}}++?!c>=TS();}{failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=min(0,ai);}{?fail>failOld;ths:=t;hhs:=h;shs:=as;++?!fail>failOld;}}d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}}*](fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX()->h>=hDEG()&as>=sDEG())"); <(
  "Init":
    implyL('L=="\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())->0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG()"); <(
      "\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())":
        hideR('R=="(0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG())");
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN())->0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()");
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN())->0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()");
        QE,
      "0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG()":
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN())->0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()");
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN())->0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()");
        QE
    ),
  "Post":
    QE,
  "Step":
    composeb('R=="[{?c>=TS();c:=0;as:=*;ai:=*;{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());?0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN());?0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN());?0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN());}}}++?!c>=TS();}{failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=min(0,ai);}{?fail>failOld;ths:=t;hhs:=h;shs:=as;++?!fail>failOld;}}d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}]((0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG()))");
    MR("(0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG())", 'R=="[?c>=TS();c:=0;as:=*;ai:=*;{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());?0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN());?0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN());?0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN());}}}++?!c>=TS();][{failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=min(0,ai);}{?fail>failOld;ths:=t;hhs:=h;shs:=as;++?!fail>failOld;}}d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}]((0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG()))"); <(
      "Use Q->P":
        expand("tMAX");
        andL('L=="(0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG())");
        andL('L=="h+(0-as)*(TS()-c)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG())");
        cut("fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX()|!(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX())"); <(
          "Use":
            expand("tMAX");
            orL('L=="fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()|!(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX())"); <(
              "fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()":
                unfold; <(
                  "[?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());?0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG();]((0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=0&0>=0&(fail=0|fail=1))&h+(0-as)*(TS()-0)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG()))":
                    fullSimplify;
                    QE,
                  "[?!c>=TS();]((0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG()))":
                    fullSimplify;
                    QE,
                  "[?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN());?0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN();]((0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=0&0>=0&(fail=0|fail=1))&h+(0-as)*(TS()-0)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG()))":
                    hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())");
                    fullSimplify;
                    QE,
                  "[?\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN());?0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN();]((0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=0&0>=0&(fail=0|fail=1))&h+(0-as)*(TS()-0)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG()))":
                    cut("\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN())"); <(
                      "Use":
                        fullSimplify;
                        QE,
                      "Show":
                        hideR('R=="(0<=ai_1&ai_1<=iMAX()&as_1<=sMAX()&TS()>=0&0>=0&(fail=0|fail=1))&h+(0-as_1)*(TS()-0)>=hMIN()&(fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as_1>=sDEG())");
