                          "!t-ths<=(hMAX()-hDEG())/sMAX()":
                            notLessEqual('L=="!t-ths<=(hMAX()-hDEG())/sMAX()");
                            dC("t-ths>(hMAX()-hDEG())/sMAX()", 'R=="[{t'=1,c'=1,h'=min(0,ai)-d&c<=TS()}]((0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=c&c>=0&(1=0|1=1))&h+(0-as)*(TS()-c)>=hMIN()&(1=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=(hMAX()-hDEG())/sMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG()))"); <(
                              "Use":
                                auto,
                              "Show":
                                auto
                            )
                        )
                    )
                ),
              "Show":
                hideR('R=="[{t'=1,c'=1,h'=min(0,ai)-d&c<=TS()}]((0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=c&c>=0&(1=0|1=1))&h+(0-as)*(TS()-c)>=hMIN()&(1=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG()))");
                QE
            ),
          "[?!0>failOld;][d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=min(iMAX(),ai)-d&c<=TS()}]((0<=ai&ai<=iMAX()&as<=sMAX()&TS()>=c&c>=0&(0=0|0=1))&h+(0-as)*(TS()-c)>=hMIN()&(0=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG()))":
            orL('L=="fail=0|fail=1"); <(
              "fail=0":
                allL2R('L=="fail=0");
                fullSimplify;
                auto,
              "fail=1":
                hideL('L=="fail=1&hhs>=hMAX()&shs>=sMAX()&t-ths<=tMAX()->h>=hhs-sMAX()*(t-ths)&h>=hDEG()&as>=sDEG()");
                hideL('L=="fail=0|fail=1");
                auto
            )
        )
    )
) """"
End.

Tool.
  kyxversion """" 5.0 """"
End.
