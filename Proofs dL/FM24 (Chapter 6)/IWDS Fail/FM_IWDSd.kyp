              "Show":
                hideR('R=="(0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()");
                QE
            )
        ),
      "Show":
        hideR('R=="(0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()");
        QE
    ),
  "Post":
    QE,
  "Step":
    composeb('R=="[{?c>=TS();c:=0;as:=*;ai:=*;{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());?0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN());?0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN());?0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN());}}}++?!c>=TS();}{failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=0;}{?fail>failOld;ths:=t;hhs:=h;shs:=as;++?!fail>failOld;}}d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}]((0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN())");
