                        composeb('R=="[?\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN());?0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN();]((0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=0&0>=0&(fail=0|fail=1))&h+(0-as)*(TS()-0)>=hMIN())");
                        testb('R=="[?\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN());][?0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN();]((0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=0&0>=0&(fail=0|fail=1))&h+(0-as)*(TS()-0)>=hMIN())");
                        implyR('R=="\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN())->[?0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN();]((0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=0&0>=0&(fail=0|fail=1))&h+(0-as)*(TS()-0)>=hMIN())");
                        hideL('L=="\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN())");
                        unfold;
                        auto,
                      "[?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN());]((0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=0&0>=0&(fail=0|fail=1))&h+(0-as)*(TS()-0)>=hMIN())":
                        testb('R=="[?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN());]((0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=0&0>=0&(fail=0|fail=1))&h+(0-as)*(TS()-0)>=hMIN())");
                        implyR('R=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN())->(0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=0&0>=0&(fail=0|fail=1))&h+(0-as)*(TS()-0)>=hMIN()");
                        notExists('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN())");
                        notExists('L=="\forall ai #!\exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN())#");
                        allL("0", 'L=="\forall ai \forall as (!(0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()))");
                        allL("0", 'L=="\forall as (!(0<=0&0<=iMAX()&as=0&h+(0-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()))");
                        fullSimplify;
                        QE
                    )
                )
            ),
          "[?!c>=TS();]((0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN())":
            unfold;
            auto
        ),
      "Show [a]Q":
        MR("(0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()&i>=0", 'R=="[{failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=0;}{?fail>failOld;ths:=t;hhs:=h;shs:=as;++?!fail>failOld;}}d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}]((0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN())"); <(
          "Use Q->P":
            composeb('R=="[{failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=0;}{?fail>failOld;ths:=t;hhs:=h;shs:=as;++?!fail>failOld;}}d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}]((0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()&i>=0)");
            MR("(fail=0|fail=1)&hMAX()+(0-sMAX())*TS()>=hDEG()&hDEG()+(0-sDEG())*TS()>=hMIN()&hMIN()>0&sMAX()>=sDEG()&true&sDEG()>0&iMAX()>=sMAX()&true&iMAX()>0&i>=0", 'R=="[failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=0;}{?fail>failOld;ths:=t;hhs:=h;shs:=as;++?!fail>failOld;}][d:=*;?0<=d;?d<=as;{t'=1,c'=1,h'=i-d&c<=TS()}]((0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=c&c>=0&(fail=0|fail=1))&h+(0-as)*(TS()-c)>=hMIN()&i>=0)"); <(
              "Use Q->P":
                auto,
              "Show [a]Q":
                unfold;
                fullSimplify;
                dC("h+(-as)*(TS()-c)>=hMIN()", 'R=="[{t'=1,c'=1,h'=i-d&c<=TS()}]((0<=ai&ai<=iMAX()&as<=sMAX()&as>=0&TS()>=c&c>=0&(fail=0|fail=1))&h+(-as)*(TS()-c)>=hMIN()&i>=0)"); <(
                  "Use":
                    auto,
                  "Show":
                    auto
                )
            ),
          "Show [a]Q":
            QE
        )
    )
) """"
End.

