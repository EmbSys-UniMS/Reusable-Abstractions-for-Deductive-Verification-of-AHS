/* Model or tactics did not reparse, printed verbatim, needs manual editing */

/* Input content */
Theorem "FM/IWDSc"

ProgramVariables
    Real c;
    Real t;
    
    Real h; /* water level */
    Real d; /* demand */
    Real i; /* inflow */
    
    Real as; /* supply action */
    Real ai; /* inflow action */
    
    /* fail observers */
    Real hfail;
    Real tfail;
    Real sfail;
    Real failOld;
    Real fail;
    /* repair observers */
    Real tr;
End.

Definitions
    Real TS;
    Real iMAX;
    Real hMAX;
    Real hDEG;
    Real hMIN;
    /* Supply */
    Real sMAX; 
    Real sDEG;
    Real sMIN;
    /* Recovery Rate */
    Real RR;   
    
    /* Contracts */
    Real WCRREPAIR(Real ai, Real as, Real time)   =  (ai-as)*(time);  
    Real WCRFAIL(Real as, Real time)               =  (0-as)*(time); 
    Bool RECOVER(Real ai, Real as)        <-> WCRREPAIR(ai, as, TS)>=RR*TS;
    Bool HCFULL(Real h, Real ai, Real as) <-> 0<=ai & ai <= iMAX & as=sMAX & h+WCRREPAIR(ai, as, TS) >= hMAX & h+WCRFAIL(as, TS) >= hDEG;
    Bool HCDEG(Real h, Real ai, Real as)  <-> 0<=ai & ai <= iMAX & as=sDEG & h+WCRREPAIR(ai, as, TS) >= hDEG & h+WCRFAIL(as, TS) >= hMIN & RECOVER(ai,as);
    Bool HCMIN(Real h, Real ai, Real as)  <-> 0<=ai & ai <= iMAX & as=0    & h+WCRREPAIR(ai, as, TS) >= hMIN & h+WCRFAIL(as, TS) >= hMIN & RECOVER(ai,as);
    
    /*max time for recovering from hMIN to hMAX*/
    Real trMAXBack = (hMAX-hMIN)/RR; /*max recovery time for h+WCRREPAIR(ai, as,TS-c)>=hMAX*/
    Real trMAX = trMAXBack+TS;          /*max recovery time for h>=hMAX&as=sMAX*/
    
    HP RL ::= 
    { 
        if(c>=TS){c:=0;as:=*;ai:=*; /* Resilience Contracts */
            if(\exists ai \exists as HCFULL(h, ai, as)){?HCFULL(h, ai, as);}
            else 
            {
                if(\exists ai \exists as HCDEG(h, ai, as)) {?HCDEG(h, ai, as);}
                else 
                {
                    if(\exists ai \exists as HCMIN(h, ai, as)) {?HCMIN(h, ai, as);}
                }
            }
        };
    }; 
            
    HP Flow ::= 
    {
        failOld:=fail;
        {fail:=0; i:=min(iMAX,ai); ++ fail:=1; i:=0;}; /*pump system can fail*/
        d:=*;?0<=d;?d<=as; /* demand */
        if(fail>failOld) /* store upon failure */
        {
            tfail:=t; hfail:=h; sfail:=as;
        };
        if(fail<failOld) /* store upon repair */
        {
            tr:=t;
        };
    };
End.


Problem
/* sDEG>=RR ensures that h>=hMIN+RR*(t-tr) in the invariant remains fulfilled when fail=0 in the (t-tr)<=c) & h+WCRFAIL( as,TS-c)>=hDEG case. Proof could likely also be done with a more relaxed condition on RR*/
(hMAX+WCRFAIL(sMAX,TS) >= hDEG & hDEG+WCRFAIL(sDEG,TS) >= hMIN & hMIN > 0 & h >= hMAX & RR>0 &iMAX>0 & WCRREPAIR(iMAX, sDEG, TS)>=RR*TS & sDEG>=RR)&
(c=0 & TS>0 & t=0 & tr = t) &
(sMAX>=sDEG & sDEG>0 & iMAX>=sMAX) &
/* contract hold initially */
(((\exists ai \exists as HCFULL(h, ai, as)) ->  HCFULL(h, ai, as)) &
( ( !(\exists ai \exists as HCFULL(h, ai, as)) & (\exists ai \exists as HCDEG(h, ai, as)) ) -> HCDEG(h, ai, as)) &
((!(\exists ai \exists as HCFULL(h, ai, as)) & !(\exists ai \exists as HCDEG(h, ai, as)) & (\exists ai \exists as HCMIN(h, ai, as))) -> HCMIN(h, ai, as))) & 
/* initially no fail */
(failOld = fail & fail= 0)
->
[
    {   
        RL;
        Flow;
        {t'=1, c'=1, h'=i-d & c<= TS}
    }*@invariant((0<=ai & ai<=iMAX & as>=0 & as<=sMAX & TS>=c & c>=0 & 
                 (fail =0 | fail =1)) & 
                 h-as*(TS-c)>=hMIN &
                 ((((h+WCRREPAIR(ai, as,TS-c)>=hMAX)|(fail=0->(t-tr)<=c))&h+WCRFAIL( as,TS-c)>=hDEG|WCRREPAIR(ai, as, TS)>=RR*TS&(fail=0->h>=hMIN+RR*(t-tr)))) & 
                 (fail=0 & (t-tr)>trMAXBack->h+WCRREPAIR(ai, as,TS-c)>=hMAX) &
                 (fail=0 & (t-tr)>trMAXBack & (as<sMAX | h<hMAX) -> (t-tr)+(TS-c)<=trMAX))
] (fail=0 & (t-tr)>trMAX -> (as=sMAX | h>=hMAX))
End.

End.
/* End input content */

/* Printed tactics */
Tactic "FM/IWDSc from tactic"
implyR('R=="(hMAX()+WCRFAIL(sMAX(),TS())>=hDEG()&hDEG()+WCRFAIL(sDEG(),TS())>=hMIN()&hMIN()>0&h>=hMAX()&RR()>0&iMAX()>0&WCRREPAIR(iMAX(),sDEG(),TS())>=RR()*TS()&sDEG()>=RR())&(c=0&TS()>0&t=0&tr=t)&(sMAX()>=sDEG()&sDEG()>0&iMAX()>=sMAX())&((\exists ai \exists as HCFULL(h,ai,as)->HCFULL(h,ai,as))&(!\exists ai \exists as HCFULL(h,ai,as)&\exists ai \exists as HCDEG(h,ai,as)->HCDEG(h,ai,as))&(!\exists ai \exists as HCFULL(h,ai,as)&!\exists ai \exists as HCDEG(h,ai,as)&\exists ai \exists as HCMIN(h,ai,as)->HCMIN(h,ai,as)))&failOld=fail&fail=0->[{RL{|^@|};Flow{|^@|};{t'=1,c'=1,h'=i-d&c<=TS()}}*](fail=0&t-tr>trMAX()->as=sMAX()|h>=hMAX())");
loop("(0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h-as*(TS()-c)>=hMIN()&((h+WCRREPAIR(ai,as,TS()-c)>=hMAX()|(fail=0->t-tr<=c))&h+WCRFAIL(as,TS()-c)>=hDEG()|WCRREPAIR(ai,as,TS())>=RR()*TS()&(fail=0->h>=hMIN()+RR()*(t-tr)))&(fail=0&t-tr>trMAXBack()->h+WCRREPAIR(ai,as,TS()-c)>=hMAX())&(fail=0&t-tr>trMAXBack()&(as < sMAX()|h < hMAX())->t-tr+(TS()-c)<=trMAX())", 'R=="[{RL{|^@|};Flow{|^@|};{t'=1,c'=1,h'=i-d&c<=TS()}}*](fail=0&t-tr>trMAX()->as=sMAX()|h>=hMAX())"); <(
  "Init":
    implyL('L=="\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())->0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG()"); <(
      "\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())":
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())->0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS()");
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())->0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS()");
        hideR('R=="(0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h-as*(TS()-c)>=hMIN()&((h+(ai-as)*(TS()-c)>=hMAX()|(fail=0->t-tr<=c))&h+(0-as)*(TS()-c)>=hDEG()|(ai-as)*TS()>=RR()*TS()&(fail=0->h>=hMIN()+RR()*(t-tr)))&(fail=0&t-tr>trMAXBack()->h+(ai-as)*(TS()-c)>=hMAX())&(fail=0&t-tr>trMAXBack()&(as < sMAX()|h < hMAX())->t-tr+(TS()-c)<=trMAX())");
        QE,
      "0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG()":
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())->0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS()");
        hideL('L=="!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG())&!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())&\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS())->0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS()");
        QE
    ),
  "Post":
    implyR('R=="fail=0&t-tr>trMAX()->as=sMAX()|h>=hMAX()");
    unfold;
    fullSimplify;
    QE,
  "Step":
    expandAllDefs();
    composeb('R=="[{?c>=TS();c:=0;as:=*;ai:=*;{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());?0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sMAX()&h+(ai-as)*TS()>=hMAX()&h+(0-as)*TS()>=hDEG());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());?0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=sDEG()&h+(ai-as)*TS()>=hDEG()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());{?\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());?0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS();++?!\exists ai \exists as (0<=ai&ai<=iMAX()&as=0&h+(ai-as)*TS()>=hMIN()&h+(0-as)*TS()>=hMIN()&(ai-as)*TS()>=RR()*TS());}}}++?!c>=TS();}{failOld:=fail;{fail:=0;i:=min(iMAX(),ai);++fail:=1;i:=0;}d:=*;?0<=d;?d<=as;{?fail>failOld;tfail:=t;hfail:=h;sfail:=as;++?!fail>failOld;}{?fail < failOld;tr:=t;++?!fail < failOld;}}{t'=1,c'=1,h'=i-d&c<=TS()}]((0<=ai&ai<=iMAX()&as>=0&as<=sMAX()&TS()>=c&c>=0&(fail=0|fail=1))&h-as*(TS()-c)>=hMIN()&((h+(ai-as)*(TS()-c)>=hMAX()|(fail=0->t-tr<=c))&h+(0-as)*(TS()-c)>=hDEG()|(ai-as)*TS()>=RR()*TS()&(fail=0->h>=hMIN()+RR()*(t-tr)))&(fail=0&t-tr>(hMAX()-hMIN())/RR()->h+(ai-as)*(TS()-c)>=hMAX())&(fail=0&t-tr>(hMAX()-hMIN())/RR()&(as < sMAX()|h < hMAX())->t-tr+(TS()-c)<=(hMAX()-hMIN())/RR()+TS()))");
