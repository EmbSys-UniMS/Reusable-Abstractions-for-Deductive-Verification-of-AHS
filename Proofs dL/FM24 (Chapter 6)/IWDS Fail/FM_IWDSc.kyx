                                                orL('L=="h+(ai-as)*(TS()-c)>=hMAX()|t-tr<=c"); <(
                                                  "h+(ai-as)*(TS()-c)>=hMAX()":
                                                    dC("h>=hMAX()", 'R=="[{t'=1,c'=1,h'=i-d&c<=TS()&as>=sMAX()}](t-tr>(hMAX()-hMIN())/RR()&(as < sMAX()|h < hMAX())->t-tr+(TS()-c)<=(hMAX()-hMIN())/RR()+TS())"); <(
                                                      "Use":
                                                        auto,
                                                      "Show":
                                                        auto
                                                    ),
                                                  "t-tr<=c":
                                                    dC("t-tr<=c", 'R=="[{t'=1,c'=1,h'=i-d&c<=TS()&as>=sMAX()}](t-tr>(hMAX()-hMIN())/RR()&(as < sMAX()|h < hMAX())->t-tr+(TS()-c)<=(hMAX()-hMIN())/RR()+TS())"); <(
                                                      "Use":
                                                        auto,
                                                      "Show":
                                                        auto
                                                    )
                                                ),
                                              "(ai-as)*TS()>=RR()*TS()&h>=hMIN()+RR()*(t-tr)":
                                                andL('L=="(ai-as)*TS()>=RR()*TS()&h>=hMIN()+RR()*(t-tr)");
                                                dC("h>=hMAX()", 'R=="[{t'=1,c'=1,h'=i-d&c<=TS()&as>=sMAX()}](t-tr>(hMAX()-hMIN())/RR()&(as < sMAX()|h < hMAX())->t-tr+(TS()-c)<=(hMAX()-hMIN())/RR()+TS())"); <(
                                                  "Use":
                                                    hideL('L=="h>=hMIN()+RR()*(t-tr)");
                                                    hideL('L=="t-tr>(hMAX()-hMIN())/RR()->h+(ai-as)*(TS()-c)>=hMAX()");
                                                    auto,
                                                  "Show":
                                                    hideL('L=="h>=hMIN()+RR()*(t-tr)");
                                                    hideL('L=="t-tr>(hMAX()-hMIN())/RR()->h+(ai-as)*(TS()-c)>=hMAX()");
                                                    auto
                                                )
                                            ),
                                          "Show":
                                            auto
                                        )
                                    ),
                                  "Show":
                                    hideR('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}](t-tr>(hMAX()-hMIN())/RR()&(as < sMAX()|h < hMAX())->t-tr+(TS()-c)<=(hMAX()-hMIN())/RR()+TS())");
                                    QE
                                )
                            )
                        ),
                      "fail=1":
                        allL2R('L=="fail=1");
                        unfold;
                        fullSimplify;
                        boxAnd('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}](((h+(ai-as)*(TS()-c)>=hMAX()|(1=0->t-tr<=c))&h+(-as)*(TS()-c)>=hDEG()|(ai-as)*TS()>=RR()*TS()&(1=0->h>=hMIN()+RR()*(t-tr)))&(1=0&t-tr>(hMAX()-hMIN())/RR()->h+(ai-as)*(TS()-c)>=hMAX())&(1=0&t-tr>(hMAX()-hMIN())/RR()&(as < sMAX()|h < hMAX())->t-tr+(TS()-c)<=(hMAX()-hMIN())/RR()+TS()))");
                        andR('R=="[{t'=1,c'=1,h'=i-d&c<=TS()}]((h+(ai-as)*(TS()-c)>=hMAX()|(1=0->t-tr<=c))&h+(-as)*(TS()-c)>=hDEG()|(ai-as)*TS()>=RR()*TS()&(1=0->h>=hMIN()+RR()*(t-tr)))&[{t'=1,c'=1,h'=i-d&c<=TS()}]((1=0&t-tr>(hMAX()-hMIN())/RR()->h+(ai-as)*(TS()-c)>=hMAX())&(1=0&t-tr>(hMAX()-hMIN())/RR()&(as < sMAX()|h < hMAX())->t-tr+(TS()-c)<=(hMAX()-hMIN())/RR()+TS()))"); <(
                          "[{t'=1,c'=1,h'=i-d&c<=TS()}]((h+(ai-as)*(TS()-c)>=hMAX()|(1=0->t-tr<=c))&h+(-as)*(TS()-c)>=hDEG()|(ai-as)*TS()>=RR()*TS()&(1=0->h>=hMIN()+RR()*(t-tr)))":
                            hideL('L=="1=0&t-tr>(hMAX()-hMIN())/RR()->h+(ai-as)*(TS()-c)>=hMAX()");
                            hideL('L=="1=0&t-tr>(hMAX()-hMIN())/RR()&(as < sMAX()|h < hMAX())->t-tr+(TS()-c)<=(hMAX()-hMIN())/RR()+TS()");
                            orL('L=="(h+(ai-as)*(TS()-c)>=hMAX()|(1=0->t-tr<=c))&h+(-as)*(TS()-c)>=hDEG()|(ai-as)*TS()>=RR()*TS()&(1=0->h>=hMIN()+RR()*(t-tr))"); <(
                              "(h+(ai-as)*(TS()-c)>=hMAX()|(1=0->t-tr<=c))&h+(-as)*(TS()-c)>=hDEG()":
                                fullSimplify;
                                andL('L=="(h+(ai-as)*(TS()-c)>=hMAX()|(1=0->t-tr<=c))&h+(-as)*(TS()-c)>=hDEG()");
                                hideL('L=="h+(ai-as)*(TS()-c)>=hMAX()|(1=0->t-tr<=c)");
                                dC("h+(-as)*(TS()-c)>=hDEG()", 'R=="[{t'=1,c'=1,h'=i-d&c<=TS()}]((h+(ai-as)*(TS()-c)>=hMAX()|(1=0->t-tr<=c))&h+(-as)*(TS()-c)>=hDEG()|(ai-as)*TS()>=RR()*TS()&(1=0->h>=hMIN()+RR()*(t-tr)))"); <(
                                  "Use":
                                    auto,
                                  "Show":
                                    hideL('L=="1=0->i=ai");
                                    auto
                                ),
                              "(ai-as)*TS()>=RR()*TS()&(1=0->h>=hMIN()+RR()*(t-tr))":
                                andL('L=="(ai-as)*TS()>=RR()*TS()&(1=0->h>=hMIN()+RR()*(t-tr))");
                                fullSimplify;
                                dC("(ai-as)*TS()>=RR()*TS()", 'R=="[{t'=1,c'=1,h'=i-d&c<=TS()}]((h+(ai-as)*(TS()-c)>=hMAX()|(1=0->t-tr<=c))&h+(-as)*(TS()-c)>=hDEG()|(ai-as)*TS()>=RR()*TS()&(1=0->h>=hMIN()+RR()*(t-tr)))"); <(
                                  "Use":
                                    auto,
                                  "Show":
                                    auto
                                )
                            ),
                          "[{t'=1,c'=1,h'=i-d&c<=TS()}]((1=0&t-tr>(hMAX()-hMIN())/RR()->h+(ai-as)*(TS()-c)>=hMAX())&(1=0&t-tr>(hMAX()-hMIN())/RR()&(as < sMAX()|h < hMAX())->t-tr+(TS()-c)<=(hMAX()-hMIN())/RR()+TS()))":
                            allL2R('L=="fail=1");
                            auto
                        )
                    )
                )
            )
        )
    )
)
End.
/* End printed tactics */
