Lemma "FM/Robf: Proof".
"  ==>  (((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>((xr)-(xa)))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>((yr)-(ya)))) > (TEVD()))&(((VMAXa()) >= ((0)))&(((VMINr()) >= ((0)))&(((VMAXr()) >= (VMINr()))&(((cr) = ((0)))&(((TS()) >= (cr))&(((t) = ((0)))&(((tDHIGH()) >= ((0)))&(((tDHIGH()) >= (tDLOW()))&((TEVD()) >= (TSTP())))))))))))&(((dS) = ((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>((xr)-(xa)))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>((yr)-(ya)))))&(((\exists vxr (\exists vyr (((VMINr()) <= ((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))))&((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))) <= (VMAXr()))&((((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDLOW()))))) > (TEVD()))&(((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDHIGH()))))) > (TSTP())))))))->(((VMINr()) <= ((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))))&((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))) <= (VMAXr()))&((((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDLOW()))))) > (TEVD()))&(((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDHIGH()))))) > (TSTP()))))))&(((!(\exists vxr (\exists vyr (((VMINr()) <= ((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))))&((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))) <= (VMAXr()))&((((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDLOW()))))) > (TEVD()))&(((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDHIGH()))))) > (TSTP()))))))))->(((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))) = ((0))))&(((ths) = (-((1))))&((tD) = ((0))))))))->([{{dS:=(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>((xr)-(xa)))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>((yr)-(ya)));};{{{tDOld:=tD;};{{tD:=*;};{{?((tD) <= (tDHIGH()));};{{{{?(((tD) > (tDLOW()))&((tDOld) <= (tDLOW())));};{{ths:=t;};{{dhs:=(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>((xr)-(xa)))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>((yr)-(ya)));};{vhs:=(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr));}}}}++{?(!(((tD) > (tDLOW()))&((tDOld) <= (tDLOW()))));}};{{{?((cr) >= ((TS())+(tD)));};{{cr:=(0);};{{vxr:=*;};{{vyr:=*;};{{{?(\exists vxr (\exists vyr (((VMINr()) <= ((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))))&((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))) <= (VMAXr()))&((((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDLOW()))))) > (TEVD()))&(((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDHIGH()))))) > (TSTP())))))));};{?(((VMINr()) <= ((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))))&((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))) <= (VMAXr()))&((((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDLOW()))))) > (TEVD()))&(((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDHIGH()))))) > (TSTP())))));}}++{{?(!(\exists vxr (\exists vyr (((VMINr()) <= ((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))))&((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))) <= (VMAXr()))&((((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDLOW()))))) > (TEVD()))&(((dS)+(-((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr)))+(VMAXa()))*((TS())+(tDHIGH()))))) > (TSTP()))))))));};{?(((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))) = ((0)));}}}}}}}++{?(!((cr) >= ((TS())+(tD))));}}}}}};{{{vxa:=*;};{{vya:=*;};{?(((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxa))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vya))) <= (VMAXa()));}}};{{t'=(1.0),cr'=(1.0),xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr) <= ((TS())+(tD))}}}}}*](((((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>((xr)-(xa)))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>((yr)-(ya)))) > (TSTP()))&(((VMINr()) <= ((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))))&(((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))) <= (VMAXr()))))|(((abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vxr))+(abs<< ._1 < 0&._0=-._1|._1>=0&._0=._1 >>(vyr))) = ((0)))))
\qed::d55e27d0e12352bd9619a0273ca47294"
End.
Tool.
  tool """" KeYmaera X """"
  model """" Theorem "FM/Robf"

ProgramVariables
  Real t;
  Real cr;          /* clock of rob */

  Real vxr;         /* velocity of rob */
  Real vyr;
  Real xr;          /* pos of rob */
  Real yr;
  
  Real vxa;         /* velocity of opponent */
  Real vya;
  Real xa;          /* Pos of opponent (a) */
  Real ya;

  Real dS;          /* Sensor Variable */
  
  Real tD;
  Real tDOld;
  Real ths;
  Real dhs;
  Real vhs;
End.


Definitions
  Real TS;          /* Sampling-Time r-contract */
  Real VMAXa;       /* Max. velocity of opponent */
  Real VMAXr;       /* Max. velocity of rob */
  Real VMINr;       /* Min. velocity of rob in RobEVD */
  Real TEVD;        /* Evasion Threshold */
  Real TSTP;        /* Stop Threshold */
  
  Real tDHIGH;        /* Maximum possible delay */
  Real tDLOW;         /* Maximum low delay */
  
  
  Real n(Real x, Real y) = abs(x)+abs(y); /* L1 Norm */        
  Real d(Real x1, Real y1, Real x2, Real y2) = n(x1-x2, y1-y2); /* L1 Distance */
  
  Bool HCFull(Real dS, Real vxr, Real vyr) <-> VMINr <= n(vxr,vyr) & n(vxr,vyr) <= VMAXr & dS+WCRLS(vxr,vyr) > TEVD & dS+WCRHS(vxr,vyr) > TSTP;
  
  Real WCRLS(Real vxr, Real vyr) = -(n(vxr,vyr)+VMAXa)*(TS+tDLOW);  /* worst case reaction low stress */
  Real WCRHS(Real vxr, Real vyr) = -(n(vxr,vyr)+VMAXa)*(TS+tDHIGH); /* worst case reaction low stress */
  Bool HCFB(Real dS, Real vxr, Real vyr) <-> n(vxr,vyr)=0; 
End.

Problem
(d(xr, yr, xa, ya) > TEVD & VMAXa >=0 & 
VMINr >= 0 & VMAXr >= VMINr & 
cr=0 & TS>=cr & t=0 &
tDHIGH >= 0 & tDHIGH>=tDLOW & TEVD>=TSTP) & 
/* RL contract holds in initial time step */
dS = d(xr, yr, xa, ya) &
((\exists vxr \exists vyr HCFull(dS, vxr, vyr)) -> HCFull(dS, vxr, vyr)) & 
(!((\exists vxr \exists vyr HCFull(dS, vxr, vyr))) -> HCFB(dS, vxr, vyr)) &
(ths=-1 & tD=0) /* no delay initially */
->
[ 
    {
        {
        /* Sensor contract*/
            dS:=d(xr, yr, xa, ya);
        }
        /* Controller contract */
        {tDOld:=tD;
        tD:=*; ?tD<=tDHIGH;
        if(tD>tDLOW&tDOld<=tDLOW) {ths:=t;dhs:=d(xr, yr, xa, ya);vhs:=n(vxr,vyr);}; /* observer for high delay */
        if(cr >= TS+tD) {
            cr:=0;
            vxr:= *; vyr:= *;
            if(\exists vxr \exists vyr HCFull(dS, vxr, vyr)){?HCFull(dS, vxr, vyr);}
            else{?HCFB(dS, vxr, vyr);}; /* Since HCFB does not maintain any thresholds and merely sets velocity to zero, we have omitted \exists vxr \exists vyr for simplicity. */
        }}
        /* Opp Ctr */
        {
            vxa:= *; vya:= *;
            ?n(vxa, vya)<=VMAXa;
        }
        /* Continuous evolution */
        {
            t' = 1.0,
            cr' = 1.0,
            xr' = vxr, yr' = vyr,
            xa'  = vxa,  ya'  = vya &
            (cr <= TS+tD)
        }
    }*@invariant(t>=0 & 0<=cr & cr <= TS+tDHIGH & 
    (((d(xr, yr, xa, ya)-(n(vxr,vyr)+VMAXa)*(TS+tDHIGH-cr) > TSTP & VMINr<=n(vxr,vyr) & n(vxr,vyr) <= VMAXr |  n(vxr,vyr)=0))) 
    )
] 
(
    (((d(xr, yr, xa, ya) > TSTP & VMINr<=n(vxr,vyr) & n(vxr,vyr) <= VMAXr |  n(vxr,vyr)=0)))
)/* full service or stop */
End.


End. """"
  tactic """" unfold;
loop("t>=0&0<=cr&cr<=TS()+tDHIGH()&(d(xr,yr,xa,ya)-(n(vxr,vyr)+VMAXa())*(TS()+tDHIGH()-cr)>TSTP()&VMINr()<=n(vxr,vyr)&n(vxr,vyr)<=VMAXr()|n(vxr,vyr)=0)", 'R=="[{dS:=d(xr,yr,xa,ya);{tDOld:=tD;tD:=*;?tD<=tDHIGH();{?tD>tDLOW()&tDOld<=tDLOW();ths:=t;dhs:=d(xr,yr,xa,ya);vhs:=n(vxr,vyr);++?!(tD>tDLOW()&tDOld<=tDLOW());}{?cr>=TS()+tD;cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr HCFull(dS,vxr,vyr);?HCFull(dS,vxr,vyr);++?!\exists vxr \exists vyr HCFull(dS,vxr,vyr);?HCFB(dS,vxr,vyr);}++?!cr>=TS()+tD;}}{vxa:=*;vya:=*;?n(vxa,vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}}*](d(xr,yr,xa,ya)>TSTP()&VMINr()<=n(vxr,vyr)&n(vxr,vyr)<=VMAXr()|n(vxr,vyr)=0)"); <(
  "Init":
    cut("\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())|!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())"); <(
      "Use":
        orL('L=="\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())|!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())"); <(
          "\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())":
            implyL('L=="\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())->VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP()"); <(
              "\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())":
                hideR('R=="t>=0&0<=cr&cr<=TS()+tDHIGH()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)");
                QE,
              "VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP()":
                unfold;
                fullSimplify;
                QE
            ),
          "!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())":
            unfold;
            hideL('L=="\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())->VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP()");
            unfold;
            fullSimplify;
            QE
        ),
      "Show":
        hideR('R=="t>=0&0<=cr&cr<=TS()+tDHIGH()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)");
        QE
    ),
  "Post":
    unfold;
    fullSimplify;
    QE,
  "Step":
    composeb('R=="[dS:=abs(xr-xa)+abs(yr-ya);{tDOld:=tD;tD:=*;?tD<=tDHIGH();{?tD>tDLOW()&tDOld<=tDLOW();ths:=t;dhs:=abs(xr-xa)+abs(yr-ya);vhs:=abs(vxr)+abs(vyr);++?!(tD>tDLOW()&tDOld<=tDLOW());}{?cr>=TS()+tD;cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP());?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP();++?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;}++?!cr>=TS()+tD;}}{vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](t>=0&0<=cr&cr<=TS()+tDHIGH()&(abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH()-cr)>TSTP()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0))");
