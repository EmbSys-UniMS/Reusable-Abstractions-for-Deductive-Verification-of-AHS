                                dW('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD&xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0}](abs(xro+vxr*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxr)+abs(vxa))*(cr-cro)&abs(yro+vyr*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyr)+abs(vya))*(cr-cro))");
                                discreteGhost("cr-cro", "p", 'R=="abs(xro+vxr*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxr)+abs(vxa))*(cr-cro)&abs(yro+vyr*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyr)+abs(vya))*(cr-cro)");
                                hideL('L=="p=cr-cro");
                                unfold;
                                fullSimplify;
                                auto
                            ),
                          "Show":
                            boxAnd('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)");
                            andR('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]xa=xao+vxa*(cr-cro)&[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)"); <(
                              "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]xa=xao+vxa*(cr-cro)":
                                auto,
                              "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)":
                                boxAnd('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)");
                                andR('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]ya=yao+vya*(cr-cro)&[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)"); <(
                                  "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]ya=yao+vya*(cr-cro)":
                                    auto,
                                  "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)":
                                    boxAnd('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)");
                                    andR('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]xr=xro+vxr*(cr-cro)&[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](yr=yro+vyr*(cr-cro)&TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)"); <(
                                      "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]xr=xro+vxr*(cr-cro)":
                                        auto,
                                      "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](yr=yro+vyr*(cr-cro)&TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)":
                                        boxAnd('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](yr=yro+vyr*(cr-cro)&TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)");
                                        andR('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]yr=yro+vyr*(cr-cro)&[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)"); <(
                                          "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]yr=yro+vyr*(cr-cro)":
                                            auto,
                                          "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)":
                                            boxAnd('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}](TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&cr-cro>=0)");
                                            andR('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)&[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]cr-cro>=0"); <(
                                              "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]TS()+tDHIGH()-cr=TS()+tDHIGH()-cro-(cr-cro)":
                                                auto,
                                              "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]cr-cro>=0":
