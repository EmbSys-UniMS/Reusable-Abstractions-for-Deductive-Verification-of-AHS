/* Exported from KeYmaera X v5.0 */

Theorem "FM/Robg"

ProgramVariables
  Real t;
  Real cr;          /* clock of rob */

  Real vxr;         /* velocity of rob */
  Real vyr;
  Real xr;          /* pos of rob */
  Real yr;
  
  Real vxa;         /* velocity of opponent */
  Real vya;
  Real xa;          /* Pos of opponent (a) */
  Real ya;

  Real dS;          /* Sensor Variable */
  
  Real tD;
  Real tDOld;
  
  Real ths;
  Real dhs;
  Real vhs;
  Real tls;
  Real dls;
  Real vls;
End.


Definitions
  Real TS;          /* Sampling-Time r-contract */
  Real VMAXa;       /* Max. velocity of opponent */
  Real VMAXr;       /* Max. velocity of rob */
  Real VMINr;       /* Min. velocity of rob in RobEVD */
  Real TEVD;        /* Evasion Threshold */
  Real TSTP;        /* Stop Threshold */
  
  Real tDHIGH;        /* Maximum possible delay */
  Real tDLOW;         /* Maximum low delay */
  
  
  Real n(Real x, Real y) = abs(x)+abs(y); /* L1 Norm */        
  Real d(Real x1, Real y1, Real x2, Real y2) = n(x1-x2, y1-y2); /* L1 Distance */
  
  Bool HCFull(Real dS, Real vxr, Real vyr) <-> VMINr <= n(vxr,vyr) & n(vxr,vyr) <= VMAXr & dS+WCRLS(vxr,vyr) > TEVD & dS+WCRHS(vxr,vyr) > TSTP;
  
  Real WCRLS(Real vxr, Real vyr) = -(n(vxr,vyr)+VMAXa)*(TS+tDLOW);  /* worst case reaction low stress */
  Real WCRHS(Real vxr, Real vyr) = -(n(vxr,vyr)+VMAXa)*(TS+tDHIGH); /* worst case reaction low stress */
  Bool HCFB(Real dS, Real vxr, Real vyr) <-> n(vxr,vyr)=0; 
End.

Problem
(d(xr, yr, xa, ya) > TEVD & VMAXa >=0 & 
VMINr >= 0 & VMAXr >= VMINr & 
cr=0 & TS>=cr & t=0 &
tDLOW >= 0 & tDHIGH>=tDLOW & TEVD>=TSTP) & 
/* RL contract holds in initial time step */
dS = d(xr, yr, xa, ya) &
((\exists vxr \exists vyr HCFull(dS, vxr, vyr)) -> HCFull(dS, vxr, vyr)) & 
(!((\exists vxr \exists vyr HCFull(dS, vxr, vyr))) -> HCFB(dS, vxr, vyr)) &
tls=0 & dls=d(xr, yr, xa, ya) & vls=n(vxr,vyr) &
(ths=-1 & tD=0) /* no delay initially */
->
[ 
    {
        {
        /* Sensor contract*/
            dS:=d(xr, yr, xa, ya);
        }
        /* Controller contract */
        {
        {tDOld:=tD;
        tD:=*; ?-TS<=tD&tD<=tDHIGH;
        if(tD<=tDLOW&tDOld>tDLOW) {tls:=t;dls:=d(xr, yr, xa, ya);vls:=n(vxr,vyr);};}/* observer for getting back to low delay  */
        if(cr >= TS+tD) {
            cr:=0;
            vxr:= *; vyr:= *;
            if(\exists vxr \exists vyr HCFull(dS, vxr, vyr)){?HCFull(dS, vxr, vyr);}
            else{?HCFB(dS, vxr, vyr);}; /* Since HCFB does not maintain any thresholds and merely sets velocity to zero, we have omitted \exists vxr \exists vyr for simplicity. */
        }
        }
        /* Opp Ctr */
        {
            vxa:= *; vya:= *;
            ?n(vxa, vya)<=VMAXa;
        }
        /* Continuous evolution */
        {
            t' = 1.0,
            cr' = 1.0,
            xr' = vxr, yr' = vyr,
            xa'  = vxa,  ya'  = vya &
            (cr <= TS+tD)
        }
    }*@invariant(
    (t>=0 & 0<=cr & cr <= TS+tD & TS >=0 & -TS<=tD&tD<=tDHIGH) &
    ((((d(xr, yr, xa, ya)>TEVD))|(tD<=tDLOW & dls>TEVD)) -> (d(xr, yr, xa, ya)-(n(vxr,vyr)+VMAXa)*(TS+tDLOW-cr) > TEVD & VMINr<=n(vxr,vyr) & n(vxr,vyr) <= VMAXr |  n(vxr,vyr)=0)) &
    (d(xr, yr, xa, ya)<=TEVD & n(vxr,vyr)>0 -> cr>TS+tDLOW & VMINr<=n(vxr,vyr) & n(vxr,vyr) <= VMAXr)
    )
] 
(
    (tD<=tDLOW & dls>=TEVD -> (d(xr, yr, xa, ya) > TEVD & VMINr<=n(vxr,vyr) & n(vxr,vyr) <= VMAXr |  n(vxr,vyr)=0))
)/* full service or stop */
End.

Tactic "FM/Robg: Proof"
unfold;
loop("(t>=0&0<=cr&cr<=TS()+tD&TS()>=0&-TS()<=tD&tD<=tDHIGH())&(d(xr,yr,xa,ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->d(xr,yr,xa,ya)-(n(vxr,vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=n(vxr,vyr)&n(vxr,vyr)<=VMAXr()|n(vxr,vyr)=0)&(d(xr,yr,xa,ya)<=TEVD()&n(vxr,vyr)>0->cr>TS()+tDLOW()&VMINr()<=n(vxr,vyr)&n(vxr,vyr)<=VMAXr())", 'R=="[{dS:=d(xr,yr,xa,ya);{{tDOld:=tD;tD:=*;?-TS()<=tD&tD<=tDHIGH();{?tD<=tDLOW()&tDOld>tDLOW();tls:=t;dls:=d(xr,yr,xa,ya);vls:=n(vxr,vyr);++?!(tD<=tDLOW()&tDOld>tDLOW());}}{?cr>=TS()+tD;cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr HCFull(dS,vxr,vyr);?HCFull(dS,vxr,vyr);++?!\exists vxr \exists vyr HCFull(dS,vxr,vyr);?HCFB(dS,vxr,vyr);}++?!cr>=TS()+tD;}}{vxa:=*;vya:=*;?n(vxa,vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}}*](tD<=tDLOW()&dls>=TEVD()->d(xr,yr,xa,ya)>TEVD()&VMINr()<=n(vxr,vyr)&n(vxr,vyr)<=VMAXr()|n(vxr,vyr)=0)"); <(
  "Init":
    cut("\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())|!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())"); <(
      "Use":
        orL('L=="\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())|!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())"); <(
          "\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())":
            implyL('L=="\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())->VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP()"); <(
              "\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())":
                hideR('R=="(t>=0&0<=cr&cr<=TS()+tD&TS()>=0&-TS()<=tD&tD<=tDHIGH())&(abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr())");
                QE,
              "VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP()":
                hideL('L=="!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())->abs(vxr)+abs(vyr)=0");
                hideL('L=="\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())");
                unfold;
                fullSimplify;
                QE
            ),
          "!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP())":
            unfold;
            fullSimplify;
            QE
        ),
      "Show":
        simplify('R=="(t>=0&0<=cr&cr<=TS()+tD&TS()>=0&-TS()<=tD&tD<=tDHIGH())&(abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr())");
        QE
    ),
  "Post":
    QE,
  "Step":
    composeb('R=="[dS:=abs(xr-xa)+abs(yr-ya);{{tDOld:=tD;tD:=*;?-TS()<=tD&tD<=tDHIGH();{?tD<=tDLOW()&tDOld>tDLOW();tls:=t;dls:=abs(xr-xa)+abs(yr-ya);vls:=abs(vxr)+abs(vyr);++?!(tD<=tDLOW()&tDOld>tDLOW());}}{?cr>=TS()+tD;cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP());?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP();++?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;}++?!cr>=TS()+tD;}}{vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]((t>=0&0<=cr&cr<=TS()+tD&TS()>=0&-TS()<=tD&tD<=tDHIGH())&(abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()))");
    composeb('R=="[dS:=abs(xr-xa)+abs(yr-ya);]#[{{tDOld:=tD;tD:=*;?-TS()<=tD&tD<=tDHIGH();{?tD<=tDLOW()&tDOld>tDLOW();tls:=t;dls:=abs(xr-xa)+abs(yr-ya);vls:=abs(vxr)+abs(vyr);++?!(tD<=tDLOW()&tDOld>tDLOW());}}{?cr>=TS()+tD;cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP());?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP();++?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;}++?!cr>=TS()+tD;}}{vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]((t>=0&0<=cr&cr<=TS()+tD&TS()>=0&-TS()<=tD&tD<=tDHIGH())&(abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()))#");
    assignb('R=="[dS:=abs(xr-xa)+abs(yr-ya);][{tDOld:=tD;tD:=*;?-TS()<=tD&tD<=tDHIGH();{?tD<=tDLOW()&tDOld>tDLOW();tls:=t;dls:=abs(xr-xa)+abs(yr-ya);vls:=abs(vxr)+abs(vyr);++?!(tD<=tDLOW()&tDOld>tDLOW());}}{?cr>=TS()+tD;cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP());?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP();++?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&dS+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;}++?!cr>=TS()+tD;}][{vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]((t>=0&0<=cr&cr<=TS()+tD&TS()>=0&-TS()<=tD&tD<=tDHIGH())&(abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()))");
    MR("(t>=0&0<=cr&cr<=TS()+tD&TS()>=0&-TS()<=tD&tD<=tDHIGH())&(abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr())", 'R=="[{tDOld:=tD;tD:=*;?-TS()<=tD&tD<=tDHIGH();{?tD<=tDLOW()&tDOld>tDLOW();tls:=t;dls:=abs(xr-xa)+abs(yr-ya);vls:=abs(vxr)+abs(vyr);++?!(tD<=tDLOW()&tDOld>tDLOW());}}{?cr>=TS()+tD;cr:=0;vxr:=*;vyr:=*;{?\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&abs(xr-xa)+abs(yr-ya)+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&abs(xr-xa)+abs(yr-ya)+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP());?VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&abs(xr-xa)+abs(yr-ya)+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&abs(xr-xa)+abs(yr-ya)+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP();++?!\exists vxr \exists vyr (VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()&abs(xr-xa)+abs(yr-ya)+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW())>TEVD()&abs(xr-xa)+abs(yr-ya)+-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDHIGH())>TSTP());?abs(vxr)+abs(vyr)=0;}++?!cr>=TS()+tD;}][{vxa:=*;vya:=*;?abs(vxa)+abs(vya)<=VMAXa();}{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD}]((t>=0&0<=cr&cr<=TS()+tD&TS()>=0&-TS()<=tD&tD<=tDHIGH())&(abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()))"); <(
