              "Use":
                boxAnd('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()+tD&xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&cr-cro>=0)&abs(xro+vxr*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxr)+abs(vxa))*(cr-cro)&abs(yro+vyr*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyr)+abs(vya))*(cr-cro)}]((t>=0&0<=cr&cr<=TS()+tD&TS()>=0&-TS()<=tD&tD<=tDHIGH())&(abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()))");
                andR('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()+tD&xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&cr-cro>=0)&abs(xro+vxr*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxr)+abs(vxa))*(cr-cro)&abs(yro+vyr*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyr)+abs(vya))*(cr-cro)}](t>=0&0<=cr&cr<=TS()+tD&TS()>=0&-TS()<=tD&tD<=tDHIGH())&[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()+tD&xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&cr-cro>=0)&abs(xro+vxr*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxr)+abs(vxa))*(cr-cro)&abs(yro+vyr*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyr)+abs(vya))*(cr-cro)}]((abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()))"); <(
                  "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()+tD&xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&cr-cro>=0)&abs(xro+vxr*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxr)+abs(vxa))*(cr-cro)&abs(yro+vyr*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyr)+abs(vya))*(cr-cro)}](t>=0&0<=cr&cr<=TS()+tD&TS()>=0&-TS()<=tD&tD<=tDHIGH())":
                    hideL('L=="abs(xro-xao)+abs(yro-yao)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xro-xao)+abs(yro-yao)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cro)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0");
                    hideL('L=="abs(xro-xao)+abs(yro-yao)<=TEVD()&abs(vxr)+abs(vyr)>0->cro>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()");
                    auto,
                  "[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()+tD&xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&cr-cro>=0)&abs(xro+vxr*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxr)+abs(vxa))*(cr-cro)&abs(yro+vyr*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyr)+abs(vya))*(cr-cro)}]((abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()))":
                    unfold;
                    cut("abs(xro-xao)+abs(yro-yao)<=TEVD()&abs(vxr)+abs(vyr)>0|!(abs(xro-xao)+abs(yro-yao)<=TEVD()&abs(vxr)+abs(vyr)>0)"); <(
                      "Use":
                        cut("tD<=tDLOW()&dls>TEVD()|!(tD<=tDLOW()&dls>TEVD())"); <(
                          "Use":
                            orL('L=="abs(xro-xao)+abs(yro-yao)<=TEVD()&abs(vxr)+abs(vyr)>0|!(abs(xro-xao)+abs(yro-yao)<=TEVD()&abs(vxr)+abs(vyr)>0)"); <(
                              "abs(xro-xao)+abs(yro-yao)<=TEVD()&abs(vxr)+abs(vyr)>0":
                                orL('L=="tD<=tDLOW()&dls>TEVD()|!(tD<=tDLOW()&dls>TEVD())"); <(
                                  "tD<=tDLOW()&dls>TEVD()":
                                    unfold;
                                    fullSimplify;
                                    auto,
                                  "!(tD<=tDLOW()&dls>TEVD())":
                                    unfold;
                                    fullSimplify;
                                    notAnd('L=="!(tD<=tDLOW()&dls>TEVD())");
                                    orL('L=="!tD<=tDLOW()|!dls>TEVD()"); <(
                                      "!tD<=tDLOW()":
                                        auto,
                                      "!dls>TEVD()":
                                        auto
                                    )
                                ),
                              "!(abs(xro-xao)+abs(yro-yao)<=TEVD()&abs(vxr)+abs(vyr)>0)":
                                orL('L=="tD<=tDLOW()&dls>TEVD()|!(tD<=tDLOW()&dls>TEVD())"); <(
                                  "tD<=tDLOW()&dls>TEVD()":
                                    unfold;
                                    fullSimplify;
                                    unfold;
                                    notAnd('L=="!(abs(xro-xao)+abs(yro-yao)<=TEVD()&abs(vxr)+abs(vyr)>0)");
                                    notGreater('L=="!abs(xro-xao)+abs(yro-yao)<=TEVD()|#!abs(vxr)+abs(vyr)>0#");
                                    notLessEqual('L=="#!abs(xro-xao)+abs(yro-yao)<=TEVD()#|abs(vxr)+abs(vyr)<=0");
                                    orL('L=="abs(xro-xao)+abs(yro-yao)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cro)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0"); <(
                                      "abs(xro-xao)+abs(yro-yao)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cro)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()":
                                        unfold;
                                        orL('L=="abs(xro-xao)+abs(yro-yao)>TEVD()|abs(vxr)+abs(vyr)<=0"); <(
                                          "abs(xro-xao)+abs(yro-yao)>TEVD()":
                                            auto,
                                          "abs(vxr)+abs(vyr)<=0":
                                            auto
                                        ),
                                      "abs(vxr)+abs(vyr)=0":
                                        hideL('L=="abs(xro-xao)+abs(yro-yao)>TEVD()|abs(vxr)+abs(vyr)<=0");
                                        auto
                                    ),
                                  "!(tD<=tDLOW()&dls>TEVD())":
                                    unfold;
                                    fullSimplify;
                                    notAnd('L=="!(abs(xro-xao)+abs(yro-yao)<=TEVD()&abs(vxr)+abs(vyr)>0)");
                                    notAnd('L=="!(tD<=tDLOW()&dls>TEVD())");
                                    fullSimplify;
                                    orL('L=="abs(xro-xao)+abs(yro-yao)>TEVD()|abs(vxr)+abs(vyr)<=0"); <(
                                      "abs(xro-xao)+abs(yro-yao)>TEVD()":
                                        fullSimplify;
                                        orL('L=="tD>tDLOW()|dls<=TEVD()"); <(
                                          "tD>tDLOW()":
                                            auto,
                                          "dls<=TEVD()":
                                            auto
                                        ),
                                      "abs(vxr)+abs(vyr)<=0":
                                        orL('L=="tD>tDLOW()|dls<=TEVD()"); <(
                                          "tD>tDLOW()":
                                            unfold;
                                            fullSimplify;
                                            auto,
                                          "dls<=TEVD()":
                                            unfold;
                                            fullSimplify;
                                            auto
                                        )
                                    )
                                )
                            ),
                          "Show":
                            hideR('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()+tD&xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&cr-cro>=0)&abs(xro+vxr*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxr)+abs(vxa))*(cr-cro)&abs(yro+vyr*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyr)+abs(vya))*(cr-cro)}]((abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()))");
                            QE
                        ),
                      "Show":
                        hideR('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&(cr<=TS()+tD&xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&cr-cro>=0)&abs(xro+vxr*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxr)+abs(vxa))*(cr-cro)&abs(yro+vyr*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyr)+abs(vya))*(cr-cro)}]((abs(xr-xa)+abs(yr-ya)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xr-xa)+abs(yr-ya)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cr)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0)&(abs(xr-xa)+abs(yr-ya)<=TEVD()&abs(vxr)+abs(vyr)>0->cr>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()))");
                        QE
                    )
                ),
              "Show":
                dW('R=="[{t'=1.0,cr'=1.0,xr'=vxr,yr'=vyr,xa'=vxa,ya'=vya&cr<=TS()+tD&xa=xao+vxa*(cr-cro)&ya=yao+vya*(cr-cro)&xr=xro+vxr*(cr-cro)&yr=yro+vyr*(cr-cro)&cr-cro>=0}](abs(xro+vxr*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxr)+abs(vxa))*(cr-cro)&abs(yro+vyr*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyr)+abs(vya))*(cr-cro))");
                discreteGhost("cr-cro", "p", 'R=="abs(xro+vxr*(cr-cro)-(xao+vxa*(cr-cro)))>=abs(xro-xao)-(abs(vxr)+abs(vxa))*(cr-cro)&abs(yro+vyr*(cr-cro)-(yao+vya*(cr-cro)))>=abs(yro-yao)-(abs(vyr)+abs(vya))*(cr-cro)");
                hideL('L=="p=cr-cro");
                unfold;
                fullSimplify;
                hideL('L=="abs(xro-xao)+abs(yro-yao)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xro-xao)+abs(yro-yao)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cro)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0");
                hideL('L=="abs(xro-xao)+abs(yro-yao)<=TEVD()&abs(vxr)+abs(vyr)>0->cro>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()");
                QE
            ),
          "Show":
            unfold;
            fullSimplify;
            hideL('L=="abs(xro-xao)+abs(yro-yao)>TEVD()|tD<=tDLOW()&dls>TEVD()->abs(xro-xao)+abs(yro-yao)-(abs(vxr)+abs(vyr)+VMAXa())*(TS()+tDLOW()-cro)>TEVD()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()|abs(vxr)+abs(vyr)=0");
            hideL('L=="abs(xro-xao)+abs(yro-yao)<=TEVD()&abs(vxr)+abs(vyr)>0->cro>TS()+tDLOW()&VMINr()<=abs(vxr)+abs(vyr)&abs(vxr)+abs(vyr)<=VMAXr()");
            auto
        )
    )
)
End.

End.