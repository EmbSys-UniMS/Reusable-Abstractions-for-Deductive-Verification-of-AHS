                  "Use":
                    discreteGhost("wl", "wlStart", 'L=="wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()");
                    dC("wl>=wlStart", 'R=="[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5&(wl>0&crl<=TS())&u*b-a*wl^0.5>=0}](wl>wlMIN()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN())"); <(
                      "Use":
