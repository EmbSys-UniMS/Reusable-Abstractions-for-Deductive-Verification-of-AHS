                            auto,
                          "[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5&((wl>0&crl<=TS())&u*b-a*wl^0.5<=0&u*b-a*wl^0.5>=flowStart)&wl>=wlStart+flowStart*(crl-crlStart)}](TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN())":
