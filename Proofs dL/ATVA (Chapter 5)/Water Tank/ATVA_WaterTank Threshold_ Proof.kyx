              "u*b-a*wl^0.5<=0":
                discreteGhost("u*b-a*wl^0.5", "flowStart", 'L=="wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()");
                dC("u*b-a*wl^0.5<=0&u*b-a*wl^0.5>=flowStart", 'R=="[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5&wl>0&crl<=TS()}](wl>wlMIN()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN())"); <(
                  "Use":
                    discreteGhost("crl", "crlStart", 'L=="flowStart=u*b-a*wl^0.5");
                    discreteGhost("wl", "wlStart", 'L=="wl+flowStart*(TS()-crlStart)>wlMIN()");
                    dC("wl>=wlStart+flowStart*(crl-crlStart)", 'R=="[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5&(wl>0&crl<=TS())&u*b-a*wl^0.5<=0&u*b-a*wl^0.5>=flowStart}](wl>wlMIN()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN())"); <(
