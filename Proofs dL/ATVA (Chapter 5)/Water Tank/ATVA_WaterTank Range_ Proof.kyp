End. """"
  tactic """" unfold;
loop("(TS()-crl>=0&crl>=0.0&u>=0.0)&(wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl>wlMIN())&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX()&wl < wlMAX()", 'R=="[{{?crl>=TS();crl:=0.0;u:=*;?u>=0.0&wl+(u*b-a*wl^0.5)*TS()>wlMIN()&wl+(u*b-a*wl^0.5)*TS() < wlMAX();++?crl < TS();}{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5&wl>0&crl<=TS()}}*](wl>wlMIN()&wl < wlMAX())"); <(
  "Init":
    auto,
  "Post":
    auto,
