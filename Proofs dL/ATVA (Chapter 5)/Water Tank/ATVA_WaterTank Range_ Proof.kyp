                    hideR('R=="[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5&(wl>0&crl<=TS())&TS()>=0&TS()-crl>=0}]((wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl>wlMIN())&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX()&wl < wlMAX())");
                    QE
                )
            ),
          "Show":
            auto
        )
    )
) """"
End.

Tool.
  kyxversion """" 5.1.2 """"
End.
