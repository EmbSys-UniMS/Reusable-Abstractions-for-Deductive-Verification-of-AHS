Lemma "ATVA/WaterTank Range: Proof".
"  ==>  (((t) = ((0.0)))&(((crl) = ((0.0)))&((((u) >= ((0.0)))&(((u) > ((((wlMIN())-(wl))/((TS())*(b)))+(((a)/(b))*((wl)^((0.5))))))&((u) < ((((wlMAX())-(wl))/((TS())*(b)))+(((a)/(b))*((wl)^((0.5))))))))&(((wl) > (wlMIN()))&(((wl) < (wlMAX()))&(((TS()) > ((0.0)))&(((wlMAX()) > ((0)))&(((wlMIN()) > ((0)))&(((wlMAX()) > (wlMIN()))&(((b) > ((0)))&((a) > ((0)))))))))))))->([{{{{?((crl) >= (TS()));};{{crl:=(0.0);};{{u:=*;};{?(((u) >= ((0.0)))&((((wl)+((((u)*(b))-((a)*((wl)^((0.5)))))*(TS()))) > (wlMIN()))&(((wl)+((((u)*(b))-((a)*((wl)^((0.5)))))*(TS()))) < (wlMAX()))));}}}}++{?((crl) < (TS()));}};{{t'=(1.0),crl'=(1.0),wl'=((u)*(b))-((a)*((wl)^((0.5))))&((wl) > ((0)))&((crl) <= (TS()))}}}*](((wl) > (wlMIN()))&((wl) < (wlMAX()))))
\qed::78bc998e6b58a41c9760954be989c604"
End.
Tool.
  tool """" KeYmaera X """"
  model """" Theorem "ATVA/WaterTank Range"

Definitions
  Real epsSIZE;
  Real TS;
  Real wlMAX;
  Real wlMIN;
End.

ProgramVariables
  Real t;
  Real u;
  Real crl;
  Real wl;
  Real eps;
  Real a;
  Real b;
End.

Problem
  (t = 0.0)
  & (crl = 0.0)
  & ((u >= 0.0)
  & (u > ((wlMIN-wl)/(TS()*b)+((a/b)*(wl^0.5))))
  & (u < ((wlMAX-wl)/(TS()*b)+((a/b)*(wl^0.5)))))
  & (wl > wlMIN)
  & (wl < wlMAX)
  & (TS() > 0.0)
  & (wlMAX > 0)
  & (wlMIN > 0)
  & (wlMAX > wlMIN)
  & (b > 0) /* D in thesis*/
  & (a > 0) /* A in thesis*/
  ->
  [
    {
      {
        ?(crl >= TS);
        crl:=0.0;
        
        u:= *;
        {        
            ? (u >= 0.0)
            & (wl+(u*b-a*wl^0.5)*TS > wlMIN)
            & (wl+(u*b-a*wl^0.5)*TS < wlMAX);
        }
      ++
        ?(crl < TS);
        
      }
      {
        {
          t' = 1.0,
          crl' = 1.0,
          wl' = (u*b)-(a*(wl^0.5))
          & wl>0 & crl <= TS /* We assume wl > 0 to simplify the proof. This is without loss of generality, since we show wl > wlMIN > 0. */
        }
      }
      
    }*@invariant((TS-crl>=0&crl>=0.0&u>=0.0) & ((wl+(u*b-a*wl^0.5)*(TS-crl) > wlMIN&wl>wlMIN)) & (wl+(u*b-a*wl^0.5)*(TS-crl)<wlMAX&wl < wlMAX))
  ] ((wl > wlMIN) & (wl < wlMAX))
End.

Tactic "ATVA/WaterTank Range: Proof"
unfold;
loop("wl>wlMIN()&wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX()", 'R=="[{eps:=0.0;{?crl>=TS();crl:=0.0;u:=*;?u>=0.0&wl+(u*b-a*wl^0.5)*TS()>wlMIN()&wl+(u*b-a*wl^0.5)*TS() < wlMAX();++?crl < TS();}{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&wl>0&crl<=TS()}}*](wl>wlMIN()&wl < wlMAX())"); <(
  "Init":
    auto,
  "Post":
    auto,
  "Step":
    composeb('R=="[eps:=0.0;{?crl>=TS();crl:=0.0;u:=*;?u>=0.0&wl+(u*b-a*wl^0.5)*TS()>wlMIN()&wl+(u*b-a*wl^0.5)*TS() < wlMAX();++?crl < TS();}{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&wl>0&crl<=TS()}](wl>wlMIN()&wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX())");
    assignb('R=="[eps:=0.0;][{?crl>=TS();crl:=0.0;u:=*;?u>=0.0&wl+(u*b-a*wl^0.5)*TS()>wlMIN()&wl+(u*b-a*wl^0.5)*TS() < wlMAX();++?crl < TS();}{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&wl>0&crl<=TS()}](wl>wlMIN()&wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX())");
    composeb('R=="[{?crl>=TS();crl:=0.0;u:=*;?u>=0.0&wl+(u*b-a*wl^0.5)*TS()>wlMIN()&wl+(u*b-a*wl^0.5)*TS() < wlMAX();++?crl < TS();}{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&wl>0&crl<=TS()}](wl>wlMIN()&wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX())");
    MR("wl>wlMIN()&wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX()", 'R=="[?crl>=TS();crl:=0.0;u:=*;?u>=0.0&wl+(u*b-a*wl^0.5)*TS()>wlMIN()&wl+(u*b-a*wl^0.5)*TS() < wlMAX();++?crl < TS();][{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&wl>0&crl<=TS()}](wl>wlMIN()&wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX())"); <(
      "Use Q->P":
        auto,
      "Show [a]Q":
        cut("u*b-a*wl^0.5<=0|u*b-a*wl^0.5>=0"); <(
          "Use":
            discreteGhost("u*b-a*wl^0.5", "change", 'L=="u*b-a*wl^0.5<=0|u*b-a*wl^0.5>=0");
            orL('L=="change<=0|change>=0"); <(
              "change<=0":
                dC("u*b-a*wl^0.5<=0&u*b-a*wl^0.5>=change", 'R=="[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&wl>0&crl<=TS()}](wl>wlMIN()&wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX())"); <(
                  "Use":
                    discreteGhost("wl", "ho", 'L=="wl>wlMIN()&wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+change*(TS()-crl)>wlMIN()&wl+change*(TS()-crl) < wlMAX()");
                    dC("wl<=ho", 'R=="[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&(wl>0&crl<=TS())&u*b-a*wl^0.5<=0&u*b-a*wl^0.5>=change}](wl>wlMIN()&wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX())"); <(
