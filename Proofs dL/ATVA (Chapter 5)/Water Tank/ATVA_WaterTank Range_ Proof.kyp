                dC("u*b-a*wl^0.5>=0&u*b-a*wl^0.5<=change", 'R=="[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&wl>0&crl<=TS()}](wl>wlMIN()&wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX())"); <(
                  "Use":
                    boxAnd('R=="[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&(wl>0&crl<=TS())&u*b-a*wl^0.5>=0&u*b-a*wl^0.5<=change}](wl>wlMIN()&wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX())");
                    andR('R=="[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&(wl>0&crl<=TS())&u*b-a*wl^0.5>=0&u*b-a*wl^0.5<=change}]wl>wlMIN()&[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&(wl>0&crl<=TS())&u*b-a*wl^0.5>=0&u*b-a*wl^0.5<=change}](wl < wlMAX()&TS()>=crl&crl>=0.0&u>=0.0&wl+(u*b-a*wl^0.5)*(TS()-crl)>wlMIN()&wl+(u*b-a*wl^0.5)*(TS()-crl) < wlMAX())"); <(
                      "[{t'=1.0,crl'=1.0,wl'=u*b-a*wl^0.5,eps'=1.0&(wl>0&crl<=TS())&u*b-a*wl^0.5>=0&u*b-a*wl^0.5<=change}]wl>wlMIN()":
                        auto,
