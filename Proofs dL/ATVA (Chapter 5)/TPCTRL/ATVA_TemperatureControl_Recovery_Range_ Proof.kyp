Lemma "ATVA/TemperatureControl_Recovery_Range: Proof".
"  ==>  (((t) = ((0.0)))&(((crl) = ((0.0)))&(((TS()) > ((0)))&(((tLD) = ((0.0)))&(((tRECMAX()) > (TS()))&(((TMAX()) >= (T))&(((T) >= (TMIN()))&(((TMAX()) >= (TMIN()))&(((HMAX()) >= (h))&(((h) >= (HMIN()))&(((cool) >= ((0)))&((((T)+(((HMIN())-(cool))*(TS()))) >= (TMIN()))&(((T)+(((HMAX())-(cool))*(TS()))) <= (TMAX()))))))))))))))->([{{{h:=*;};{?(((HMAX()) >= (h))&((h) >= (HMIN())));}};{{{{?((crl) >= (TS()));};{{crl:=(0.0);};{{cool:=*;};{{?((cool) >= ((0)));};{{?(((T) < (TMIN()))->(((T)+(((HMIN())-(cool))*(((tLD)+(tRECMAX()))+(-(t))))) >= (TMIN())));};{{?(((T) > (TMAX()))->(((T)+(((HMAX())-(cool))*(((tLD)+(tRECMAX()))+(-(t))))) <= (TMAX())));};{{?(((T) >= (TMIN()))->(((T)+(((HMIN())-(cool))*(TS()))) >= (TMIN())));};{?(((T) <= (TMAX()))->(((T)+(((HMAX())-(cool))*(TS()))) <= (TMAX())));}}}}}}}}++{?((crl) < (TS()));}};{{{{T:=*;};{tLD:=t;}}++{?(true);}};{{t'=(1.0),crl'=(1.0),T'=(h)-(cool)&(crl) <= (TS())}}}}}*]((((t)-(tLD)) >= (tRECMAX()))->(((TMAX()) >= (T))&((T) >= (TMIN())))))
\qed::c256413154a5ca3dcfb537efb8f9d1b5"
End.
Tool.
  tool """" KeYmaera X """"
  model """" Theorem "ATVA/TemperatureControl_Recovery_Range"

Definitions
  Real TS;
  Real tRECMAX;
  Real CMAX;
  Real CMIN;
  Real TMIN;
  Real TMAX;
  Real HMAX;
  Real HMIN;
End.

ProgramVariables
  Real crl; 
  Real T;
  Real t;
  Real tLD;
  Real h;
  Real cool;
End.

Problem
/*Clocks Init Values + Evolutions*/
(t = 0.0)
& (crl = 0.0)
& (TS > 0)
& (tLD = 0.0)
& (tRECMAX>TS)
/*Threshold pre conditions*/
& (TMAX >= T)
& (T >= TMIN)
& (TMAX>=TMIN)
& (HMAX >= h)
& (h >= HMIN)
/*Contract conditions*/
& cool>=0
& ((T + ((HMIN - cool) *  TS) >= TMIN) & (T + ((HMAX - cool) *  TS) <= TMAX))
  ->
  [
    {
      {
        /*Opp chooses Action*/  
        h:= *;
        ?(HMAX >= h) & (h >= HMIN);
      }

      {
        /*Every TS the Agent chooses an Action that is valid under the Hybrid Contract*/  
        ?(crl >= TS);
            crl :=0.0;
            cool:= *;
            ?cool>=0;
            ?T<TMIN -> T + (HMIN - cool) *  (tLD + tRECMAX +  - t) >= TMIN;
            ?T>TMAX -> T + (HMAX - cool) *  (tLD + tRECMAX +  - t) <= TMAX;
            ?T>=TMIN -> T + (HMIN - cool) *  TS >= TMIN;
            ?T<=TMAX-> T + (HMAX - cool) *  TS <= TMAX;
        ++
        /*Do Nothing - Between Time TSs*/
        ?(crl < TS);
        
      }
      
      {
        /*DISTURBANCE*/
        T:=*;
        tLD:= t;
        ++ 
        /*Normal Case - NOTHING*/
        ?true;
      }
      
      {
        
        {
          /*Evolutions*/
          t' = 1.0,
          crl ' = 1.0,
          T' = (h - cool)
          & (crl  <= TS)
        }
      }
      
    }*@invariant(cool>=0&((T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN())&(T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX())&(T>=TMIN()->T+(HMIN()-cool)*(TS()-crl)>=TMIN())&(T<=TMAX()->T+(HMAX()-cool)*(TS()-crl)<=TMAX())|t-tLD<=crl)&crl>=0&crl<=TS()&(t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN()))
  ] (t-tLD >= tRECMAX -> (TMAX >= T & T >= TMIN))
End.

Tactic "TemperatureControl_Recovery_Range: Proof"
unfold;
loop("((T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN())&(T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX())&(T>=TMIN()->T+(HMIN()-cool)*(TS()-crl)>=TMIN())&(T<=TMAX()->T+(HMAX()-cool)*(TS()-crl)<=TMAX())|t-tLD<=crl)&crl>=0&crl<=TS()&(t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN())", 'R=="[{{h:=*;?HMAX()>=h&h>=HMIN();}{?crl>=TS();crl:=0.0;cool:=*;?T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN();?T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX();?T>=TMIN()->T+(HMIN()-cool)*TS()>=TMIN();?T<=TMAX()->T+(HMAX()-cool)*TS()<=TMAX();++?crl < TS();}{T:=*;tLD:=t;++?true;}{t'=1.0,crl'=1.0,T'=h-cool&crl<=TS()}}*](t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN())"); <(
  "Init":
    auto,
  "Post":
    auto,
  "Step":
    composeb('R=="[{h:=*;?HMAX()>=h&h>=HMIN();}{?crl>=TS();crl:=0.0;cool:=*;?T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN();?T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX();?T>=TMIN()->T+(HMIN()-cool)*TS()>=TMIN();?T<=TMAX()->T+(HMAX()-cool)*TS()<=TMAX();++?crl < TS();}{T:=*;tLD:=t;++?true;}{t'=1.0,crl'=1.0,T'=h-cool&crl<=TS()}](((T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN())&(T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX())&(T>=TMIN()->T+(HMIN()-cool)*(TS()-crl)>=TMIN())&(T<=TMAX()->T+(HMAX()-cool)*(TS()-crl)<=TMAX())|t-tLD<=crl)&crl>=0&crl<=TS()&(t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN()))");
    composeb('R=="[h:=*;?HMAX()>=h&h>=HMIN();][{?crl>=TS();crl:=0.0;cool:=*;?T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN();?T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX();?T>=TMIN()->T+(HMIN()-cool)*TS()>=TMIN();?T<=TMAX()->T+(HMAX()-cool)*TS()<=TMAX();++?crl < TS();}{T:=*;tLD:=t;++?true;}{t'=1.0,crl'=1.0,T'=h-cool&crl<=TS()}](((T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN())&(T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX())&(T>=TMIN()->T+(HMIN()-cool)*(TS()-crl)>=TMIN())&(T<=TMAX()->T+(HMAX()-cool)*(TS()-crl)<=TMAX())|t-tLD<=crl)&crl>=0&crl<=TS()&(t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN()))");
    randomb('R=="[h:=*;][?HMAX()>=h&h>=HMIN();][{?crl>=TS();crl:=0.0;cool:=*;?T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN();?T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX();?T>=TMIN()->T+(HMIN()-cool)*TS()>=TMIN();?T<=TMAX()->T+(HMAX()-cool)*TS()<=TMAX();++?crl < TS();}{T:=*;tLD:=t;++?true;}{t'=1.0,crl'=1.0,T'=h-cool&crl<=TS()}](((T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN())&(T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX())&(T>=TMIN()->T+(HMIN()-cool)*(TS()-crl)>=TMIN())&(T<=TMAX()->T+(HMAX()-cool)*(TS()-crl)<=TMAX())|t-tLD<=crl)&crl>=0&crl<=TS()&(t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN()))");
    allR('R=="\forall h [?HMAX()>=h&h>=HMIN();][{?crl>=TS();crl:=0.0;cool:=*;?T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN();?T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX();?T>=TMIN()->T+(HMIN()-cool)*TS()>=TMIN();?T<=TMAX()->T+(HMAX()-cool)*TS()<=TMAX();++?crl < TS();}{T:=*;tLD:=t;++?true;}{t'=1.0,crl'=1.0,T'=h-cool&crl<=TS()}](((T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN())&(T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX())&(T>=TMIN()->T+(HMIN()-cool)*(TS()-crl)>=TMIN())&(T<=TMAX()->T+(HMAX()-cool)*(TS()-crl)<=TMAX())|t-tLD<=crl)&crl>=0&crl<=TS()&(t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN()))");
    testb('R=="[?HMAX()>=h&h>=HMIN();][{?crl>=TS();crl:=0.0;cool:=*;?T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN();?T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX();?T>=TMIN()->T+(HMIN()-cool)*TS()>=TMIN();?T<=TMAX()->T+(HMAX()-cool)*TS()<=TMAX();++?crl < TS();}{T:=*;tLD:=t;++?true;}{t'=1.0,crl'=1.0,T'=h-cool&crl<=TS()}](((T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN())&(T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX())&(T>=TMIN()->T+(HMIN()-cool)*(TS()-crl)>=TMIN())&(T<=TMAX()->T+(HMAX()-cool)*(TS()-crl)<=TMAX())|t-tLD<=crl)&crl>=0&crl<=TS()&(t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN()))");
    implyR('R=="HMAX()>=h&h>=HMIN()->[{?crl>=TS();crl:=0.0;cool:=*;?T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN();?T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX();?T>=TMIN()->T+(HMIN()-cool)*TS()>=TMIN();?T<=TMAX()->T+(HMAX()-cool)*TS()<=TMAX();++?crl < TS();}{T:=*;tLD:=t;++?true;}{t'=1.0,crl'=1.0,T'=h-cool&crl<=TS()}](((T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN())&(T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX())&(T>=TMIN()->T+(HMIN()-cool)*(TS()-crl)>=TMIN())&(T<=TMAX()->T+(HMAX()-cool)*(TS()-crl)<=TMAX())|t-tLD<=crl)&crl>=0&crl<=TS()&(t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN()))");
    composeb('R=="[{?crl>=TS();crl:=0.0;cool:=*;?T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN();?T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX();?T>=TMIN()->T+(HMIN()-cool)*TS()>=TMIN();?T<=TMAX()->T+(HMAX()-cool)*TS()<=TMAX();++?crl < TS();}{T:=*;tLD:=t;++?true;}{t'=1.0,crl'=1.0,T'=h-cool&crl<=TS()}](((T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN())&(T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX())&(T>=TMIN()->T+(HMIN()-cool)*(TS()-crl)>=TMIN())&(T<=TMAX()->T+(HMAX()-cool)*(TS()-crl)<=TMAX())|t-tLD<=crl)&crl>=0&crl<=TS()&(t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN()))");
    MR("((T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN())&(T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX())&(T>=TMIN()->T+(HMIN()-cool)*(TS()-crl)>=TMIN())&(T<=TMAX()->T+(HMAX()-cool)*(TS()-crl)<=TMAX())|t-tLD<=crl)&crl>=0&crl<=TS()&(t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN())", 'R=="[?crl>=TS();crl:=0.0;cool:=*;?T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN();?T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX();?T>=TMIN()->T+(HMIN()-cool)*TS()>=TMIN();?T<=TMAX()->T+(HMAX()-cool)*TS()<=TMAX();++?crl < TS();][{T:=*;tLD:=t;++?true;}{t'=1.0,crl'=1.0,T'=h-cool&crl<=TS()}](((T < TMIN()->T+(HMIN()-cool)*(tLD+tRECMAX()+-t)>=TMIN())&(T>TMAX()->T+(HMAX()-cool)*(tLD+tRECMAX()+-t)<=TMAX())&(T>=TMIN()->T+(HMIN()-cool)*(TS()-crl)>=TMIN())&(T<=TMAX()->T+(HMAX()-cool)*(TS()-crl)<=TMAX())|t-tLD<=crl)&crl>=0&crl<=TS()&(t-tLD>=tRECMAX()->TMAX()>=T&T>=TMIN()))"); <(
