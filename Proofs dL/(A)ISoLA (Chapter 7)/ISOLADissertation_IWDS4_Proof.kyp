                  "(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)&h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc_0+hMIN()": implyL('L=="a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp") ; <(
                      "a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3": hideR('R=="[{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}](asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL)") ; QE,
                      "cc=ccp": hideL('L=="!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0") ; andL('L=="(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)&h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc_0+hMIN()") ; unfold ; fullSimplify ; orL('L=="asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL") ; <(
                          "asup=supFULL()": fullSimplify ; auto,
                          "h<=hFULL()+(a1+a2+a3+1)*FP()*cRL": cut("i-d<=(a1+a2+a3+1)*FP()") ; <(
                              "Use": hideL('L=="p1=1|p1=0") ; hideL('L=="p2=1|p2=0") ; hideL('L=="p3=1|p3=0") ; hideL('L=="pb=1|pb=0") ; hideL('L=="h<=hB()->pb=1") ; hideL('L=="i=(min(p1,a1)+min(p2,a2)+min(p3,a3)+pb)*FP()") ; hideL('L=="a1=0|a1=1") ; hideL('L=="a2=0|a2=1") ; hideL('L=="a3=0|a3=1") ; hideL('L=="p1p=p1_0") ; hideL('L=="p2p=p2_0") ; hideL('L=="p3p=p3_0") ; hideL('L=="a1=a1p") ; hideL('L=="a2=a2p") ; hideL('L=="a3=a3p") ; hideL('L=="p1=p1p") ; hideL('L=="p2=p2p") ; hideL('L=="p3=p3p") ; hideL('L=="h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc_0+hMIN()") ; allL2R('L=="ccp=cc_0") ; allL2R('L=="cc=cc_0") ; hideL('L=="ccp=cc_0") ; auto,
                              "Show": hideR('R=="[{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}](asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL)") ; hideL('L=="h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc_0+hMIN()") ; hideL('L=="h<=hB()->pb=1") ; hideL('L=="a1=a1p") ; hideL('L=="a2=a2p") ; hideL('L=="a3=a3p") ; hideL('L=="p1=p1p") ; hideL('L=="p2=p2p") ; hideL('L=="p3=p3p") ; hideL('L=="h<=hFULL()+(a1+a2+a3+1)*FP()*cRL") ; hideL('L=="hFULL()>=supFULL()*TS()+hMIN()") ; hideL('L=="hDEG()=supDEG()*TS()+hMIN()") ; hideL('L=="hB()>hMIN()+supFULL()*EPSSIZE()") ; hideL('L=="p1p=p1_0") ; hideL('L=="p2p=p2_0") ; hideL('L=="p3p=p3_0") ; hideL('L=="eps=0") ; hideL('L=="hMIN()>=0") ; allL2R('L=="supDEG()=FP()") ; hideL('L=="supDEG()=FP()") ; hideL('L=="supFULL()=2*FP()") ; hideL('L=="cRL>=0") ; hideL('L=="EPSSIZE()>0") ; hideL('L=="cRL<=TS()") ; hideL('L=="cc_0>=0") ; hideL('L=="d<=asup") ; hideL('L=="hp=h") ; hideL('L=="ccp=cc_0") ; hideL('L=="cc=ccp") ; QE
                            )
                        )
                    ),
                  "!(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)": orL('L=="asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL") ; <(
                      "asup=supFULL()": auto,
                      "h<=hFULL()+(a1+a2+a3+1)*FP()*cRL": cut("i-d<=(a1+a2+a3+1)*FP()") ; <(
                          "Use": hideL('L=="ccp=cc_0") ; hideL('L=="a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp") ; hideL('L=="!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0") ; hideL('L=="i=(min(p1,a1)+min(p2,a2)+min(p3,a3)+pb)*FP()") ; hideL('L=="hp=h") ; hideL('L=="h>hMIN()") ; hideL('L=="!(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)") ; hideL('L=="d>=0") ; hideL('L=="d<=asup") ; hideL('L=="cc_0>=0") ; hideL('L=="cRL<=TS()") ; hideL('L=="EPSSIZE()>0") ; hideL('L=="supFULL()=2*FP()") ; hideL('L=="supDEG()=1*FP()") ; hideL('L=="a1=0|a1=1") ; hideL('L=="a2=0|a2=1") ; hideL('L=="hMIN()>=0") ; hideL('L=="a3=0|a3=1") ; hideL('L=="TS()>=0") ; hideL('L=="asup>=supDEG()") ; hideL('L=="asup<=supFULL()") ; hideL('L=="hB()>hMIN()+supFULL()*EPSSIZE()") ; hideL('L=="p1p=p1_0") ; hideL('L=="p2p=p2_0") ; hideL('L=="p3p=p3_0") ; hideL('L=="eps=0.0") ; hideL('L=="p1=1.0|p1=0.0") ; hideL('L=="p2=1.0|p2=0.0") ; hideL('L=="p3=1.0|p3=0.0") ; hideL('L=="pb=1.0|pb=0.0") ; hideL('L=="h<=hB()->pb=1.0") ; auto,
                          "Show": hideR('R=="[{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}](asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL)") ; hideL('L=="a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp") ; hideL('L=="!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0") ; hideL('L=="!(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)") ; hideL('L=="hFULL()>=supFULL()*TS()+hMIN()") ; hideL('L=="hDEG()=supDEG()*TS()+hMIN()") ; hideL('L=="hB()>hMIN()+supFULL()*EPSSIZE()") ; hideL('L=="p1p=p1_0") ; hideL('L=="p2p=p2_0") ; hideL('L=="p3p=p3_0") ; hideL('L=="eps=0.0") ; hideL('L=="h<=hB()->pb=1.0") ; hideL('L=="TS()>=0") ; hideL('L=="hMIN()>=0") ; allL2R('L=="supDEG()=1*FP()") ; hideL('L=="supDEG()=1*FP()") ; hideL('L=="h<=hFULL()+(a1+a2+a3+1)*FP()*cRL") ; hideL('L=="supFULL()=2*FP()") ; hideL('L=="cRL>=0") ; hideL('L=="EPSSIZE()>0") ; hideL('L=="cRL<=TS()") ; hideL('L=="cc_0>=0") ; hideL('L=="ccp=cc_0") ; QE
                        )
                    )
                ),
              "[{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}](cRL>=0&cRL<=TS()&h>hMIN()&asup>=supDEG()&asup<=supFULL()&(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&cc>=0)": orL('L=="(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)&h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc_0+hMIN()|!(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)") ; <(
                  "(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)&h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc_0+hMIN()": unfold ; hideL('L=="i=(min(p1,a1)+min(p2,a2)+min(p3,a3)+pb)*FP()") ; implyL('L=="a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp") ; <(
                      "a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3": hideR('R=="[{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}](cRL>=0&cRL<=TS()&h>hMIN()&asup>=supDEG()&asup<=supFULL()&(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&cc>=0)") ; QE,
                      "cc=ccp": hideL('L=="!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0") ; hideL('L=="asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL") ; hideL('L=="p1=1.0|p1=0.0") ; hideL('L=="p2=1.0|p2=0.0") ; hideL('L=="p3=1.0|p3=0.0") ; hideL('L=="pb=1.0|pb=0.0") ; hideL('L=="h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc_0+hMIN()") ; auto
                    ),
                  "!(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)": hideL('L=="a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp") ; implyL('L=="!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0") ; <(
                      "!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)": hideR('R=="[{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}](cRL>=0&cRL<=TS()&h>hMIN()&asup>=supDEG()&asup<=supFULL()&(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&cc>=0)") ; QE,
                      "cc=0": hideL('L=="!(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)") ; hideL('L=="p1=1.0|p1=0.0") ; hideL('L=="p2=1.0|p2=0.0") ; hideL('L=="p3=1.0|p3=0.0") ; hideL('L=="pb=1.0|pb=0.0") ; hideL('L=="h<=hB()->pb=1.0") ; auto
                    )
                )
            )
        )
    )
)
End.

End. """"
  tactic """" unfold;
loop("h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc+hMIN()&(asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL)&cRL>=0&cRL<=TS()&h>hMIN()&asup>=supDEG()&asup<=supFULL()&(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&cc>=0", 'R=="[{a1p:=a1;a2p:=a2;a3p:=a3;p1p:=p1;p2p:=p2;p3p:=p3;eps:=0.0;p1:=*;?p1=1.0|p1=0.0;p2:=*;?p2=1.0|p2=0.0;p3:=*;?p3=1.0|p3=0.0;pb:=*;?pb=1.0|pb=0.0;?h<=hB()->pb=1.0;{?cRL>=TS();a1:=*;a2:=*;a3:=*;asup:=*;?h>hFULL()->asup=supFULL();?h>hDEG()&h<=hFULL()->asup>supDEG()&asup < supFULL()&h-asup*TS()>hMIN();?h<=hDEG()->asup=supDEG();?(a1=1|a1=0)&(a2=1|a2=0)&(a3=1|a3=0);cRL:=0.0;++?cRL < TS();}ccp:=cc;cc:=*;?a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp;?!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0;i:=*;?i=(min(p1,a1)+min(p2,a2)+min(p3,a3)+pb)*FP();d:=*;?d>=0&d<=asup;hp:=h;{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}}*](a1=1&a2=1&a3=1&p1=1&p2=1&p3=1&((a1+a2+a3)*FP()-supFULL())*cc>hFULL()+(a1+a2+a3+1)*FP()*TS()->asup=supFULL())"); <(
  "Init":
    auto,
  "Post":
    auto,
  "Step":
    composeb('R=="[a1p:=a1;a2p:=a2;a3p:=a3;p1p:=p1;p2p:=p2;p3p:=p3;eps:=0.0;p1:=*;?p1=1.0|p1=0.0;p2:=*;?p2=1.0|p2=0.0;p3:=*;?p3=1.0|p3=0.0;pb:=*;?pb=1.0|pb=0.0;?h<=hB()->pb=1.0;{?cRL>=TS();a1:=*;a2:=*;a3:=*;asup:=*;?h>hFULL()->asup=supFULL();?h>hDEG()&h<=hFULL()->asup>supDEG()&asup < supFULL()&h-asup*TS()>hMIN();?h<=hDEG()->asup=supDEG();?(a1=1|a1=0)&(a2=1|a2=0)&(a3=1|a3=0);cRL:=0.0;++?cRL < TS();}ccp:=cc;cc:=*;?a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp;?!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0;i:=*;?i=(min(p1,a1)+min(p2,a2)+min(p3,a3)+pb)*FP();d:=*;?d>=0&d<=asup;hp:=h;{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}](h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc+hMIN()&(asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL)&cRL>=0&cRL<=TS()&h>hMIN()&asup>=supDEG()&asup<=supFULL()&(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&cc>=0)");
    assignb('R=="[a1p:=a1;][a2p:=a2;a3p:=a3;p1p:=p1;p2p:=p2;p3p:=p3;eps:=0.0;p1:=*;?p1=1.0|p1=0.0;p2:=*;?p2=1.0|p2=0.0;p3:=*;?p3=1.0|p3=0.0;pb:=*;?pb=1.0|pb=0.0;?h<=hB()->pb=1.0;{?cRL>=TS();a1:=*;a2:=*;a3:=*;asup:=*;?h>hFULL()->asup=supFULL();?h>hDEG()&h<=hFULL()->asup>supDEG()&asup < supFULL()&h-asup*TS()>hMIN();?h<=hDEG()->asup=supDEG();?(a1=1|a1=0)&(a2=1|a2=0)&(a3=1|a3=0);cRL:=0.0;++?cRL < TS();}ccp:=cc;cc:=*;?a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp;?!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0;i:=*;?i=(min(p1,a1)+min(p2,a2)+min(p3,a3)+pb)*FP();d:=*;?d>=0&d<=asup;hp:=h;{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}](h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc+hMIN()&(asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL)&cRL>=0&cRL<=TS()&h>hMIN()&asup>=supDEG()&asup<=supFULL()&(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&cc>=0)");
