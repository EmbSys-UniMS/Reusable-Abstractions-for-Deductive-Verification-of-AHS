                        hideL('L=="p1=1.0|p1=0.0");
                        hideL('L=="p2=1.0|p2=0.0");
                        hideL('L=="p3=1.0|p3=0.0");
                        hideL('L=="pb=1.0|pb=0.0");
                        hideL('L=="h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc_0+hMIN()");
                        auto
                    ),
                  "!(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)":
                    hideL('L=="a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp");
                    implyL('L=="!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0"); <(
                      "!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)":
                        hideR('R=="[{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}](cRL>=0&cRL<=TS()&h>hMIN()&asup>=supDEG()&asup<=supFULL()&(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&cc>=0)");
                        QE,
                      "cc=0":
                        hideL('L=="!(a1=a1p&a2=a2p&a3=a3p&p1=p1p&p2=p2p&p3=p3p)");
                        hideL('L=="p1=1.0|p1=0.0");
                        hideL('L=="p2=1.0|p2=0.0");
                        hideL('L=="p3=1.0|p3=0.0");
                        hideL('L=="pb=1.0|pb=0.0");
                        hideL('L=="h<=hB()->pb=1.0");
                        auto
                    )
                )
            )
        )
    )
) """"
End.

Tool.
  kyxversion """" 5.0 """"
End.
