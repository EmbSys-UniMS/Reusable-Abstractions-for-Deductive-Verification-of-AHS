Lemma "ISOLADissertation/IWDS4 from tactic".
"  ==>  (((t) = ((0.0)))&(((cc) = ((0)))&(((EPSSIZE()) > ((0)))&(((supFULL()) = (((2))*(FP())))&(((supDEG()) = (((1))*(FP())))&(((FP()) >= ((0)))&(((hMIN()) >= ((0)))&(((TS()) >= ((0)))&(((hFULL()) >= (((supFULL())*(TS()))+(hMIN())))&(((hDEG()) >= (((supDEG())*(TS()))+(hMIN())))&(((hB()) > ((hMIN())+((supFULL())*(EPSSIZE()))))&(((h) > (hMIN()))&(((eps) = ((0.0)))&(((cRL) >= ((0)))&(((cRL) <= (TS()))&((((h) > (hFULL()))->((asup) = (supFULL())))&(((h) > (hDEG()))&((h) <= (hFULL())))))))))))))))))))->((((asup) > (supDEG()))&(((asup) < (supFULL()))&((((h)-((asup)*(TS()))) > (hMIN()))&((((h) <= (hDEG()))->((asup) = (supDEG())))&((((a1) = ((1)))|((a1) = ((0))))&((((a2) = ((1)))|((a2) = ((0))))&(((a3) = ((1)))|((a3) = ((0))))))))))->([{{a1p:=a1;};{{a2p:=a2;};{{a3p:=a3;};{{p1p:=p1;};{{p2p:=p2;};{{p3p:=p3;};{{eps:=(0.0);};{{p1:=*;};{{?(((p1) = ((1.0)))|((p1) = ((0.0))));};{{p2:=*;};{{?(((p2) = ((1.0)))|((p2) = ((0.0))));};{{p3:=*;};{{?(((p3) = ((1.0)))|((p3) = ((0.0))));};{{pb:=*;};{{?(((pb) = ((1.0)))|((pb) = ((0.0))));};{{?(((h) <= (hB()))->((pb) = ((1.0))));};{{{{?((cRL) >= (TS()));};{{a1:=*;};{{a2:=*;};{{a3:=*;};{{asup:=*;};{{?(((h) > (hFULL()))->((asup) = (supFULL())));};{{?((((h) > (hDEG()))&((h) <= (hFULL())))->(((asup) > (supDEG()))&(((asup) < (supFULL()))&(((h)-((asup)*(TS()))) > (hMIN())))));};{{?(((h) <= (hDEG()))->((asup) = (supDEG())));};{{?((((a1) = ((1)))|((a1) = ((0))))&((((a2) = ((1)))|((a2) = ((0))))&(((a3) = ((1)))|((a3) = ((0))))));};{cRL:=(0.0);}}}}}}}}}}++{?((cRL) < (TS()));}};{{ccp:=cc;};{{cc:=*;};{{?((((a1p) = (a1))&(((a2p) = (a2))&(((a3p) = (a3))&(((p1p) = (p1))&(((p2p) = (p2))&((p3p) = (p3)))))))->((cc) = (ccp)));};{{?((!(((a1p) = (a1))&(((a2p) = (a2))&(((a3p) = (a3))&(((p1p) = (p1))&(((p2p) = (p2))&((p3p) = (p3))))))))->((cc) = ((0))));};{{i:=*;};{{?((i) = (((((min<< ._1 < ._2&._0=._1|._1>=._2&._0=._2 >>((p1,a1)))+(min<< ._1 < ._2&._0=._1|._1>=._2&._0=._2 >>((p2,a2))))+(min<< ._1 < ._2&._0=._1|._1>=._2&._0=._2 >>((p3,a3))))+(pb))*(FP())));};{{d:=*;};{{?(((d) >= ((0)))&((d) <= (asup)));};{{hp:=h;};{{t'=(1.0),cRL'=(1.0),cc'=(1),h'=(i)-(d),eps'=(1.0)&((((hp) > (hB()))&((h) > (hB())))|((((hp) <= (hB()))&((h) <= (hB())))|((eps) <= (EPSSIZE()))))&(((cRL) <= (TS()))&((h) > (hMIN())))}}}}}}}}}}}}}}}}}}}}}}}}}}}}*]((((a1) = ((1)))&(((a2) = ((1)))&(((a3) = ((1)))&(((p1) = ((1)))&(((p2) = ((1)))&(((p3) = ((1)))&(((((((a1)+(a2))+(a3))*(FP()))-(supFULL()))*(cc)) > ((hFULL())+((((((a1)+(a2))+(a3))+((1)))*(FP()))*(TS()))))))))))->((asup) = (supFULL())))))
\qed::614a8f55933696bada535a98cc0a8f03"
End.
Tool.
  tool """" KeYmaera X """"
  model """" Theorem "ISOLADissertation/IWDS4"

Definitions
  Real EPSSIZE;
  Real hB;
  Real TS;
  Real FP; /* pump rate */
  Real hMIN;
  Real hDEG;
  Real supDEG;
  Real supFULL;
  Real hFULL;
End.

ProgramVariables
  Real t;
  Real p1;
  Real p2;
  Real p3;
  Real pb;
  Real a1;
  Real a2;
  Real a3;
  Real p1p;
  Real p2p;
  Real p3p;
  Real a1p;
  Real a2p;
  Real a3p;
  Real asup;
  Real cRL;
  Real cc; 
  Real ccp;
  Real i;
  Real d;
  Real h;  /* h=water level */
  Real hp;
  Real eps;
End.

Problem
  (t = 0.0)
  & cc=0
  /* assumptions on constants */  
  & EPSSIZE>0
  & supFULL=2*FP 
  & supDEG=1*FP 
  & FP >=0
  & hMIN >=0 
  & TS>=0
  /* water levels */
  & hFULL>=supFULL*TS+hMIN
  & hDEG>=supDEG*TS+hMIN
  & hB>hMIN+supFULL*EPSSIZE
  & h>hMIN
  & eps = 0.0
  /* RL Contract */
  & cRL >=0 
  & cRL<=TS
  /* full service */
  & (h>hFULL->asup=supFULL)
  /* above reserve */
  & (h>hDEG & h<=hFULL)->asup>supDEG & asup<supFULL & h-asup*TS>hMIN /* add as many service levels as you want */
  /* in reserve */
  & (h<=hDEG->asup=supDEG) &
  (a1=1|a1=0)&(a2=1|a2=0)&(a3=1|a3=0)
  ->
  [
    {
        /* Store previous values */
        a1p:=a1; a2p:=a2; a3p:=a3; p1p:=p1; p2p:=p2; p3p:=p3; 
        eps:=0.0;
        /* Pump Failure and Repairs */
        p1:= *;
        ?((p1 = 1.0)
        | (p1 = 0.0));
        p2:= *;
        ?((p2 = 1.0)
        | (p2 = 0.0));
        p3:= *;
        ?((p3 = 1.0) | (p3 = 0.0));
        pb := *;
        ?((pb = 1.0) | (pb = 0.0));
        /* Backup Pump */
        ?(h <= hB -> pb = 1.0);
        {
            ?(cRL >= TS); /* RL contracts */
            a1:= *;
            a2:= *;
            a3:= *;
            asup:= *;
            ?(h>hFULL->asup=supFULL);
            ?(h>hDEG & h<=hFULL)->asup>supDEG & asup<supFULL & h-asup*TS>hMIN; /* add as many service levels as you want */
            ?(h<=hDEG->asup=supDEG);
            ?((a1=1|a1=0)&(a2=1|a2=0)&(a3=1|a3=0));
            cRL:=0.0;
        ++
            ?(cRL < TS);
        }
        ccp:=cc;
        cc:=*; /* on change reset timer cc*/
        ?( (a1p=a1 & a2p=a2 & a3p=a3 & p1p=p1 & p2p=p2 & p3p=p3)->cc=ccp);
        ?((!(a1p=a1 & a2p=a2 & a3p=a3 & p1p=p1 & p2p=p2 & p3p=p3))->cc=0);
        
        i:= *; /* inflow */
        ?(i = (min(p1,a1)+min(p2,a2)+min(p3,a3)+pb)*FP);
        d:= *; /* demand */
        ?((d >= 0) & (d <= asup));
        hp:=h;
        {
            {t' = 1.0, cRL' = 1.0, cc'=1, h' = (i-d), eps' = 1.0 &
            ((hp > hB & h > hB) | (hp <= hB & h <=hB) | eps <= EPSSIZE) & cRL <= TS & h>hMIN} /*simplified continuous evolution. nondeterministic choise replaced by (hp > hB & h > hB) | (hp <= hB & h <=hB) to make the proof easier */
        }
    }*
    
  ] (a1=1&a2=1&a3=1&p1=1&p2=1&p3=1&((a1+a2+a3)*FP-supFULL)*cc>hFULL+(a1+a2+a3+1)*FP*TS->asup=supFULL)
End.

Tactic "FinalWaterDistributionFullServiceALLACTIVE: Proof"
unfold ; loop("h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc+hMIN()&(asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL)&cRL>=0&cRL<=TS()&h>hMIN()&asup>=supDEG()&asup<=supFULL()&(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&cc>=0", 'R=="[{a1p:=a1;a2p:=a2;a3p:=a3;p1p:=p1;p2p:=p2;p3p:=p3;eps:=0.0;p1:=*;?p1=1.0|p1=0.0;p2:=*;?p2=1.0|p2=0.0;p3:=*;?p3=1.0|p3=0.0;pb:=*;?pb=1.0|pb=0.0;?h<=hB()->pb=1.0;{?cRL>=TS();a1:=*;a2:=*;a3:=*;asup:=*;?h>hFULL()->asup=supFULL();?h>hDEG()&h<=hFULL()->asup>supDEG()&asup < supFULL()&h-asup*TS()>hMIN();?h<=hDEG()->asup=supDEG();?(a1=1|a1=0)&(a2=1|a2=0)&(a3=1|a3=0);cRL:=0.0;++?cRL < TS();}ccp:=cc;cc:=*;?a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp;?!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0;i:=*;?i=(min(p1,a1)+min(p2,a2)+min(p3,a3)+pb)*FP();d:=*;?d>=0&d<=asup;hp:=h;{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}}*](a1=1&a2=1&a3=1&p1=1&p2=1&p3=1&((a1+a2+a3)*FP()-supFULL())*cc>hFULL()+(a1+a2+a3+1)*FP()*TS()->asup=supFULL())") ; <(
  "Init": auto,
  "Post": auto,
  "Step": composeb('R=="[a1p:=a1;a2p:=a2;a3p:=a3;p1p:=p1;p2p:=p2;p3p:=p3;eps:=0.0;p1:=*;?p1=1.0|p1=0.0;p2:=*;?p2=1.0|p2=0.0;p3:=*;?p3=1.0|p3=0.0;pb:=*;?pb=1.0|pb=0.0;?h<=hB()->pb=1.0;{?cRL>=TS();a1:=*;a2:=*;a3:=*;asup:=*;?h>hFULL()->asup=supFULL();?h>hDEG()&h<=hFULL()->asup>supDEG()&asup < supFULL()&h-asup*TS()>hMIN();?h<=hDEG()->asup=supDEG();?(a1=1|a1=0)&(a2=1|a2=0)&(a3=1|a3=0);cRL:=0.0;++?cRL < TS();}ccp:=cc;cc:=*;?a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp;?!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0;i:=*;?i=(min(p1,a1)+min(p2,a2)+min(p3,a3)+pb)*FP();d:=*;?d>=0&d<=asup;hp:=h;{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}](h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc+hMIN()&(asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL)&cRL>=0&cRL<=TS()&h>hMIN()&asup>=supDEG()&asup<=supFULL()&(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&cc>=0)") ; assignb('R=="[a1p:=a1;][a2p:=a2;a3p:=a3;p1p:=p1;p2p:=p2;p3p:=p3;eps:=0.0;p1:=*;?p1=1.0|p1=0.0;p2:=*;?p2=1.0|p2=0.0;p3:=*;?p3=1.0|p3=0.0;pb:=*;?pb=1.0|pb=0.0;?h<=hB()->pb=1.0;{?cRL>=TS();a1:=*;a2:=*;a3:=*;asup:=*;?h>hFULL()->asup=supFULL();?h>hDEG()&h<=hFULL()->asup>supDEG()&asup < supFULL()&h-asup*TS()>hMIN();?h<=hDEG()->asup=supDEG();?(a1=1|a1=0)&(a2=1|a2=0)&(a3=1|a3=0);cRL:=0.0;++?cRL < TS();}ccp:=cc;cc:=*;?a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3->cc=ccp;?!(a1p=a1&a2p=a2&a3p=a3&p1p=p1&p2p=p2&p3p=p3)->cc=0;i:=*;?i=(min(p1,a1)+min(p2,a2)+min(p3,a3)+pb)*FP();d:=*;?d>=0&d<=asup;hp:=h;{t'=1.0,cRL'=1.0,cc'=1,h'=i-d,eps'=1.0&(hp>hB()&h>hB()|hp<=hB()&h<=hB()|eps<=EPSSIZE())&cRL<=TS()&h>hMIN()}](h>((min(p1,a1)+min(p2,a2)+min(p3,a3))*FP()-supFULL())*cc+hMIN()&(asup=supFULL()|h<=hFULL()+(a1+a2+a3+1)*FP()*cRL)&cRL>=0&cRL<=TS()&h>hMIN()&asup>=supDEG()&asup<=supFULL()&(a1=0|a1=1)&(a2=0|a2=1)&(a3=0|a3=1)&cc>=0)") ; composeb('R=="[a2p:=a2;a3p:=a3;p1p:=p1;p2p:=p2;p3p:=p3;eps:=0.0;p1:=*;?p1=1.0|p1=0.0;p2:=*;?p2=1.0|p2=0.0;p3:=*;?p3=1.0|p3=0.0;pb:=*;?pb=1.0|pb=0.0;?h<=hB(