  hideL(-1=="(((XCOld-X)^2+(YCOld-Y)^2)^0.5-VRL*(STEPTSRL()-stepClockTSRL)-VMAXC()*(STEPTSRL()-(stepClockTSRL-(simTimeOld-simTimeOldPrev)))>THRESHOLDC()|VRL=0)&(VRL=0<->DirXRL=0&DirYRL=0)&(VRL=0->VXRL=0&VYRL=0)&((XRLOld-X)^2.0+(YRLOld-Y)^2.0)^0.5=VRL*(simTimeOld-simTimeOldPrev)&VRL=(VXRL^2+VYRL^2)^0.5&(((XCOldPrev-XRLOld)^2+(YCOldPrev-YRLOld)^2)^0.5>THRESHOLDC()|XRLOld=XRLOldPrev&YRLOld=YRLOldPrev)&VRL>=0&VMAXRL()>=VRL&STEPTSRL()>=stepClockTSRL&stepClockTSRL>=0&simTimeOld>=simTimeOldPrev&simTimeOldPrev>=0&stepClockTSRL>=simTimeOld-simTimeOldPrev&SMALLSTEPSIZE()=0.01&STEPTSRL()>=0&VMAXRL()>=0&VMAXC()>=0") ; master, 
    discreteGhost("stepClockTSRL", "stepClockTSRLOld", 'R) ; discreteGhost("VRL", "VRLOld", 'R) ; discreteGhost("DirXRL", "DirXRLOld", 'R) ; discreteGhost("DirYRL", "DirYRLOld", 'R) ; discreteGhost("VXRL", "VXRLOld", 'R) ; discreteGhost("VYRL", "VYRLOld", 'R) ; composeb(1) ; MR("(stepClockTSRLOld>=STEPTSRL()->(VRL>=0.0&VMAXRL()>=VRL&(VRL=0.0<->DirXRL=0.0&DirYRL=0.0)&((DiffXC^2.0+DiffYC^2.0)^0.5-VRL*STEPTSRL()-VMAXC()*STEPTSRL()>THRESHOLDC()|VRL=0.0))&stepClockTSRL=0)&(stepClockTSRLOld < STEPTSRL()->stepClockTSRL=stepClockTSRLOld&VRL=VRLOld&DirXRL=DirXRLOld&DirYRL=DirYRLOld)", 1) ; <(
    hideL(-1=="(((XCOld-X)^2+(YCOld-Y)^2)^0.5-VRLOld*(STEPTSRL()-stepClockTSRLOld)-VMAXC()*(STEPTSRL()-(stepClockTSRLOld-(simTimeOld-simTimeOldPrev)))>THRESHOLDC()|VRLOld=0)&(VRLOld=0<->DirXRLOld=0&DirYRLOld=0)&(VRLOld=0->VXRLOld=0&VYRLOld=0)&((XRLOld-X)^2.0+(YRLOld-Y)^2.0)^0.5=VRLOld*(simTimeOld-simTimeOldPrev)&VRLOld=(VXRLOld^2+VYRLOld^2)^0.5&(((XCOldPrev-XRLOld)^2+(YCOldPrev-YRLOld)^2)^0.5>THRESHOLDC()|XRLOld=XRLOldPrev&YRLOld=YRLOldPrev)&VRLOld>=0&VMAXRL()>=VRLOld&STEPTSRL()>=stepClockTSRLOld&stepClockTSRLOld>=0&simTimeOld>=simTimeOldPrev&simTimeOldPrev>=0&stepClockTSRLOld>=simTimeOld-simTimeOldPrev&SMALLSTEPSIZE()=0.01&STEPTSRL()>=0&VMAXRL()>=0&VMAXC()>=0&simTimeOld=simTime&XRL=X&YRL=Y&((XC-XCOld)^2+(YC-YCOld)^2)^0.5<=VMAXC()*(simTimeOld-simTimeOldPrev)") ; master, 
      composeb(1) ; MR("(VXRL^2+VYRL^2)^0.5=VRL&(VRL=0->VXRL=0&VYRL=0)", 1) ; <(
      unfold ; hideL(-3=="((XCOld-X)^2+(YCOld-Y)^2)^0.5-VRLOld*(STEPTSRL()-stepClockTSRLOld)-VMAXC()*(STEPTSRL()-(stepClockTSRLOld-(simTimeOld-simTimeOldPrev)))>THRESHOLDC()|VRLOld=0") ; hideL(-5=="((XRLOld-X)^2.0+(YRLOld-Y)^2.0)^0.5=VRLOld*(simTimeOld-simTimeOldPrev)") ; hideL(-6=="((XCOldPrev-XRLOld)^2+(YCOldPrev-YRLOld)^2)^0.5>THRESHOLDC()|XRLOld=XRLOldPrev&YRLOld=YRLOldPrev") ; hideL(-9=="stepClockTSRLOld>=0") ; hideL(-9=="simTimeOld>=simTimeOldPrev") ; hideL(-9=="simTimeOldPrev>=0") ; hideL(-9=="stepClockTSRLOld>=simTimeOld-simTimeOldPrev") ; hideL(-9=="SMALLSTEPSIZE()=0.01") ; hideL(-12=="simTimeOld=simTime") ; hideL(-14=="((XC-XCOld)^2+(YC-YCOld)^2)^0.5<=VMAXC()*(simTimeOld-simTimeOldPrev)") ; hideL(-14=="DiffXC=XC-X") ; hideL(-14=="DiffYC=YC-Y") ; hideL(-12=="XRL=X") ; hideL(-12=="YRL=Y") ; cut("stepClockTSRLOld>=STEPTSRL()|stepClockTSRLOld < STEPTSRL()") ; <(
        orL(-16) ; <(
          hideL(-15=="stepClockTSRLOld < STEPTSRL()->stepClockTSRL=stepClockTSRLOld&VRL=VRLOld&DirXRL=DirXRLOld&DirYRL=DirYRLOld") ; implyL(-14) ; <(
