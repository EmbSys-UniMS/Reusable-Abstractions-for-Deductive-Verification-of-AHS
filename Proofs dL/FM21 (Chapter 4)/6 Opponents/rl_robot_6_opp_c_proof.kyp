Lemma "RL Robot 6 Opp C: Proof".
"  ==>  (((simTime) = ((0.0)))&(((SMALLSTEPSIZE()) = ((0.01)))&(((YRL) = (Y))&(((XRL) = (X))&(((stepClockTSRL) = ((0.0)))&(((smallStep) = ((0.0)))&((((STEPTSRL()) >= ((0)))&(((VMAXRL()) >= ((0)))&(((VMAXC()) >= ((0)))&((((((XC)-(XCOld))^((2)))+(((YC)-(YCOld))^((2))))^((0.5))) <= ((VMAXC())*(TDiff))))))&(((YRLOld) = (YRL))&(((XRLOld) = (XRL))&(((simTimeOld) = (simTime))&(((TDiff) = ((simTime)-(simTimeOld)))&(((((VRL) >= ((0.0)))&(((DirXRL) != ((0.0)))|((DirYRL) != ((0.0)))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = (VRL)))&(((((DirXRL) = ((0.0)))&((DirYRL) = ((0.0))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = ((0.0))))&(((true)->(((DiffXC) = ((XC)-(X)))&((DiffYC) = ((YC)-(Y)))))&((true)->(((VRL) >= ((0.0)))&(((VMAXRL()) >= (VRL))&((((VRL) = ((0.0)))<->(((DirXRL) = ((0.0)))&((DirYRL) = ((0.0)))))&(((((((((DiffXA)^((2.0)))+((DiffYA)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXA())*(STEPTSRL()))) > (THRESHOLDA()))|((VRL) = ((0.0))))&(((((((((DiffXB)^((2.0)))+((DiffYB)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXB())*(STEPTSRL()))) > (THRESHOLDB()))|((VRL) = ((0.0))))&(((((((((DiffXC)^((2.0)))+((DiffYC)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXC())*(STEPTSRL()))) > (THRESHOLDC()))|((VRL) = ((0.0))))&(((((((((DiffXD)^((2.0)))+((DiffYD)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXD())*(STEPTSRL()))) > (THRESHOLDD()))|((VRL) = ((0.0))))&(((((((((DiffXE)^((2.0)))+((DiffYE)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXE())*(STEPTSRL()))) > (THRESHOLDE()))|((VRL) = ((0.0))))&((((((((DiffXF)^((2.0)))+((DiffYF)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXF())*(STEPTSRL()))) > (THRESHOLDF()))|((VRL) = ((0.0)))))))))))))))))))))))))))->([{{{smallStep:=(0.0);};{{TDiff:=(simTime)-(simTimeOld);};{{simTimeOld:=simTime;};{{YA:=*;};{{XA:=*;};{{YB:=*;};{{XB:=*;};{{XCOld:=XC;};{{YCOld:=YC;};{{YC:=*;};{{XC:=*;};{{?((((((XC)-(XCOld))^((2)))+(((YC)-(YCOld))^((2))))^((0.5))) <= ((VMAXC())*(TDiff)));};{{YD:=*;};{{XD:=*;};{{YE:=*;};{{XE:=*;};{{YF:=*;};{{FX:=*;};{{YRLOld:=YRL;};{{XRLOld:=XRL;};{{YRL:=Y;};{XRL:=X;}}}}}}}}}}}}}}}}}}}}}};{{{DiffXA:=*;};{{DiffYA:=*;};{{DirXA:=*;};{{DirYA:=*;};{{DiffXB:=*;};{{DiffYB:=*;};{{DirXB:=*;};{{DirYB:=*;};{{DiffXC:=*;};{{DiffYC:=*;};{{DirXC:=*;};{{DirYC:=*;};{{DiffXD:=*;};{{DiffYD:=*;};{{DirXD:=*;};{{DirYD:=*;};{{DiffXE:=*;};{{DiffYE:=*;};{{DirXE:=*;};{{DirYE:=*;};{{DiffXF:=*;};{{DiffYF:=*;};{{DirXF:=*;};{{DirYF:=*;};{{?((true)->(((DiffXA) = ((XA)-(X)))&((DiffYA) = ((YA)-(Y)))));};{{?((true)->(((DiffXB) = ((XB)-(X)))&((DiffYB) = ((YB)-(Y)))));};{{?((true)->(((DiffXC) = ((XC)-(X)))&((DiffYC) = ((YC)-(Y)))));};{{?((true)->(((DiffXD) = ((XD)-(X)))&((DiffYD) = ((YD)-(Y)))));};{{?((true)->(((DiffXE) = ((XE)-(X)))&((DiffYE) = ((YE)-(Y)))));};{?((true)->(((DiffXF) = ((FX)-(X)))&((DiffYF) = ((YF)-(Y)))));}}}}}}}}}}}}}}}}}}}}}}}}}}}}}};{{{{?((stepClockTSRL) >= (STEPTSRL()));};{{stepClockTSRL:=(0.0);};{{DirXRL:=*;};{{DirYRL:=*;};{{VRL:=*;};{?((true)->(((VRL) >= ((0.0)))&(((VMAXRL()) >= (VRL))&((((VRL) = ((0.0)))<->(((DirXRL) = ((0.0)))&((DirYRL) = ((0.0)))))&(((((((((DiffXA)^((2.0)))+((DiffYA)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXA())*(STEPTSRL()))) > (THRESHOLDA()))|((VRL) = ((0.0))))&(((((((((DiffXB)^((2.0)))+((DiffYB)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXB())*(STEPTSRL()))) > (THRESHOLDB()))|((VRL) = ((0.0))))&(((((((((DiffXC)^((2.0)))+((DiffYC)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXC())*(STEPTSRL()))) > (THRESHOLDC()))|((VRL) = ((0.0))))&(((((((((DiffXD)^((2.0)))+((DiffYD)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXD())*(STEPTSRL()))) > (THRESHOLDD()))|((VRL) = ((0.0))))&(((((((((DiffXE)^((2.0)))+((DiffYE)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXE())*(STEPTSRL()))) > (THRESHOLDE()))|((VRL) = ((0.0))))&((((((((DiffXF)^((2.0)))+((DiffYF)^((2.0))))^((0.5)))-((VRL)*(STEPTSRL())))-((VMAXF())*(STEPTSRL()))) > (THRESHOLDF()))|((VRL) = ((0.0)))))))))))));}}}}}}++{?((stepClockTSRL) < (STEPTSRL()));}};{{{VXRL:=*;};{{VYRL:=*;};{{?((((VRL) >= ((0.0)))&(((DirXRL) != ((0.0)))|((DirYRL) != ((0.0)))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = (VRL)));};{?((((DirXRL) = ((0.0)))&((DirYRL) = ((0.0))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = ((0.0))));}}}};{{?(true);};{{simTime'=(1.0),stepClockTSRL'=(1.0),X'=VXRL,Y'=VYRL,smallStep'=(1.0)&(true)&((stepClockTSRL) <= (STEPTSRL()))}}}}}}}*](((((((XCOld)-(XRL))^((2)))+(((YCOld)-(YRL))^((2))))^((0.5))) > (THRESHOLDC()))|(((XRL) = (XRLOld))&((YRL) = (YRLOld)))))
\qed::c3b1dd5d3042d33de4c8b290c12588d7"
End.
Tool.
  tool """"KeYmaera X""""
  model """"ArchiveEntry "RL Robot 6 Opp C"

Functions.
  R SMALLSTEPSIZE.
  R THRESHOLDRL.
  R VMAXRL.
  R STEPTSRL.
  R VMAXA.
  R VMAXB.
  R VMAXC.
  R VMAXD.
  R VMAXE.
  R VMAXF.
  R THRESHOLDA.
  R THRESHOLDB.
  R THRESHOLDC.
  R THRESHOLDD.
  R THRESHOLDE.
  R THRESHOLDF.
End.

ProgramVariables.
  R simTime.
  R XB.
  R YB.
  R GoalX.
  R GoalY.
  R XA.
  R YA.
  R XC.
  R YC.
  R XD.
  R YD.
  R XE.
  R YE.
  R FX.
  R YF.
  R YRL.
  R XRL.
  R DistToGoal.
  R ArrivedAtGoal.
  R Arrived.
  R Crash.
  R DiffXA.
  R DiffYA.
  R DirXA.
  R DirYA.
  R DiffXB.
  R DiffYB.
  R DirXB.
  R DirYB.
  R DiffXC.
  R DiffYC.
  R DirXC.
  R DirYC.
  R DiffXD.
  R DiffYD.
  R DirXD.
  R DirYD.
  R DiffXE.
  R DiffYE.
  R DirXE.
  R DirYE.
  R DiffXF.
  R DiffYF.
  R DirXF.
  R DirYF.
  R Reward.
  R DirXRL.
  R DirYRL.
  R VRL.
  R stepClockTSRL.
  R VXRL.
  R VYRL.
  R X.
  R Y.
  R smallStep.
  R simTimeOld.
  R TDiff.
  R XRLOld.
  R YRLOld.
  R XCOld.
  R YCOld.
End.

Problem.
(simTime = 0.0) &
  (SMALLSTEPSIZE = 0.01) &
  (YRL = Y) &
  (XRL = X) &
  (stepClockTSRL = 0.0) &
  (smallStep = 0.0)&
  /*contract assumptions*/
  ((STEPTSRL>=0)&
    (VMAXRL>=0)&
    (VMAXC>=0)&
    (((XC-XCOld)^2+(YC-YCOld)^2)^0.5<=VMAXC*TDiff))&
  /*init ghost observers*/
  (YRLOld = YRL)&
  (XRLOld = XRL)&
  (simTimeOld=simTime)&
  (TDiff=simTime-simTimeOld)&
  /*contracts moved to init conditions*/
  ((VRL >= 0.0) &
    ((DirXRL != 0.0) |
      (DirYRL != 0.0))
  ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = VRL)))&
  ((DirXRL = 0.0) &
    (DirYRL = 0.0)
  ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = 0.0)))&
  ((true)->((DiffXC = (XC-X)) &(DiffYC = (YC-Y))))&
((true)
    ->((VRL >= 0.0) &
      (VMAXRL >= VRL) &
      (VRL = 0.0
        <->(DirXRL = 0.0) &
          (DirYRL = 0.0)) &
      ((((((DiffXA^2.0)+(DiffYA^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXA*STEPTSRL)) > THRESHOLDA) |
        (VRL = 0.0)) &
      ((((((DiffXB^2.0)+(DiffYB^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXB*STEPTSRL)) > THRESHOLDB) |
        (VRL = 0.0)) &
      ((((((DiffXC^2.0)+(DiffYC^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXC*STEPTSRL)) > THRESHOLDC) |
        (VRL = 0.0)) &
      ((((((DiffXD^2.0)+(DiffYD^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXD*STEPTSRL)) > THRESHOLDD) |
        (VRL = 0.0)) &
      ((((((DiffXE^2.0)+(DiffYE^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXE*STEPTSRL)) > THRESHOLDE) |
        (VRL = 0.0)) &
      ((((((DiffXF^2.0)+(DiffYF^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXF*STEPTSRL)) > THRESHOLDF) |
        (VRL = 0.0))))
->([
    {
      {
        smallStep:=0.0;
        TDiff:=simTime-simTimeOld;
        simTimeOld:=simTime;
        YA:= *;
        XA:= *;
        YB:= *;
        XB:= *;
        XCOld := XC;
        YCOld := YC;
        YC:= *;
        XC:= *;
        ?(((XC-XCOld)^2+(YC-YCOld)^2)^0.5<=VMAXC*TDiff);
        YD:= *;
        XD:= *;
        YE:= *;
        XE:= *;
        YF:= *;
        FX:= *;
        YRLOld := YRL;
        XRLOld := XRL;
        YRL:=Y;
        XRL:=X;
      }
      {
        DiffXA:= *;
        DiffYA:= *;
        DirXA:= *;
        DirYA:= *;
        DiffXB:= *;
        DiffYB:= *;
        DirXB:= *;
        DirYB:= *;
        DiffXC:= *;
        DiffYC:= *;
        DirXC:= *;
        DirYC:= *;
        DiffXD:= *;
        DiffYD:= *;
        DirXD:= *;
        DirYD:= *;
        DiffXE:= *;
        DiffYE:= *;
        DirXE:= *;
        DirYE:= *;
        DiffXF:= *;
        DiffYF:= *;
        DirXF:= *;
        DirYF:= *;
        ?((true)
          ->((DiffXA = (XA-X)) &
            (DiffYA = (YA-Y))));
        ?((true)
          ->((DiffXB = (XB-X)) &
            (DiffYB = (YB-Y))));
        ?((true)
          ->((DiffXC = (XC-X)) &
            (DiffYC = (YC-Y))));
        ?((true)
          ->((DiffXD = (XD-X)) &
            (DiffYD = (YD-Y))));
        ?((true)
          ->((DiffXE = (XE-X)) &
            (DiffYE = (YE-Y))));
        ?((true)
          ->((DiffXF = (FX-X)) &
            (DiffYF = (YF-Y))));
      }
      {
        ?(stepClockTSRL >= STEPTSRL);
        stepClockTSRL:=0.0;
        {
          DirXRL:= *;
          DirYRL:= *;
          VRL:= *;
          ?((true)
            ->((VRL >= 0.0) &
              (VMAXRL >= VRL) &
              (VRL = 0.0
                <->(DirXRL = 0.0) &
                  (DirYRL = 0.0)) &
              ((((((DiffXA^2.0)+(DiffYA^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXA*STEPTSRL)) > THRESHOLDA) |
                (VRL = 0.0)) &
              ((((((DiffXB^2.0)+(DiffYB^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXB*STEPTSRL)) > THRESHOLDB) |
                (VRL = 0.0)) &
              ((((((DiffXC^2.0)+(DiffYC^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXC*STEPTSRL)) > THRESHOLDC) |
                (VRL = 0.0)) &
              ((((((DiffXD^2.0)+(DiffYD^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXD*STEPTSRL)) > THRESHOLDD) |
                (VRL = 0.0)) &
              ((((((DiffXE^2.0)+(DiffYE^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXE*STEPTSRL)) > THRESHOLDE) |
                (VRL = 0.0)) &
              ((((((DiffXF^2.0)+(DiffYF^2.0))^0.5)-(VRL*STEPTSRL)-(VMAXF*STEPTSRL)) > THRESHOLDF) |
                (VRL = 0.0))));
        }
      ++
        ?(stepClockTSRL < STEPTSRL);
      }
      {
        VXRL:= *;
        VYRL:= *;
        ?((VRL >= 0.0) &
            ((DirXRL != 0.0) |
              (DirYRL != 0.0))
          ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = VRL)));
        ?((DirXRL = 0.0) &
            (DirYRL = 0.0)
          ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = 0.0)));
      }
      {
        ?((true));
        {
          simTime' = 1.0,
          stepClockTSRL' = 1.0,
          X' = VXRL,
          Y' = VYRL,
          smallStep' = 1.0
        &((true)) &
          (stepClockTSRL <= STEPTSRL)
        }
      }
    }*
    /* The robot either maintains a distance > THRESHOLD to the old position of the opponent or stopps */
  ] ((((XCOld-XRL)^2+(YCOld-YRL)^2)^0.5>THRESHOLDC)|(XRL=XRLOld&YRL=YRLOld)))
End.
End.""""
  tactic """"unfold ; ((loop("(((XC-X)^2+(YC-Y)^2)^0.5-VRL*(STEPTSRL()-stepClockTSRL)-VMAXC()*(STEPTSRL()-(stepClockTSRL-(simTime-simTimeOld)))>THRESHOLDC()|VRL=0)&(VRL=0<->DirXRL=0&DirYRL=0)&(VRL=0->VXRL=0&VYRL=0)&((XRL-X)^2.0+(YRL-Y)^2.0)^0.5=VRL*(simTime-simTimeOld)&VRL=(VXRL^2+VYRL^2)^0.5&(((XCOld-XRL)^2+(YCOld-YRL)^2)^0.5>THRESHOLDC()|XRL=XRLOld&YRL=YRLOld)&(VRL>=0&VMAXRL()>=VRL)&STEPTSRL()>=stepClockTSRL&stepClockTSRL>=0&simTime>=simTimeOld&simTimeOld>=0&stepClockTSRL>=simTime-simTimeOld", 1) ; <(
nil, 
master, 
discreteGhost("simTimeOld", "simTimeOldPrev", 'R) ; discreteGhost("XCOld", "XCOldPrev", 'R) ; discreteGhost("YCOld", "YCOldPrev", 'R) ; discreteGhost("XRLOld", "XRLOldPrev", 'R) ; discreteGhost("YRLOld", "YRLOldPrev", 'R) ; discreteGhost("XC", "XCPrev", 'R) ; discreteGhost("YC", "YCPrev", 'R) ; discreteGhost("XRL", "XRLPrev", 'R) ; discreteGhost("YRL", "YRLPrev", 'R) ; composeb(1) ; MR("simTimeOld=simTime&XCOld=XCPrev&YCOld=YCPrev&XRLOld=XRLPrev&YRLOld=YRLPrev&XRL=X&YRL=Y&((XC-XCOld)^2+(YC-YCOld)^2)^0.5<=VMAXC()*(simTimeOld-simTimeOldPrev)", 1) ; <(
master, 
