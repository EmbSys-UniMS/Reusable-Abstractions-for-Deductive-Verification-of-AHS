        )
      ), 
      master
    )
  ), 
  andR(1) ; <(
  master, 
    andR(1) ; <(
    hideL(-3=="true->VRL>=0.0&(VRL=0.0<->DirXRL=0.0&DirYRL=0.0)&((DiffXA^2.0+DiffYA^2.0)^0.5/noiseMAX()-VRL*STEPTSRL()-MAXVELOA()*STEPTSRL()>THRESHOLDA()|VRL=0.0)") ; hideL(-3=="DMAX()>=0.0&noiseMIN()>=0.0&noiseMAX()>=noiseMIN()->noiseA>=noiseMIN()&noiseA<=noiseMAX()&(((XA-X)^2.0+(YA-Y)^2.0)^0.5*noiseA<=DMAX()->(DiffXA^2.0+DiffYA^2.0)^0.5=((XA-X)^2.0+(YA-Y)^2.0)^0.5*noiseA)&(((XA-X)^2.0+(YA-Y)^2.0)^0.5*noiseA>DMAX()->(DiffXA^2.0+DiffYA^2.0)^0.5=DMAX())") ; hideL(-7=="((XA-XAOld)^2+(YA-YAOld)^2)^0.5<=MAXVELOA()*(0.0-0.0)") ; master, 
      andR(1) ; <(
      master, 
        andR(1) ; <(
        trueImply(-3) ; hideL(-4=="DMAX()>=0.0&noiseMIN()>=0.0&noiseMAX()>=noiseMIN()->noiseA>=noiseMIN()&noiseA<=noiseMAX()&(((XA-X)^2.0+(YA-Y)^2.0)^0.5*noiseA<=DMAX()->(DiffXA^2.0+DiffYA^2.0)^0.5=((XA-X)^2.0+(YA-Y)^2.0)^0.5*noiseA)&(((XA-X)^2.0+(YA-Y)^2.0)^0.5*noiseA>DMAX()->(DiffXA^2.0+DiffYA^2.0)^0.5=DMAX())") ; hideL(-8=="((XA-XAOld)^2+(YA-YAOld)^2)^0.5<=MAXVELOA()*(0.0-0.0)") ; unfold ; hideL(-12=="(DiffXA^2.0+DiffYA^2.0)^0.5/noiseMAX()-VRL*STEPTSRL()-MAXVELOA()*STEPTSRL()>THRESHOLDA()|VRL=0.0") ; master, 
