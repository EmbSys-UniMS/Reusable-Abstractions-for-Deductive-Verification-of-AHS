Lemma "RL Robot Disturbance A: Proof".
"  ==>  (((simTime) = ((0.0)))&(((SMALLSTEPSIZE()) = ((0.01)))&(((YRL) = (Y))&(((XRL) = (X))&(((stepClockTSRL) = ((0.0)))&(((smallStep) = ((0.0)))&((((STEPTSRL()) >= ((0)))&(((UNUSED()) >= ((0)))&(((MAXVELOA()) >= ((0)))&(((DMAX()) >= ((0)))&(((((((XA)-(XAOld))^((2)))+(((YA)-(YAOld))^((2))))^((0.5))) <= ((MAXVELOA())*(TDiff)))&(((noiseMIN()) >= ((0)))&(((noiseMAX()) >= (noiseMIN()))&((noiseMAX()) >= ((1))))))))))&(((YRLOld) = (YRL))&(((XRLOld) = (XRL))&(((simTimeOld) = (simTime))&(((TDiff) = ((simTime)-(simTimeOld)))&(((((VRL) >= ((0.0)))&(((DirXRL) != ((0.0)))|((DirYRL) != ((0.0)))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = (VRL)))&(((((DirXRL) = ((0.0)))&((DirYRL) = ((0.0))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = ((0.0))))&(((true)->(((VRL) >= ((0.0)))&((((VRL) = ((0.0)))<->(((DirXRL) = ((0.0)))&((DirYRL) = ((0.0)))))&(((((((((DiffXA)^((2.0)))+((DiffYA)^((2.0))))^((0.5)))/(noiseMAX()))-((VRL)*(STEPTSRL())))-((MAXVELOA())*(STEPTSRL()))) > (THRESHOLDA()))|((VRL) = ((0.0)))))))&((((DMAX()) >= ((0.0)))&(((noiseMIN()) >= ((0.0)))&((noiseMAX()) >= (noiseMIN()))))->(((noiseA) >= (noiseMIN()))&(((noiseA) <= (noiseMAX()))&(((((((((XA)-(X))^((2.0)))+(((YA)-(Y))^((2.0))))^((0.5)))*(noiseA)) <= (DMAX()))->(((((DiffXA)^((2.0)))+((DiffYA)^((2.0))))^((0.5))) = ((((((XA)-(X))^((2.0)))+(((YA)-(Y))^((2.0))))^((0.5)))*(noiseA))))&((((((((XA)-(X))^((2.0)))+(((YA)-(Y))^((2.0))))^((0.5)))*(noiseA)) > (DMAX()))->(((((DiffXA)^((2.0)))+((DiffYA)^((2.0))))^((0.5))) = (DMAX())))))))))))))))))))))->([{{{smallStep:=(0.0);};{{TDiff:=(simTime)-(simTimeOld);};{{simTimeOld:=simTime;};{{YAOld:=YA;};{{XAOld:=XA;};{{YA:=*;};{{XA:=*;};{{?((((((XA)-(XAOld))^((2)))+(((YA)-(YAOld))^((2))))^((0.5))) <= ((MAXVELOA())*(TDiff)));};{{BY:=*;};{{BX:=*;};{{YRLOld:=YRL;};{{XRLOld:=XRL;};{{YRL:=Y;};{XRL:=X;}}}}}}}}}}}}}};{{{noiseA:=*;};{{noiseB:=*;};{{DiffXA:=*;};{{DiffYA:=*;};{{DirXA:=*;};{{DirYA:=*;};{{DiffXB:=*;};{{DiffYB:=*;};{{DirXB:=*;};{{DirYB:=*;};{{?((((DMAX()) >= ((0.0)))&(((noiseMIN()) >= ((0.0)))&((noiseMAX()) >= (noiseMIN()))))->(((noiseA) >= (noiseMIN()))&(((noiseA) <= (noiseMAX()))&(((((((((XA)-(X))^((2.0)))+(((YA)-(Y))^((2.0))))^((0.5)))*(noiseA)) <= (DMAX()))->(((((DiffXA)^((2.0)))+((DiffYA)^((2.0))))^((0.5))) = ((((((XA)-(X))^((2.0)))+(((YA)-(Y))^((2.0))))^((0.5)))*(noiseA))))&((((((((XA)-(X))^((2.0)))+(((YA)-(Y))^((2.0))))^((0.5)))*(noiseA)) > (DMAX()))->(((((DiffXA)^((2.0)))+((DiffYA)^((2.0))))^((0.5))) = (DMAX())))))));};{?((((DMAX()) >= ((0.0)))&(((noiseMIN()) >= ((0.0)))&((noiseMAX()) >= (noiseMIN()))))->(((noiseB) >= (noiseMIN()))&(((noiseB) <= (noiseMAX()))&(((((((((BX)-(X))^((2.0)))+(((BY)-(Y))^((2.0))))^((0.5)))*(noiseB)) <= (DMAX()))->(((((DiffXB)^((2.0)))+((DiffYB)^((2.0))))^((0.5))) = ((((((BX)-(X))^((2.0)))+(((BY)-(Y))^((2.0))))^((0.5)))*(noiseB))))&((((((((BX)-(X))^((2.0)))+(((BY)-(Y))^((2.0))))^((0.5)))*(noiseB)) > (DMAX()))->(((((DiffXB)^((2.0)))+((DiffYB)^((2.0))))^((0.5))) = (DMAX())))))));}}}}}}}}}}}};{{{{?((stepClockTSRL) >= (STEPTSRL()));};{{stepClockTSRL:=(0.0);};{{DirXRL:=*;};{{DirYRL:=*;};{{VRL:=*;};{?((true)->(((VRL) >= ((0.0)))&((((VRL) = ((0.0)))<->(((DirXRL) = ((0.0)))&((DirYRL) = ((0.0)))))&((((((((((DiffXA)^((2.0)))+((DiffYA)^((2.0))))^((0.5)))/(noiseMAX()))-((VRL)*(STEPTSRL())))-((MAXVELOA())*(STEPTSRL()))) > (THRESHOLDA()))|((VRL) = ((0.0))))&(((((((((DiffXB)^((2.0)))+((DiffYB)^((2.0))))^((0.5)))/(noiseMAX()))-((VRL)*(STEPTSRL())))-((MAXVELOB())*(STEPTSRL()))) > (THRESHOLDB()))|((VRL) = ((0.0))))))));}}}}}}++{?((stepClockTSRL) < (STEPTSRL()));}};{{{VXRL:=*;};{{VYRL:=*;};{{?((((VRL) >= ((0.0)))&(((DirXRL) != ((0.0)))|((DirYRL) != ((0.0)))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = (VRL)));};{?((((DirXRL) = ((0.0)))&((DirYRL) = ((0.0))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = ((0.0))));}}}};{{?(true);};{{simTime'=(1.0),stepClockTSRL'=(1.0),X'=VXRL,Y'=VYRL,smallStep'=(1.0)&(true)&((stepClockTSRL) <= (STEPTSRL()))}}}}}}}*](((((((XAOld)-(XRL))^((2)))+(((YAOld)-(YRL))^((2))))^((0.5))) > (THRESHOLDA()))|(((XRL) = (XRLOld))&((YRL) = (YRLOld)))))
\qed::3da69937ba51aee91c6097bae1e0328f"
End.
Tool.
  tool """"KeYmaera X""""
  model """"ArchiveEntry "RL Robot Disturbance A"

Functions.
  R SMALLSTEPSIZE.
  R BXUPPERLIMIT.
  R BXLOWERLIMIT.
  R BYUPPERLIMIT.
  R BYLOWERLIMIT.
  R XGoalUPPERLIMIT.
  R XGoalLOWERLIMIT.
  R YGoalUPPERLIMIT.
  R YGoalLOWERLIMIT.
  R XAUPPERLIMIT.
  R XALOWERLIMIT.
  R YAUPPERLIMIT.
  R YALOWERLIMIT.
  R DMAX.
  R noiseMIN.
  R noiseMAX.
  R UNUSED.
  R MAXVELOA.
  R MAXVELOB.
  R THRESHOLDA.
  R THRESHOLDB.
  R STEPTSRL.
End.

ProgramVariables.
  R simTime.
  R simTimeOld.
  R TDiff.
  R BX.
  R BY.
  R XAOld.
  R YAOld.
  R XGoal.
  R YGoal.
  R XA.
  R YA.
  R YRL.
  R XRL.
  R XRLOld.
  R YRLOld.
  R DistToGoal.
  R ArrivedAtGoal.
  R Arrived.
  R Crash.
  R Reward.
  R noiseA.
  R noiseB.
  R DiffXA.
  R DiffYA.
  R DirXA.
  R DirYA.
  R DiffXB.
  R DiffYB.
  R DirXB.
  R DirYB.
  R DirXRL.
  R DirYRL.
  R VRL.
  R stepClockTSRL.
  R VXRL.
  R VYRL.
  R X.
  R Y.
  R smallStep.
End.

Problem.
(
   simTime = 0.0) &
  (SMALLSTEPSIZE = 0.01) &
  (YRL = Y) &
  (XRL = X) &
  (stepClockTSRL = 0.0) &
  (smallStep = 0.0)&
  /*contract assumptions*/
  ((STEPTSRL>=0)&
  /*MAXVELORL was not needed and is thus removed -> replaced by UNUSED*/
  (UNUSED>=0)&
  (MAXVELOA>=0)&
  (DMAX>=0) &
  (((XA-XAOld)^2+(YA-YAOld)^2)^0.5<=MAXVELOA*TDiff) &
  (noiseMIN >= 0) &
  (noiseMAX >= noiseMIN) &
  (noiseMAX >=1)) &
  /*init ghost observers*/
  (YRLOld = YRL)&
  (XRLOld = XRL)&
  (simTimeOld=simTime)&
  (TDiff=simTime-simTimeOld)&
  /*contracts moved to init conditions*/
  ((VRL >= 0.0) &((
  DirXRL != 0.0) | (DirYRL != 0.0))
  ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = VRL)))&
  ((DirXRL = 0.0) &(DirYRL = 0.0)
  ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = 0.0)))&
  /*RL Controller contract*/
  ((true)
    ->((VRL >= 0.0) &
      (VRL = 0.0
        <->(DirXRL = 0.0) & (DirYRL = 0.0)) &
      ((((((DiffXA^2.0)+(DiffYA^2.0))^0.5)/noiseMAX-(VRL*STEPTSRL)-(MAXVELOA*STEPTSRL)) > THRESHOLDA) |
        (VRL = 0.0))))&
  /*Sensor Robot A*/
   ((DMAX >= 0.0) &
  (noiseMIN >= 0.0) &
  (noiseMAX >= noiseMIN)
  ->((noiseA >= noiseMIN) &
  (noiseA <= noiseMAX) &
  ((((((XA-X)^2.0)+((YA-Y)^2.0))^0.5)*noiseA) <= DMAX
    ->((((DiffXA^2.0)+(DiffYA^2.0))^0.5) = (((((XA-X)^2.0)+((YA-Y)^2.0))^0.5)*noiseA))) &
  ((((((XA-X)^2.0)+((YA-Y)^2.0))^0.5)*noiseA) > DMAX
    ->((((DiffXA^2.0)+(DiffYA^2.0))^0.5) = DMAX))))
->(
  [
    {
      {
        smallStep:=0.0;
        TDiff:=simTime-simTimeOld;
        simTimeOld:=simTime;
        YAOld := YA;
        XAOld := XA;
        YA:= *;
        XA:= *;
        ?(((XA-XAOld)^2+(YA-YAOld)^2)^0.5<=MAXVELOA*TDiff);
        BY:= *;
        BX:= *;
        YRLOld := YRL;
        XRLOld := XRL;
        YRL:=Y;
        XRL:=X;
      }
      /*Sensor Contract*/
      {
        noiseA:= *;
        noiseB:= *;
        DiffXA:= *;
        DiffYA:= *;
        DirXA:= *;
        DirYA:= *;
        DiffXB:= *;
        DiffYB:= *;
        DirXB:= *;
        DirYB:= *;
        ?((DMAX >= 0.0) &
            (noiseMIN >= 0.0) &
            (noiseMAX >= noiseMIN)
          ->((noiseA >= noiseMIN) &
            (noiseA <= noiseMAX) &
            ((((((XA-X)^2.0)+((YA-Y)^2.0))^0.5)*noiseA) <= DMAX
              ->((((DiffXA^2.0)+(DiffYA^2.0))^0.5) = (((((XA-X)^2.0)+((YA-Y)^2.0))^0.5)*noiseA))) &
            ((((((XA-X)^2.0)+((YA-Y)^2.0))^0.5)*noiseA) > DMAX
              ->((((DiffXA^2.0)+(DiffYA^2.0))^0.5) = DMAX))));
        ?((DMAX >= 0.0) &
            (noiseMIN >= 0.0) &
            (noiseMAX >= noiseMIN)
          ->((noiseB >= noiseMIN) &
            (noiseB <= noiseMAX) &
            ((((((BX-X)^2.0)+((BY-Y)^2.0))^0.5)*noiseB) <= DMAX
              ->((((DiffXB^2.0)+(DiffYB^2.0))^0.5) = (((((BX-X)^2.0)+((BY-Y)^2.0))^0.5)*noiseB))) &
            ((((((BX-X)^2.0)+((BY-Y)^2.0))^0.5)*noiseB) > DMAX
              ->((((DiffXB^2.0)+(DiffYB^2.0))^0.5) = DMAX))));
      }
      /*RL Controller contract*/
      {
        ?(stepClockTSRL >= STEPTSRL);
        stepClockTSRL:=0.0;
        {
          DirXRL:= *;
          DirYRL:= *;
          VRL:= *;
          ?((true)
            ->((VRL >= 0.0) &
              (VRL = 0.0
                <->(DirXRL = 0.0) &
                  (DirYRL = 0.0)) &
              ((((((DiffXA^2.0)+(DiffYA^2.0))^0.5)/noiseMAX-(VRL*STEPTSRL)-(MAXVELOA*STEPTSRL)) > THRESHOLDA) |
                (VRL = 0.0)) &
              ((((((DiffXB^2.0)+(DiffYB^2.0))^0.5)/noiseMAX-(VRL*STEPTSRL)-(MAXVELOB*STEPTSRL)) > THRESHOLDB) |
                (VRL = 0.0))));
        }
      ++
        ?(stepClockTSRL < STEPTSRL);
      }
      /*Motor Control*/
      {
        VXRL:= *;
        VYRL:= *;
        ?((VRL >= 0.0) &
            ((DirXRL != 0.0) | (DirYRL != 0.0))
          ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = VRL)));
        ?((DirXRL = 0.0) & (DirYRL = 0.0)
          ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = 0.0)));
      }
      {
        ?((true));
        {
          simTime' = 1.0,
          stepClockTSRL' = 1.0,
          X' = VXRL,
          Y' = VYRL,
          smallStep' = 1.0
        &((true)) &
          (stepClockTSRL <= STEPTSRL)
        }
      }
    }*
  ] ((((XAOld-XRL)^2+(YAOld-YRL)^2)^0.5>THRESHOLDA)|(XRL=XRLOld&YRL=YRLOld)))
End.
End.""""
