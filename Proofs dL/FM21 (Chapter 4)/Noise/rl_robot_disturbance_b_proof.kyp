Lemma "RL Robot Disturbance B: Proof".
"  ==>  (((simTime) = ((0.0)))&(((SMALLSTEPSIZE()) = ((0.01)))&(((YRL) = (Y))&(((XRL) = (X))&(((stepClockTSRL) = ((0.0)))&(((smallStep) = ((0.0)))&((((STEPTSRL()) >= ((0)))&(((UNUSED()) >= ((0)))&(((MAXVELOB()) >= ((0)))&(((DMAX()) >= ((0)))&(((((((XB)-(XBOld))^((2)))+(((YB)-(YBOld))^((2))))^((0.5))) <= ((MAXVELOB())*(TDiff)))&(((noiseMIN()) >= ((0)))&(((noiseMAX()) >= (noiseMIN()))&((noiseMAX()) >= ((1))))))))))&(((YRLOld) = (YRL))&(((XRLOld) = (XRL))&(((simTimeOld) = (simTime))&(((TDiff) = ((simTime)-(simTimeOld)))&(((((VRL) >= ((0.0)))&(((DirXRL) != ((0.0)))|((DirYRL) != ((0.0)))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = (VRL)))&(((((DirXRL) = ((0.0)))&((DirYRL) = ((0.0))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = ((0.0))))&(((true)->(((VRL) >= ((0.0)))&((((VRL) = ((0.0)))<->(((DirXRL) = ((0.0)))&((DirYRL) = ((0.0)))))&(((((((((DiffXB)^((2.0)))+((DiffYB)^((2.0))))^((0.5)))/(noiseMAX()))-((VRL)*(STEPTSRL())))-((MAXVELOB())*(STEPTSRL()))) > (THRESHOLDB()))|((VRL) = ((0.0)))))))&((((DMAX()) >= ((0.0)))&(((noiseMIN()) >= ((0.0)))&((noiseMAX()) >= (noiseMIN()))))->(((noiseB) >= (noiseMIN()))&(((noiseB) <= (noiseMAX()))&(((((((((XB)-(X))^((2.0)))+(((YB)-(Y))^((2.0))))^((0.5)))*(noiseB)) <= (DMAX()))->(((((DiffXB)^((2.0)))+((DiffYB)^((2.0))))^((0.5))) = ((((((XB)-(X))^((2.0)))+(((YB)-(Y))^((2.0))))^((0.5)))*(noiseB))))&((((((((XB)-(X))^((2.0)))+(((YB)-(Y))^((2.0))))^((0.5)))*(noiseB)) > (DMAX()))->(((((DiffXB)^((2.0)))+((DiffYB)^((2.0))))^((0.5))) = (DMAX())))))))))))))))))))))->([{{{smallStep:=(0.0);};{{TDiff:=(simTime)-(simTimeOld);};{{simTimeOld:=simTime;};{{YA:=*;};{{XA:=*;};{{YBOld:=YB;};{{XBOld:=XB;};{{YB:=*;};{{XB:=*;};{{?((((((XB)-(XBOld))^((2)))+(((YB)-(YBOld))^((2))))^((0.5))) <= ((MAXVELOB())*(TDiff)));};{{YRLOld:=YRL;};{{XRLOld:=XRL;};{{YRL:=Y;};{XRL:=X;}}}}}}}}}}}}}};{{{noiseA:=*;};{{noiseB:=*;};{{DiffXA:=*;};{{DiffYA:=*;};{{DirXA:=*;};{{DirYA:=*;};{{DiffXB:=*;};{{DiffYB:=*;};{{DirXB:=*;};{{DirYB:=*;};{{?((((DMAX()) >= ((0.0)))&(((noiseMIN()) >= ((0.0)))&((noiseMAX()) >= (noiseMIN()))))->(((noiseA) >= (noiseMIN()))&(((noiseA) <= (noiseMAX()))&(((((((((XA)-(X))^((2.0)))+(((YA)-(Y))^((2.0))))^((0.5)))*(noiseA)) <= (DMAX()))->(((((DiffXA)^((2.0)))+((DiffYA)^((2.0))))^((0.5))) = ((((((XA)-(X))^((2.0)))+(((YA)-(Y))^((2.0))))^((0.5)))*(noiseA))))&((((((((XA)-(X))^((2.0)))+(((YA)-(Y))^((2.0))))^((0.5)))*(noiseA)) > (DMAX()))->(((((DiffXA)^((2.0)))+((DiffYA)^((2.0))))^((0.5))) = (DMAX())))))));};{?((((DMAX()) >= ((0.0)))&(((noiseMIN()) >= ((0.0)))&((noiseMAX()) >= (noiseMIN()))))->(((noiseB) >= (noiseMIN()))&(((noiseB) <= (noiseMAX()))&(((((((((XB)-(X))^((2.0)))+(((YB)-(Y))^((2.0))))^((0.5)))*(noiseB)) <= (DMAX()))->(((((DiffXB)^((2.0)))+((DiffYB)^((2.0))))^((0.5))) = ((((((XB)-(X))^((2.0)))+(((YB)-(Y))^((2.0))))^((0.5)))*(noiseB))))&((((((((XB)-(X))^((2.0)))+(((YB)-(Y))^((2.0))))^((0.5)))*(noiseB)) > (DMAX()))->(((((DiffXB)^((2.0)))+((DiffYB)^((2.0))))^((0.5))) = (DMAX())))))));}}}}}}}}}}}};{{{{?((stepClockTSRL) >= (STEPTSRL()));};{{stepClockTSRL:=(0.0);};{{DirXRL:=*;};{{DirYRL:=*;};{{VRL:=*;};{?((true)->(((VRL) >= ((0.0)))&((((VRL) = ((0.0)))<->(((DirXRL) = ((0.0)))&((DirYRL) = ((0.0)))))&((((((((((DiffXA)^((2.0)))+((DiffYA)^((2.0))))^((0.5)))/(noiseMAX()))-((VRL)*(STEPTSRL())))-((MAXVELOA())*(STEPTSRL()))) > (THRESHOLDA()))|((VRL) = ((0.0))))&(((((((((DiffXB)^((2.0)))+((DiffYB)^((2.0))))^((0.5)))/(noiseMAX()))-((VRL)*(STEPTSRL())))-((MAXVELOB())*(STEPTSRL()))) > (THRESHOLDB()))|((VRL) = ((0.0))))))));}}}}}}++{?((stepClockTSRL) < (STEPTSRL()));}};{{{VXRL:=*;};{{VYRL:=*;};{{?((((VRL) >= ((0.0)))&(((DirXRL) != ((0.0)))|((DirYRL) != ((0.0)))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = (VRL)));};{?((((DirXRL) = ((0.0)))&((DirYRL) = ((0.0))))->(((((VXRL)^((2.0)))+((VYRL)^((2.0))))^((0.5))) = ((0.0))));}}}};{{?(true);};{{simTime'=(1.0),stepClockTSRL'=(1.0),X'=VXRL,Y'=VYRL,smallStep'=(1.0)&(true)&((stepClockTSRL) <= (STEPTSRL()))}}}}}}}*](((((((XBOld)-(XRL))^((2)))+(((YBOld)-(YRL))^((2))))^((0.5))) > (THRESHOLDB()))|(((XRL) = (XRLOld))&((YRL) = (YRLOld)))))
\qed::210c2113ee7a7650f1d009b0a04a513c"
End.
Tool.
  tool """"KeYmaera X""""
  model """"ArchiveEntry "RL Robot Disturbance B"

Functions. 
  R SMALLSTEPSIZE.
  R XBUPPERLIMIT.
  R XBLOWERLIMIT.
  R YBUPPERLIMIT.
  R YBLOWERLIMIT.
  R GoalXUPPERLIMIT.
  R GoalXLOWERLIMIT.
  R GoalYUPPERLIMIT.
  R GoalYLOWERLIMIT.
  R XAUPPERLIMIT.
  R XALOWERLIMIT.
  R YAUPPERLIMIT.
  R YALOWERLIMIT.
  R DMAX.
  R noiseMIN.
  R noiseMAX.
  R UNUSED.
  R MAXVELOA.
  R MAXVELOB.
  R THRESHOLDA.
  R THRESHOLDB.
  R STEPTSRL.
End.

ProgramVariables.
  R simTime.
  R simTimeOld.
  R TDiff.
  R XB.
  R YB.
  R XBOld.
  R YBOld.
  R GoalX.
  R GoalY.
  R XA.
  R YA.
  R YRL.
  R XRL.
  R XRLOld.
  R YRLOld.
  R DistToGoal.
  R ArrivedAtGoal.
  R Arrived.
  R Crash.
  R Reward.
  R noiseA.
  R noiseB.
  R DiffXA.
  R DiffYA.
  R DirXA.
  R DirYA.
  R DiffXB.
  R DiffYB.
  R DirXB.
  R DirYB.
  R DirXRL.
  R DirYRL.
  R VRL.
  R VXRL.
  R VYRL.
  R X.
  R Y.
  R smallStep.
  R stepClockTSRL.
End.

Problem.
(
   simTime = 0.0) &
  (SMALLSTEPSIZE = 0.01) &
  (YRL = Y) &
  (XRL = X) &
  (stepClockTSRL = 0.0) &
  (smallStep = 0.0)&
  /*contract assumptions*/
  ( (STEPTSRL>=0)&
    /*MAXVELORL was not needed and is thus removed -> replaced YB UNUSED*/
    (UNUSED>=0)&
    (MAXVELOB>=0)&
    (DMAX>=0) &
    (((XB-XBOld)^2+(YB-YBOld)^2)^0.5<=MAXVELOB*TDiff) &
    (noiseMIN >= 0) &
    (noiseMAX >= noiseMIN) &
    (noiseMAX >=1)) &
  /*init ghost observers*/
  (YRLOld = YRL)&
  (XRLOld = XRL)&
  (simTimeOld=simTime)&
  (TDiff=simTime-simTimeOld)&
  /*contracts moved to init conditions*/
  ( (VRL >= 0.0) &
    ((DirXRL != 0.0) | (DirYRL != 0.0))
  ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = VRL)))&
  ((DirXRL = 0.0) & (DirYRL = 0.0)
  ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = 0.0)))&
  /*RL controller contract*/
  ((true)
    ->((VRL >= 0.0) &
      ( VRL = 0.0 <-> (DirXRL = 0.0) & (DirYRL = 0.0)) &
      ((((((DiffXB^2.0)+(DiffYB^2.0))^0.5)/noiseMAX-(VRL*STEPTSRL)-(MAXVELOB*STEPTSRL)) > THRESHOLDB) | (VRL = 0.0))))&
  /*Sensor contract of opponent B*/
  ( (DMAX >= 0.0) &
  (noiseMIN >= 0.0) &
  (noiseMAX >= noiseMIN)
  ->((noiseB >= noiseMIN) &
  (noiseB <= noiseMAX) &
  ((((((XB-X)^2.0)+((YB-Y)^2.0))^0.5)*noiseB) <= DMAX
    ->((((DiffXB^2.0)+(DiffYB^2.0))^0.5) = (((((XB-X)^2.0)+((YB-Y)^2.0))^0.5)*noiseB))) &
  ((((((XB-X)^2.0)+((YB-Y)^2.0))^0.5)*noiseB) > DMAX
    ->((((DiffXB^2.0)+(DiffYB^2.0))^0.5) = DMAX))))
->(
  [
    {
      {
        smallStep:=0.0;
        TDiff:=simTime-simTimeOld;
        simTimeOld:=simTime;
        YA:= *;
        XA:= *;
        YBOld := YB;
        XBOld := XB;
        YB:= *;
        XB:= *;
        ?(((XB-XBOld)^2+(YB-YBOld)^2)^0.5<=MAXVELOB*TDiff);
        YRLOld := YRL;
        XRLOld := XRL;
        YRL:=Y;
        XRL:=X;
      }
      /*Sensor contract*/
      {
        noiseA:= *;
        noiseB:= *;
        DiffXA:= *;
        DiffYA:= *;
        DirXA:= *;
        DirYA:= *;
        DiffXB:= *;
        DiffYB:= *;
        DirXB:= *;
        DirYB:= *;
        ?((  DMAX >= 0.0) &
            (noiseMIN >= 0.0) &
            (noiseMAX >= noiseMIN)
          ->((noiseA >= noiseMIN) &
            (noiseA <= noiseMAX) &
            ((((((XA-X)^2.0)+((YA-Y)^2.0))^0.5)*noiseA) <= DMAX
              ->((((DiffXA^2.0)+(DiffYA^2.0))^0.5) = (((((XA-X)^2.0)+((YA-Y)^2.0))^0.5)*noiseA))) &
            ((((((XA-X)^2.0)+((YA-Y)^2.0))^0.5)*noiseA) > DMAX
              ->((((DiffXA^2.0)+(DiffYA^2.0))^0.5) = DMAX))));
        ?(( DMAX >= 0.0) &
            (noiseMIN >= 0.0) &
            (noiseMAX >= noiseMIN)
          ->((noiseB >= noiseMIN) &
            (noiseB <= noiseMAX) &
            ((((((XB-X)^2.0)+((YB-Y)^2.0))^0.5)*noiseB) <= DMAX
              ->((((DiffXB^2.0)+(DiffYB^2.0))^0.5) = (((((XB-X)^2.0)+((YB-Y)^2.0))^0.5)*noiseB))) &
            ((((((XB-X)^2.0)+((YB-Y)^2.0))^0.5)*noiseB) > DMAX
              ->((((DiffXB^2.0)+(DiffYB^2.0))^0.5) = DMAX))));
      }
      /*RL controller contract*/
      {
        ?(stepClockTSRL >= STEPTSRL);
        stepClockTSRL:=0.0;
        {
          DirXRL:= *;
          DirYRL:= *;
          VRL:= *;
          ?((true)
            ->((VRL >= 0.0) & (VRL = 0.0
                <->(DirXRL = 0.0) &
                  (DirYRL = 0.0)) &
              ((((((DiffXA^2.0)+(DiffYA^2.0))^0.5)/noiseMAX-(VRL*STEPTSRL)-(MAXVELOA*STEPTSRL)) > THRESHOLDA) |
                (VRL = 0.0)) &
              ((((((DiffXB^2.0)+(DiffYB^2.0))^0.5)/noiseMAX-(VRL*STEPTSRL)-(MAXVELOB*STEPTSRL)) > THRESHOLDB) |
                (VRL = 0.0))));
        }
      ++
        ?(stepClockTSRL < STEPTSRL);
      }
      /*Motor Control*/
      {
        VXRL:= *;
        VYRL:= *;
        ?((VRL >= 0.0) &
            ((DirXRL != 0.0) | (DirYRL != 0.0))
          ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = VRL)));
        ?((DirXRL = 0.0) & (DirYRL = 0.0)
          ->(((((VXRL^2.0)+(VYRL^2.0))^0.5) = 0.0)));
      }
      {
        ?((true));
        {
          simTime' = 1.0,
          stepClockTSRL' = 1.0,
          X' = VXRL,
          Y' = VYRL,
          smallStep' = 1.0
        &((true)) &
          (stepClockTSRL <= STEPTSRL)
        }
      }
    }*
  ] ((((XBOld-XRL)^2+(YBOld-YRL)^2)^0.5>THRESHOLDB)|(XRL=XRLOld&YRL=YRLOld)))
End.

