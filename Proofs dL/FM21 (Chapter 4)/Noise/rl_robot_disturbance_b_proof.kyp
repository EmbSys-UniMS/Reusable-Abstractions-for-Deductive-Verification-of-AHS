        master, 
          discreteGhost("(DiffXB^2.0+DiffYB^2.0)^0.5", "Diff", 'R) ; allL2R(-16) ; discreteGhost("((XB-X)^2.0+(YB-Y)^2.0)^0.5", "DiffUn", 'R) ; hideL(-19=="DiffUn=((XB-X)^2.0+(YB-Y)^2.0)^0.5") ; orL(-13) ; <(
          hideR(2=="VRL=0") ; hideL(-11=="VRL>=0.0") ; hideL(-11=="VRL=0.0<->DirXRL=0.0&DirYRL=0.0") ; hideL(-1=="VRL>=0.0&(DirXRL!=0.0|DirYRL!=0.0)->(VXRL^2.0+VYRL^2.0)^0.5=VRL") ; hideL(-1=="DirXRL=0.0&DirYRL=0.0->(VXRL^2.0+VYRL^2.0)^0.5=0.0") ; hideL(-5=="((XB-XBOld)^2+(YB-YBOld)^2)^0.5<=MAXVELOB()*(0.0-0.0)") ; hideL(-13=="DMAX()=(DiffXB^2.0+DiffYB^2.0)^0.5") ; master, 
