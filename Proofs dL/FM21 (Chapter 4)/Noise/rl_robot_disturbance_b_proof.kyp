hideL(-1=="(((XBPrev-X)^2+(YBPrev-Y)^2)^0.5-VRL*(STEPTSRL()-stepClockTSRL)-MAXVELOB()*(STEPTSRL()-(stepClockTSRL-(simTime-simTimeOldPrev)))>THRESHOLDB()|VRL=0)&(VRL=0<->DirXRL=0&DirYRL=0)&(VRL=0->VXRL=0&VYRL=0)&((XRLPrev-X)^2.0+(YRLPrev-Y)^2.0)^0.5=VRL*(simTime-simTimeOldPrev)&VRL=(VXRL^2+VYRL^2)^0.5&(((XBOldPrev-XRLPrev)^2+(YBOldPrev-YRLPrev)^2)^0.5>THRESHOLDB()|XRLPrev=XRLOldPrev&YRLPrev=YRLOldPrev)&VRL>=0&STEPTSRL()>=stepClockTSRL&stepClockTSRL>=0&simTime>=simTimeOldPrev&simTimeOldPrev>=0&stepClockTSRL>=simTime-simTimeOldPrev") ; master, 
