    hideL(-3=="true->VRL>=0.0&(VRL=0.0<->DirXRL=0.0&DirYRL=0.0)&((DiffXB^2.0+DiffYB^2.0)^0.5/noiseMAX()-VRL*STEPTSRL()-MAXVELOB()*STEPTSRL()>THRESHOLDB()|VRL=0.0)") ; hideL(-3=="DMAX()>=0.0&noiseMIN()>=0.0&noiseMAX()>=noiseMIN()->noiseB>=noiseMIN()&noiseB<=noiseMAX()&(((XB-X)^2.0+(YB-Y)^2.0)^0.5*noiseB<=DMAX()->(DiffXB^2.0+DiffYB^2.0)^0.5=((XB-X)^2.0+(YB-Y)^2.0)^0.5*noiseB)&(((XB-X)^2.0+(YB-Y)^2.0)^0.5*noiseB>DMAX()->(DiffXB^2.0+DiffYB^2.0)^0.5=DMAX())") ; hideL(-7=="((XB-XBOld)^2+(YB-YBOld)^2)^0.5<=MAXVELOB()*(0.0-0.0)") ; master, 
      andR(1) ; <(
